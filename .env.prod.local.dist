# Copy to `.env.prod.local` on the production server — file is ignored by Git.
# Prerequisite: project root `.env.local` must set `APP_ENV=prod`
#              (Symfony then loads `.env.prod` then this file.)

### Required in production — generate once:  openssl rand -hex 32
APP_SECRET=

### MariaDB from hosting (user / db / host as provided)
DATABASE_URL="mysql://USERNAME:PASSWORD@127.0.0.1:3306/lowpartners_app?serverVersion=mariadb-10.11.2&charset=utf8mb4"

### HTTPS canonical host (routers, mail links, console URL generation)
DEFAULT_URI="https://lowpartners.net"

{% extends 'base.html.twig' %}

{% block title %}Optický sklad{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .home-title {
            margin-top: 0.15rem;
            margin-bottom: 0.5rem;
        }
        /* Přihlášení: výchozí větší pole (desktop); mobil níže ještě zvětšit / na celou šířku */
        .home-login-form {
            max-width: 32rem;
        }
        .home-login-form > p {
            margin: 0.9rem 0;
        }
        .home-login-form label {
            display: block;
            font-size: 1.08rem;
            font-weight: 600;
            margin-bottom: 0.4rem;
            line-height: 1.3;
        }
        .home-login-form input[type="text"],
        .home-login-form input[type="password"] {
            width: 100%;
            max-width: 100%;
            box-sizing: border-box;
            -webkit-appearance: none;
            appearance: none;
            font-size: 1.25rem;
            line-height: 1.35;
            min-height: 3rem;
            padding: 0.7rem 0.95rem;
            border: 1px solid #8a9399;
            border-radius: 8px;
        }
        .home-login-form button[type="submit"] {
            box-sizing: border-box;
            min-height: 3rem;
            font-size: 1.15rem;
            font-weight: 600;
            padding: 0.65rem 1.35rem;
            border-radius: 8px;
            margin-top: 0.35rem;
            cursor: pointer;
            -webkit-appearance: none;
            appearance: none;
        }
        .home-login-form .home-login-form__hint {
            font-size: 0.95rem !important;
            line-height: 1.45;
            margin-top: 0.25rem !important;
        }
        /*
         * Mobil / landscape: 60rem pokryje většinu telefonů na šířku; min. 16–18px kvůli Chrome / měřítku.
         */
        @media (max-width: 60rem) {
            .home-login-form {
                max-width: 100%;
            }
            .home-login-form label {
                font-size: max(1.02rem, 16px);
            }
            .home-login-form input[type="text"],
            .home-login-form input[type="password"] {
                font-size: max(1.125rem, 18px);
            }
            .home-login-form button[type="submit"] {
                width: 100%;
                font-size: max(1.125rem, 18px);
            }
            .home-login-form .home-login-form__hint {
                font-size: max(0.95rem, 15px) !important;
                margin-top: 1rem !important;
            }
        }
    </style>
{% endblock %}

{% block body %}
    {% if app.user %}
        <nav class="app-menu app-menu--toolbar" aria-label="Účet a odhlášení">
            {% include '_app_menu_cz_top.html.twig' %}
        </nav>
    {% endif %}
    <h1 {% if app.user %}class="home-title"{% endif %}>Optický sklad</h1>

    {% if app.user %}
        <nav class="app-menu" aria-label="Hlavní nabídka">
            {% include '_app_menu_cz_main_links.html.twig' %}
        </nav>
        <hr style="border: 0; border-top: 1px solid #ccc; margin: 0 0 1rem;">
        <p>Jste přihlášen(a) jako <strong>{{ app.user.displayName }}</strong> (uživatel: <code>{{ app.user.userIdentifier }}</code>).</p>
    {% else %}
        <h2>Přihlášení</h2>
        {% include '_login_form.html.twig' with { last_username: last_username|default(''), error: error|default(null) } only %}
        <p style="margin-top: 1.1rem;">
            <a class="warehouse-pill" href="{{ path('app_mobile_info') }}">Android aplikace (APK)</a>
        </p>
    {% endif %}
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}Optický sklad{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .home-title {
            margin-top: 0.15rem;
            margin-bottom: 0.5rem;
        }
        /*
         * Přihlášení: Android v landscape / „širší“ viewport často přesahuje 36rem → bez stylů mrňavá pole.
         * 60rem (~960px) pokryje většinu mobilů i na šířku; min. 16px kvůli Android Chrome / měřítku systému.
         */
        .home-admin-cta {
            max-width: 44rem;
            margin: 0 0 1rem;
            padding: 0.85rem 1rem 1rem;
            border: 1px solid #c5d2e0;
            border-radius: 8px;
            background: linear-gradient(180deg, #f0f6fc 0%, #e8eef8 100%);
        }
        .home-admin-cta__title {
            margin: 0 0 0.35rem;
            font-size: 1.05rem;
            color: #0a1628;
        }
        .home-admin-cta__lede {
            margin: 0 0 0.85rem;
            font-size: 0.88rem;
            color: #3a4654;
            line-height: 1.42;
        }
        .home-admin-cta__actions {
            display: flex;
            flex-wrap: wrap;
            gap: 0.55rem 0.65rem;
            align-items: stretch;
        }
        @media (max-width: 26rem) {
            .home-admin-cta__actions {
                flex-direction: column;
            }
            .home-admin-cta__actions > a {
                width: 100%;
            }
        }
        @media (max-width: 60rem) {
            .home-login-form {
                max-width: 100%;
            }
            .home-login-form > p {
                margin: 0.9rem 0;
            }
            .home-login-form label {
                display: block;
                font-size: max(1.02rem, 16px);
                font-weight: 600;
                margin-bottom: 0.35rem;
                line-height: 1.3;
            }
            .home-login-form input[type="text"],
            .home-login-form input[type="password"] {
                width: 100%;
                max-width: 100%;
                box-sizing: border-box;
                -webkit-appearance: none;
                appearance: none;
                font-size: max(1.125rem, 18px);
                line-height: 1.35;
                min-height: 3rem;
                padding: 0.7rem 0.85rem;
                border: 1px solid #8a9399;
                border-radius: 8px;
            }
            .home-login-form button[type="submit"] {
                width: 100%;
                box-sizing: border-box;
                min-height: 3rem;
                font-size: max(1.125rem, 18px);
                font-weight: 600;
                padding: 0.65rem 1rem;
                border-radius: 8px;
                margin-top: 0.35rem;
                -webkit-appearance: none;
                appearance: none;
            }
            .home-login-form .home-login-form__hint {
                font-size: max(0.95rem, 15px) !important;
                line-height: 1.45;
                margin-top: 1rem !important;
            }
        }
    </style>
{% endblock %}

{% block body %}
    {% if app.user %}
        <nav class="app-menu app-menu--toolbar" aria-label="Účet a odhlášení">
            {% include '_app_menu_cz_top.html.twig' %}
        </nav>
    {% endif %}
    <h1 {% if app.user %}class="home-title"{% endif %}>Optický sklad</h1>

    {% if app.user %}
        {% if is_granted('ROLE_APP_ADMIN') %}
            <section class="home-admin-cta" aria-label="Správa uživatelů a sledování">
                <h2 class="home-admin-cta__title">Správa uživatelů a sledování</h2>
                <p class="home-admin-cta__lede">
                    Účty, úrovně oprávnění (VIEW / EDIT / správce katalogu / aplikační admin) a protokol požadavků (jaké stránky uživatel otevřel a jaké měl zápisy).
                </p>
                <div class="home-admin-cta__actions">
                    <a class="warehouse-pill" href="{{ path('app_admin_users_index') }}">Uživatelé a&nbsp;role</a>
                    <a class="warehouse-pill" href="{{ path('app_admin_audit_index') }}">Monitoring (HTTP&nbsp;log)</a>
                </div>
            </section>
        {% endif %}
        <nav class="app-menu" aria-label="Hlavní nabídka">
            {% include '_app_menu_cz_main_links.html.twig' %}
        </nav>
        <hr style="border: 0; border-top: 1px solid #ccc; margin: 0 0 1rem;">
        <p>Jste přihlášen(a) jako <strong>{{ app.user.displayName }}</strong> (uživatel: <code>{{ app.user.userIdentifier }}</code>).</p>
    {% else %}
        <h2>Přihlášení</h2>
        {% include '_login_form.html.twig' with { last_username: last_username|default(''), error: error|default(null) } only %}
    {% endif %}
{% endblock %}

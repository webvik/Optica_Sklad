{% extends 'base.html.twig' %}
{% block title %}Nový uživatel{% endblock %}
{% block stylesheets %}
    {{ parent() }}
    {% include '_styles_spool_form_layout.html.twig' %}
{% endblock %}
{% block body %}
    <nav class="app-menu app-menu--toolbar" aria-label="Účet a navigace správy">
        {% include '_app_menu_cz_top.html.twig' %}
    </nav>
    <p style="margin:0 0 1rem"><a href="{{ path('app_admin_users_index') }}">← zpět na Správu uživatelů</a></p>
    <h1>Nový uživatel</h1>
    <p class="spool-form" style="margin: 0 0 1rem; max-width: 40rem">
        Po uložení může jít uživatel na domovskou stránku a přihlásit se nastaveným jménem a heslem.
        Úroveň oprávnění můžete změnit kdykoli v <strong>Upravit</strong>.
    </p>

    {{ form_start(form, { attr: { class: 'spool-form', id: 'admin-user-create-form' } }) }}
        <div class="spool-form__field">
            {{ form_label(form.firstName) }}
            <div class="spool-form__value">
                {{ form_widget(form.firstName, { attr: { 'aria-label': form.firstName.vars.label } }) }}
                {{ form_errors(form.firstName) }}
            </div>
        </div>
        <div class="spool-form__field">
            {{ form_label(form.lastName) }}
            <div class="spool-form__value">
                {{ form_widget(form.lastName, { attr: { 'aria-label': form.lastName.vars.label } }) }}
                {{ form_errors(form.lastName) }}
            </div>
        </div>
        <div class="spool-form__field">
            {{ form_label(form.phone) }}
            <div class="spool-form__value">
                {{ form_widget(form.phone, { attr: { 'aria-label': form.phone.vars.label, maxlength: 32 } }) }}
                {{ form_help(form.phone) }}
                {{ form_errors(form.phone) }}
            </div>
        </div>
        <div class="spool-form__field">
            {{ form_label(form.username) }}
            <div class="spool-form__value">
                {{ form_widget(form.username, { attr: { 'aria-label': form.username.vars.label } }) }}
                {{ form_help(form.username) }}
                {{ form_errors(form.username) }}
            </div>
        </div>
        <div class="spool-form__field">
            {{ form_label(form.plainPassword.first) }}
            <div class="spool-form__value">
                {{ form_widget(form.plainPassword.first) }}
                {{ form_errors(form.plainPassword.first) }}
            </div>
        </div>
        <div class="spool-form__field">
            {{ form_label(form.plainPassword.second) }}
            <div class="spool-form__value">
                {{ form_widget(form.plainPassword.second) }}
                {{ form_errors(form.plainPassword.second) }}
                {{ form_errors(form.plainPassword) }}
            </div>
        </div>
        {% do form.plainPassword.setRendered() %}
        <div class="spool-form__field">
            {{ form_label(form.email) }}
            <div class="spool-form__value">
                {{ form_widget(form.email, { attr: { 'aria-label': form.email.vars.label } }) }}
                {{ form_errors(form.email) }}
            </div>
        </div>
        <div class="spool-form__field">
            {{ form_label(form.offerWhatsAppHandoff) }}
            <div class="spool-form__value">
                {{ form_widget(form.offerWhatsAppHandoff, { attr: { 'aria-label': form.offerWhatsAppHandoff.vars.label } }) }}
                {{ form_help(form.offerWhatsAppHandoff) }}
                {{ form_errors(form.offerWhatsAppHandoff) }}
            </div>
        </div>
        <div class="spool-form__field">
            {{ form_label(form.accessLevel) }}
            <div class="spool-form__value">
                {{ form_widget(form.accessLevel) }}
                {{ form_errors(form.accessLevel) }}
            </div>
        </div>

        <div class="spool-form__field spool-form__row--actions" style="margin-top: 0.25rem; margin-bottom: 0.25rem;">
            <span class="spool-form__row--action-spacer" aria-hidden="true"></span>
            <div class="spool-form__value spool-form__value--actions">
                <div class="spool-form__actions spool-form__actions--submit-only" role="group" aria-label="Akce">
                    {{ form_widget(form.save, { attr: { class: 'spool-form__btn' } }) }}
                </div>
            </div>
        </div>

        {{ form_rest(form) }}
    {{ form_end(form, { render_rest: false }) }}
{% endblock %}
{% block javascripts %}
    {{ parent() }}
    <script>
    (function () {
        var form = document.getElementById('admin-user-create-form');
        if (!form) return;

        var elUser = document.getElementById({{ form.username.vars.id|json_encode|raw }});
        var elFirst = document.getElementById({{ form.firstName.vars.id|json_encode|raw }});
        var elLast = document.getElementById({{ form.lastName.vars.id|json_encode|raw }});
        if (!elUser || !elFirst || !elLast) return;

        function slugPart(s) {
            if (!s) return '';
            var t = String(s).normalize('NFD').replace(/\p{M}/gu, '');
            t = t.toLowerCase();
            t = t.replace(/[^a-z0-9._-]/g, '');
            t = t.replace(/\.{2,}/g, '.');
            t = t.replace(/^\.+|\.+$/g, '');
            return t;
        }

        function suggestedLogin(firstVal, lastVal) {
            var a = slugPart(String(firstVal || '').trim());
            var b = slugPart(String(lastVal || '').trim());
            if (a && b) return a + '.' + b;
            if (a) return a;
            if (b) return b;
            return '';
        }

        var locked = false;
        var lastSuggested = '';

        function applyFromNames() {
            var s = suggestedLogin(elFirst.value, elLast.value);
            lastSuggested = s;
            if (!locked) {
                elUser.value = s;
            }
        }

        function onUsernameInput() {
            var v = elUser.value;
            var s = suggestedLogin(elFirst.value, elLast.value);
            lastSuggested = s;
            if (v === '' || v === s) {
                locked = false;
                elUser.value = s;
                return;
            }
            locked = true;
        }

        elFirst.addEventListener('input', applyFromNames);
        elLast.addEventListener('input', applyFromNames);
        elUser.addEventListener('input', onUsernameInput);

        /* Po načtení (např. chyba validace): odhadnout, zda login uživatelsky upraven */
        lastSuggested = suggestedLogin(elFirst.value, elLast.value);
        var u0 = String(elUser.value || '').trim();
        if (u0 === '') {
            locked = false;
        } else {
            locked = u0 !== lastSuggested;
        }
        if (!locked) {
            elUser.value = lastSuggested;
        }
    })();
    </script>
{% endblock %}

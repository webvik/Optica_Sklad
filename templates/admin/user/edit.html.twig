{% extends 'base.html.twig' %}
{% block title %}Upravit uživatele{% endblock %}
{% block stylesheets %}
    {{ parent() }}
    {% include '_styles_spool_form_layout.html.twig' %}
    <style>
        .spool-form__btn--danger {
            border-color: #c44;
            background: #fef2f2;
            color: #8b1a1a;
        }
        .spool-form__btn--danger:hover { background: #fde8e8; }
        .spool-form__btn--danger:active { background: #f8d4d4; }
        .spool-form__delete-hint { font-size: 0.88rem; color: #666; max-width: 14rem; line-height: 1.35; }
    </style>
{% endblock %}
{% block body %}
    <nav class="app-menu app-menu--toolbar" aria-label="Účet a navigace správy">
        {% include '_app_menu_cz_top.html.twig' %}
    </nav>
    <p style="margin:0 0 1rem"><a href="{{ path('app_admin_users_index') }}">← zpět na Správu uživatelů</a></p>
    <h1>Upravit uživatele</h1>
    <p class="spool-form" style="margin: 0 0 1rem; max-width: 40rem">
        Účet: <strong><code>{{ editUser.userIdentifier }}</code></strong>
        {% if editUser.displayName %} — {{ editUser.displayName }}{% endif %}
    </p>

    {% if form.vars.submitted and not form.vars.valid %}
        <div class="flashes" role="alert" style="margin-bottom: 1rem;">
            <p style="margin:0;padding:.65rem 1rem;border-radius:4px;max-width:40rem;background:#fee;color:#600;border:1px solid #e0b0b0;">
                Změny nebyly uloženy — opravte chyby ve formuláři níže.
            </p>
        </div>
    {% endif %}

    {{ form_start(form, { attr: { class: 'spool-form', id: 'admin-user-edit-form' } }) }}
        <div class="spool-form__field">
            {{ form_label(form.isActive) }}
            <div class="spool-form__value">
                {{ form_widget(form.isActive, { attr: { 'aria-label': form.isActive.vars.label } }) }}
                {{ form_errors(form.isActive) }}
            </div>
        </div>
        <div class="spool-form__field">
            {{ form_label(form.phone) }}
            <div class="spool-form__value">
                {{ form_widget(form.phone, { attr: { 'aria-label': form.phone.vars.label, maxlength: 32 } }) }}
                {{ form_help(form.phone) }}
                {{ form_errors(form.phone) }}
            </div>
        </div>

        <div class="spool-form__field">
            {{ form_label(form.newPasswordPlain.first) }}
            <div class="spool-form__value">
                {{ form_widget(form.newPasswordPlain.first) }}
                {{ form_errors(form.newPasswordPlain.first) }}
            </div>
        </div>
        <div class="spool-form__field">
            {{ form_label(form.newPasswordPlain.second) }}
            <div class="spool-form__value">
                {{ form_widget(form.newPasswordPlain.second) }}
                {{ form_errors(form.newPasswordPlain.second) }}
                {{ form_errors(form.newPasswordPlain) }}
                {{ form_help(form.newPasswordPlain) }}
            </div>
        </div>
        {% do form.newPasswordPlain.setRendered() %}

        <div class="spool-form__field">
            {{ form_label(form.accessLevel) }}
            <div class="spool-form__value">
                {{ form_widget(form.accessLevel) }}
                {{ form_errors(form.accessLevel) }}
            </div>
        </div>

        <div class="spool-form__field spool-form__row--actions" style="margin-top: 0.25rem; margin-bottom: 0.25rem;">
            <span class="spool-form__row--action-spacer" aria-hidden="true"></span>
            <div class="spool-form__value spool-form__value--actions">
                <div class="spool-form__actions" role="group" aria-label="Akce">
                    {% if canDeleteUser %}
                        <input type="hidden" name="_delete_token" value="{{ csrf_token('admin_user_delete') }}">
                        <button type="submit"
                                class="spool-form__btn spool-form__btn--danger"
                                formaction="{{ path('app_admin_users_delete', { id: editUser.id }) }}"
                                formmethod="post"
                                onclick="return confirm('Opravdu smazat účet «{{ editUser.userIdentifier|e('js') }}»? Tuto akci nelze vrátit.');">
                            Smazat
                        </button>
                    {% elseif deleteUserBlockedReason %}
                        <span class="spool-form__delete-hint" title="{{ deleteUserBlockedReason }}">Smazat — {{ deleteUserBlockedReason }}</span>
                    {% endif %}
                    {{ form_widget(form.save, { attr: { class: 'spool-form__btn' } }) }}
                </div>
            </div>
        </div>

        {{ form_rest(form) }}
    {{ form_end(form, { render_rest: false }) }}
{% endblock %}

{% extends 'base.html.twig' %}
{% block title %}{{ title }}{% endblock %}
{% block stylesheets %}
    {{ parent() }}
    <style>
        .spool-form { max-width: 40rem; line-height: 1.6; }
        .spool-form__field {
            display: grid;
            grid-template-columns: minmax(0, 8rem) minmax(0, 1fr);
            column-gap: 0.45rem;
            row-gap: 0.2rem;
            margin: 0 0 0.75rem;
            align-items: start;
        }
        .spool-form__field > label, .spool-form__field > .spool-form__static-label {
            font-weight: 600;
            font-size: 0.84rem;
            line-height: 1.25;
            padding-top: 0.28rem;
            word-break: break-word;
            hyphens: auto;
        }
        .spool-form__readout { margin: 0; font-size: 0.88rem; line-height: 1.35; color: #333; }
        .spool-form__value { min-width: 0; text-align: left; }
        .spool-form__value .form-error, .spool-form__value ul, .spool-form__value p.help-text { margin: 0.25rem 0 0; display: block; }
        .spool-form__value p.form-text, .spool-form__value p.help-text, .spool-form__value small { font-size: 0.85rem; line-height: 1.4; color: #555; text-align: left; }
        .spool-form__value [type="date"], .spool-form__value [type="number"],
        .spool-form__value [type="text"], .spool-form__value textarea, .spool-form__value select {
            max-width: 100%; box-sizing: border-box;
        }
        .spool-form__value input, .spool-form__value select, .spool-form__value textarea { text-align: left; width: 100%; }
        @media (min-width: 42rem) {
            .spool-form__field { grid-template-columns: 12.5rem 1fr; column-gap: 1.5rem; margin-bottom: 0.9rem; }
            .spool-form__row--actions { grid-template-columns: 12.5rem 1fr; }
            .spool-form__field > label, .spool-form__field > .spool-form__static-label { font-size: 1.06rem; line-height: 1.45; padding-top: 0.2rem; }
            .spool-form__value > input, .spool-form__value > select, .spool-form__value > textarea { max-width: 24rem; margin-left: auto; display: block; }
            .spool-form__value p.form-text, .spool-form__value p.help-text { max-width: 24rem; margin-left: auto; }
            .spool-form__value--actions .spool-form__actions { max-width: 24rem; margin-left: auto; }
            .spool-form__value > ul, .spool-form__value .form-error { text-align: left; margin-left: auto; max-width: 24rem; }
        }
        @media (max-width: 41.99rem) {
            .spool-form__row--action-spacer { display: none !important; }
            .spool-form__row--actions .spool-form__value--actions { grid-column: 1 / -1; }
        }
        .spool-form__actions { display: flex; flex-direction: row; justify-content: space-between; align-items: center; gap: 0.65rem; flex-wrap: wrap; width: 100%; }
        @media (min-width: 42rem) {
            .spool-form__row--actions .spool-form__value--actions { width: 100%; }
        }
        .spool-form__btn, .spool-form__actions button[type="submit"] {
            box-sizing: border-box; display: inline-flex; align-items: center; justify-content: center;
            min-height: 2.55rem; min-width: 5.5rem; padding: 0.45rem 1rem; font: inherit; font-size: 1rem; font-weight: 500;
            line-height: 1.2; border: 1px solid #bbb; border-radius: 4px; background: #f5f5f5; color: #1a1a1a; cursor: pointer;
        }
        .spool-form__btn:hover, .spool-form__actions button[type="submit"]:hover { background: #eaeaec; }
        .spool-form__btn:active, .spool-form__actions button[type="submit"]:active { background: #e0e0e2; }
        .spool-form__row--action-spacer { display: none; }
        @media (min-width: 42rem) {
            .spool-form__row--action-spacer { display: block; min-height: 1px; }
        }
        .spool-form--cable-type textarea { min-height: 5.5rem; }
        .spool-form--cable-type .spool-form__value--checkboxes input[type="checkbox"] { width: auto; margin: 0.24rem 0 0; }
        /** Šedý příklad kódu zásoby z DB (placeholder) */
        #{{ form.code.vars.id }}::placeholder {
            color: #8c8c8c;
            opacity: 1;
        }
        @media (min-width: 42rem) {
            .spool-form--cable-type .spool-form__value--checkboxes { max-width: 24rem; margin-left: auto; text-align: left; }
        }
        #cable-type-form-scan-overlay[hidden] { display: none !important; }
        #cable-type-form-scan-overlay {
            position: fixed; inset: 0; z-index: 9999; background: rgba(0,0,0,.75);
            display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 1rem; padding: 1rem;
        }
        #cable-type-form-scan-video { max-width: min(100%, 640px); max-height: 50vh; background: #111; border-radius: 6px; }
        /* OCR štítku → heuristické doplnění formuláře (bez katalogového párování) */
        #cable-type-label-ocr-overlay[hidden] { display: none !important; }
        #cable-type-label-ocr-overlay {
            position: fixed; inset: 0; z-index: 10005;
            background: rgba(0, 0, 0, 0.78);
            display: flex; flex-direction: column; align-items: center; justify-content: center;
            gap: 0.75rem; padding: 1rem; box-sizing: border-box;
        }
        #cable-type-label-ocr-text {
            color: #fff; margin: 0; text-align: center; max-width: 36rem;
            font-size: 0.92rem; line-height: 1.4; padding: 0 0.35rem;
        }
        #cable-type-label-ocr-video-wrap {
            width: min(100%, 28rem); height: clamp(4.5rem, 13vh, 6.75rem); overflow: hidden;
            border-radius: 8px; border: 2px solid rgba(95, 200, 255, 0.88); background: #111;
            flex-shrink: 0; box-sizing: border-box;
        }
        #cable-type-label-ocr-video { display: block; width: 100%; height: 100%; object-fit: cover; object-position: center center; }
        #cable-type-label-ocr-read {
            flex: 1 1 auto; min-width: min(100%, 12rem); min-height: 2.55rem;
            padding: 0.5rem 1rem; font: inherit; font-size: 1rem; font-weight: 600; color: #1a1a1a;
            cursor: pointer; border-radius: 6px;
            border: 2px solid rgba(95, 200, 255, 0.95); background: rgba(200, 240, 255, 0.98);
        }
        #cable-type-label-ocr-read:hover:not(:disabled) { background: rgba(170, 230, 255, 1); }
        #cable-type-label-ocr-read:disabled { opacity: 0.5; cursor: progress; pointer-events: none; }
        #cable-type-label-ocr-editor[hidden] { display: none !important; }
        #cable-type-label-ocr-editor { width: min(100%, 28rem); box-sizing: border-box; }
        #cable-type-label-ocr-draft {
            width: 100%; box-sizing: border-box; min-height: 5.5rem;
            padding: 0.5rem 0.65rem; font: inherit; font-size: 1.12rem; line-height: 1.45;
            border-radius: 6px; border: 1px solid rgba(180, 220, 255, 0.55);
            background: rgba(18, 22, 28, 0.96); color: #f0f6fa; resize: vertical;
        }
        #cable-type-label-ocr-apply-suggest {
            margin-top: 0.65rem; width: 100%; min-height: 2.6rem;
            padding: 0.45rem 1rem; font: inherit; font-size: 0.98rem; font-weight: 600;
            color: #fff; cursor: pointer; border-radius: 6px;
            border: 2px solid rgba(120, 200, 140, 0.95); background: rgba(40, 105, 62, 0.95);
        }
        #cable-type-label-ocr-apply-suggest:hover:not(:disabled) { background: rgba(48, 128, 75, 1); }
        #cable-type-label-ocr-apply-suggest:disabled { opacity: 0.45; cursor: not-allowed; pointer-events: none; }
    </style>
{% endblock %}
{% block body %}
    {% include '_app_menu_cz.html.twig' %}
    <h1>{{ title }}</h1>
    {{ form_start(form, { attr: { class: 'spool-form spool-form--cable-type', id: 'cable-type-catalog-form' } }) }}
        <div class="spool-form__field">
            {{ form_label(form.code) }}
            <div class="spool-form__value">
                {% set codePh = (codeFieldPlaceholder|default(''))|trim %}
                {% if codePh is not empty %}
                    {{ form_widget(form.code, { attr: { placeholder: ('např. ' ~ codePh) } }) }}
                {% else %}
                    {{ form_widget(form.code) }}
                {% endif %}
                {{ form_errors(form.code) }}
            </div>
        </div>
        <div class="spool-form__field">
            <span class="spool-form__static-label">Stručný název</span>
            <div class="spool-form__value">
                <p class="spool-form__readout">{{ cableListLabelPreview }}</p>
            </div>
        </div>
        <div class="spool-form__field">
            {{ form_label(form.fullDescription) }}
            <div class="spool-form__value">
                {{ form_widget(form.fullDescription) }}
                {{ form_errors(form.fullDescription) }}
            </div>
        </div>
        <div class="spool-form__field">
            {{ form_label(form.family) }}
            <div class="spool-form__value">
                {{ form_widget(form.family) }}
                {{ form_errors(form.family) }}
            </div>
        </div>
        <div class="spool-form__field">
            {{ form_label(form.fiberCount) }}
            <div class="spool-form__value">
                {{ form_widget(form.fiberCount) }}
                {{ form_errors(form.fiberCount) }}
            </div>
        </div>
        <div class="spool-form__field">
            {{ form_label(form.constructionCode) }}
            <div class="spool-form__value">
                {{ form_widget(form.constructionCode) }}
                {{ form_errors(form.constructionCode) }}
            </div>
        </div>
        <div class="spool-form__field">
            {{ form_label(form.diameterMm) }}
            <div class="spool-form__value">
                {{ form_widget(form.diameterMm) }}
                {{ form_errors(form.diameterMm) }}
            </div>
        </div>
        <div class="spool-form__field">
            {{ form_label(form.isActive) }}
            <div class="spool-form__value spool-form__value--checkboxes">
                {{ form_widget(form.isActive) }}
                {{ form_errors(form.isActive) }}
            </div>
        </div>
        <div class="spool-form__field spool-form__row--actions" style="margin-top: 0.25rem; margin-bottom: 0.25rem;">
            <span class="spool-form__row--action-spacer" aria-hidden="true"></span>
            <div class="spool-form__value spool-form__value--actions">
                <div class="spool-form__actions" role="group" aria-label="Akce">
                    <button type="button" class="spool-form__btn" id="cable-type-label-ocr-open" title="OCR řádku štítku — doplní rozpoznaná pole, kde jsou prázdná">
                        OCR štítek
                    </button>
                    <button type="button" class="spool-form__btn" id="cable-type-form-scan" title="Sken čárového kódu do pole Kód zásoby">Sken</button>
                    <button type="submit" class="spool-form__btn">Uložit</button>
                </div>
            </div>
        </div>
        {{ form_rest(form) }}
    {{ form_end(form, { render_rest: false }) }}
    <div id="cable-type-form-scan-overlay" hidden role="dialog" aria-label="Sken čárového kódu">
        <p id="cable-type-form-scan-overlay-text" style="color:#fff;margin:0;text-align:center;max-width:34rem"></p>
        <video id="cable-type-form-scan-video" playsinline autoplay muted></video>
        <button type="button" id="cable-type-form-scan-cancel" class="spool-form__btn" style="color:#1a1a1a">Zrušit</button>
    </div>
    <div id="cable-type-label-ocr-overlay" hidden role="dialog" aria-label="OCR řádek štítku kabelu">
        <p id="cable-type-label-ocr-text"></p>
        <div id="cable-type-label-ocr-video-wrap"><video id="cable-type-label-ocr-video" playsinline autoplay muted></video></div>
        <button type="button" id="cable-type-label-ocr-read">Přečíst řádek (OCR)</button>
        <div id="cable-type-label-ocr-editor" hidden>
            <label for="cable-type-label-ocr-draft" class="spool-form__static-label" style="display:block;color:#fff;text-align:center;font-weight:600;margin:0 0 0.35rem">Text ze štítku — upravte a pak doplněte formulář</label>
            <textarea id="cable-type-label-ocr-draft" rows="5" autocomplete="off" spellcheck="true"></textarea>
            <button type="button" id="cable-type-label-ocr-apply-suggest">Doplnit prázdná pole formuláře</button>
        </div>
        <button type="button" id="cable-type-label-ocr-cancel" class="spool-form__btn" style="color:#1a1a1a">Zrušit</button>
    </div>
    <div style="max-width: 40rem; margin: 0 auto; box-sizing: border-box;">
        <p style="margin: 0.85rem 0 0.35rem; display: flex; flex-wrap: wrap; gap: 0.65rem; align-items: center; justify-content: center;">
            <a class="warehouse-pill" href="{{ path('warehouse_spool_new') }}">Nová cívka do evidence</a>
        </p>
        <p style="margin: 0; text-align: center;"><a href="{{ path('warehouse_cable_type_index') }}">← zpět na seznam</a></p>
    </div>
{% endblock %}
{% block javascripts %}
    {{ parent() }}
    <script crossorigin referrerpolicy="no-referrer" src="https://cdn.jsdelivr.net/npm/tesseract.js@5/dist/tesseract.min.js"></script>
    <script type="application/json" id="cable-type-label-ocr-cfg">{{ {
        suggestUrl: path('warehouse_cable_type_label_ocr_suggest'),
        csrf: csrf_token('cable_type_label_ocr_suggest'),
    }|json_encode(256)|raw }}</script>
    <script>
(function () {
  var codeIn = document.getElementById({{ form.code.vars.id|json_encode|raw }});
  var scanBtn = document.getElementById('cable-type-form-scan');
  var scanOverlay = document.getElementById('cable-type-form-scan-overlay');
  var scanVideo = document.getElementById('cable-type-form-scan-video');
  var scanCancel = document.getElementById('cable-type-form-scan-cancel');
  var scanOverlayText = document.getElementById('cable-type-form-scan-overlay-text');
  var scanRaf = null, scanStream = null;
  function setScanText() {
    if (scanOverlayText) {
      scanOverlayText.textContent = 'Sken: po rozpoznání se vyplní pole Kód zásoby (případně doplňte a uložte).';
    }
  }
  function stopBarcodeScan() {
    if (scanRaf) { cancelAnimationFrame(scanRaf); scanRaf = null; }
    if (scanStream) {
      scanStream.getTracks().forEach(function (t) { t.stop(); });
      scanStream = null;
    }
    if (scanVideo) scanVideo.srcObject = null;
    if (scanOverlay) scanOverlay.hidden = true;
  }
  function focusCode() {
    if (codeIn) {
      codeIn.focus();
      try { codeIn.select(); } catch (e) {}
    }
  }
  function onScanDecoded(v) {
    v = String(v).trim();
    if (!v.length) return;
    stopBarcodeScan();
    if (codeIn) codeIn.value = v;
  }
  function startBarcodeScan() {
    if (!scanOverlay || !scanVideo) { focusCode(); return; }
    setScanText();
    scanOverlay.hidden = false;
    navigator.mediaDevices.getUserMedia({ video: { facingMode: { ideal: 'environment' } } })
      .then(function (stream) {
        scanStream = stream;
        scanVideo.srcObject = stream;
        return scanVideo.play();
      })
      .then(function () {
        if (typeof window.BarcodeDetector === 'undefined') {
          stopBarcodeScan();
          focusCode();
          return;
        }
        var detector = new window.BarcodeDetector({ formats: ['code_128', 'code_39', 'code_93', 'ean_13', 'qr_code', 'itf', 'data_matrix'] });
        function tick() {
          if (!scanVideo || scanStream === null) return;
          if (scanVideo.readyState < 2) {
            scanRaf = requestAnimationFrame(tick);
            return;
          }
          detector.detect(scanVideo).then(function (codes) {
            if (codes && codes.length && codes[0].rawValue) {
              onScanDecoded(codes[0].rawValue);
              return;
            }
            scanRaf = requestAnimationFrame(tick);
          }).catch(function () { scanRaf = requestAnimationFrame(tick); });
        }
        scanRaf = requestAnimationFrame(tick);
      })
      .catch(function () {
        stopBarcodeScan();
        focusCode();
      });
  }
  if (scanBtn) {
    scanBtn.addEventListener('click', function () {
      if (typeof window.BarcodeDetector !== 'undefined') startBarcodeScan();
      else focusCode();
    });
  }
  if (scanCancel) scanCancel.addEventListener('click', function () { stopBarcodeScan(); });
  document.addEventListener('keydown', function (ev) {
    if (ev.key !== 'Escape' || !scanOverlay || scanOverlay.hidden) return;
    ev.preventDefault();
    stopBarcodeScan();
  });
})();
(function () {
  var cfgEl = document.getElementById('cable-type-label-ocr-cfg');
  var cfg = {};
  try { cfg = cfgEl ? JSON.parse(cfgEl.textContent) : {}; } catch (eCfg) {}

  var openBtn = document.getElementById('cable-type-label-ocr-open');
  var overlay = document.getElementById('cable-type-label-ocr-overlay');
  var hint = document.getElementById('cable-type-label-ocr-text');
  var vid = document.getElementById('cable-type-label-ocr-video');
  var readBtn = document.getElementById('cable-type-label-ocr-read');
  var editor = document.getElementById('cable-type-label-ocr-editor');
  var draftTa = document.getElementById('cable-type-label-ocr-draft');
  var suggestBtn = document.getElementById('cable-type-label-ocr-apply-suggest');
  var cancelBtn = document.getElementById('cable-type-label-ocr-cancel');

  var familySel = document.getElementById({{ form.family.vars.id|json_encode|raw }});
  var fiberIn = document.getElementById({{ form.fiberCount.vars.id|json_encode|raw }});
  var constrIn = document.getElementById({{ form.constructionCode.vars.id|json_encode|raw }});
  var diamIn = document.getElementById({{ form.diameterMm.vars.id|json_encode|raw }});

  var stream = null;
  var ocrBusy = false;
  var suggestBusy = false;
  var cropCanvas = null;
  var STRIP_FRAC = 0.2;
  var tessRunPromise = null;
  var tessWorker = null;

  function cfgOk() {
    return !!(cfg.suggestUrl && cfg.csrf);
  }

  function normalizeDraft(raw) {
    return String(raw || '')
      .trim()
      .replace(/\s+/g, ' ');
  }

  function textEmpty(el) {
    return !el || String(el.value || '').trim() === '';
  }

  function fiberEmpty(el) {
    if (!el) return true;
    var v = String(el.value || '').trim();
    if (!v.length) return true;
    var n = parseInt(v, 10);
    return !(isFinite(n) && n > 0);
  }

  function familyHasOption(code) {
    if (!familySel || code == null) return false;
    code = String(code);
    var i = 0;
    for (; i < familySel.options.length; i++) {
      if (familySel.options[i].value === code) return true;
    }
    return false;
  }

  function fireInput(el) {
    if (!el) return;
    try {
      el.dispatchEvent(new Event('input', { bubbles: true }));
    } catch (eI) {}
    try {
      el.dispatchEvent(new Event('change', { bubbles: true }));
    } catch (eC) {}
  }

  function applySuggestedFromServer(s) {
    if (!s || typeof s !== 'object') return 0;
    var cnt = 0;
    if (s.fullDescription != null && String(s.fullDescription).trim() !== '' && textEmpty(descIn)) {
      descIn.value = String(s.fullDescription).trim();
      fireInput(descIn);
      cnt++;
    }
    if (s.fiberCount != null && fiberEmpty(fiberIn)) {
      var fv = parseInt(String(s.fiberCount), 10);
      if (isFinite(fv) && fv > 0 && fv < 2000) {
        fiberIn.value = String(fv);
        fireInput(fiberIn);
        cnt++;
      }
    }
    if (s.constructionCode != null && String(s.constructionCode).trim() !== '' && textEmpty(constrIn)) {
      constrIn.value = String(s.constructionCode).trim();
      fireInput(constrIn);
      cnt++;
    }
    if (s.diameterMm != null && String(s.diameterMm).trim() !== '' && textEmpty(diamIn)) {
      diamIn.value = String(s.diameterMm).trim();
      fireInput(diamIn);
      cnt++;
    }
    if (
      s.familyCode != null &&
      String(s.familyCode).trim() !== '' &&
      textEmpty(familySel) &&
      familyHasOption(s.familyCode)
    ) {
      familySel.value = String(s.familyCode).trim();
      fireInput(familySel);
      cnt++;
    }
    return cnt;
  }

  function terminateTess() {
    tessRunPromise = null;
    var w = tessWorker;
    tessWorker = null;
    if (w)
      try {
        Promise.resolve(w.terminate()).catch(function () {});
      } catch (eT) {}
  }

  function stopLabelOcr() {
    ocrBusy = false;
    suggestBusy = false;
    if (readBtn) readBtn.disabled = false;
    if (suggestBtn) suggestBtn.disabled = false;
    if (stream) {
      stream.getTracks().forEach(function (t) {
        t.stop();
      });
      stream = null;
    }
    if (vid) vid.srcObject = null;
    if (overlay) overlay.hidden = true;
    terminateTess();
  }

  function applyHintOpening() {
    if (hint) {
      hint.textContent =
        typeof window.Tesseract === 'undefined' || typeof window.Tesseract.createWorker !== 'function'
          ? 'OCR se nenačetla — obnovte stránku.'
          : 'Držte řádek štítku ve středu náhledu → „Přečíst řádek (OCR)“ → upravte text → „Doplnit prázdná pole formuláře“. Pole Kód zásoby OCR nemění (použijte Sken).';
    }
  }

  function captureStripCanvas() {
    if (!vid || stream === null) return null;
    if (vid.readyState < 2) return null;
    var vw = vid.videoWidth;
    var vh = vid.videoHeight;
    if (vw < 2 || vh < 2) return null;
    var sh = Math.max(12, Math.round(vh * STRIP_FRAC));
    var sy = Math.round((vh - sh) / 2);
    var cw = Math.min(960, vw);
    var ch = Math.max(12, Math.round(sh * (cw / vw)));
    if (!cropCanvas) cropCanvas = document.createElement('canvas');
    if (cropCanvas.width !== cw || cropCanvas.height !== ch) {
      cropCanvas.width = cw;
      cropCanvas.height = ch;
    }
    var ctx = cropCanvas.getContext('2d');
    if (!ctx) return null;
    ctx.drawImage(vid, 0, sy, vw, sh, 0, 0, cw, ch);
    return cropCanvas;
  }

  function ensureWorker() {
    if (typeof window.Tesseract === 'undefined' || typeof window.Tesseract.createWorker !== 'function') {
      return Promise.resolve(null);
    }
    if (tessWorker) return Promise.resolve(tessWorker);
    if (!tessRunPromise) {
      tessRunPromise = window
        .Tesseract.createWorker('eng', 1, { logger: function () {} })
        .then(function (worker) {
          return worker
            .setParameters({ tessedit_pageseg_mode: '6', user_defined_dpi: '300' })
            .then(function () {
              tessWorker = worker;
              tessRunPromise = null;
              return worker;
            });
        })
        .catch(function () {
          tessRunPromise = null;
          return null;
        });
    }
    return tessRunPromise;
  }

  function performSnapOcr() {
    if (!overlay || overlay.hidden || stream === null) return;
    if (ocrBusy) return;
    var canv = captureStripCanvas();
    if (!canv) {
      if (hint) hint.textContent = 'Kamera ještě nedodává obrázek — počkejte a zkuste „Přečíst řádek“ znovu.';
      return;
    }
    ocrBusy = true;
    if (readBtn) readBtn.disabled = true;
    if (suggestBtn) suggestBtn.disabled = true;
    ensureWorker()
      .then(function (worker) {
        if (!worker) {
          ocrBusy = false;
          if (readBtn) readBtn.disabled = false;
          if (suggestBtn && !suggestBusy) suggestBtn.disabled = false;
          if (hint) hint.textContent = 'OCR nedostupné — obnovte stránku.';
          return;
        }
        if (stream === null) {
          ocrBusy = false;
          if (readBtn) readBtn.disabled = false;
          if (suggestBtn && !suggestBusy) suggestBtn.disabled = false;
          return;
        }
        return worker.recognize(canv).then(function (res) {
          var txt = res && res.data && res.data.text ? String(res.data.text) : '';
          var draft = normalizeDraft(txt);
          if (draftTa) draftTa.value = draft;
          if (hint) {
            hint.textContent = draft.length
              ? 'Text je níže — upravte jej a použijte „Doplnit prázdná pole formuláře“ (jen prázdná pole se vyplní).'
              : 'OCR vrátil prázdný text — lépe držte řádek a zkuste znovu.';
          }
          ocrBusy = false;
          if (readBtn) readBtn.disabled = false;
          if (suggestBtn && !suggestBusy) suggestBtn.disabled = false;
        });
      })
      .catch(function () {
        ocrBusy = false;
        if (readBtn) readBtn.disabled = false;
        if (suggestBtn && !suggestBusy) suggestBtn.disabled = false;
        if (hint) hint.textContent = 'OCR selhalo — zkuste znovu (světlo, držet řádek v pruhu).';
      });
  }

  function postSuggest(text, cbOk, cbErr) {
    fetch(cfg.suggestUrl, {
      method: 'POST',
      credentials: 'same-origin',
      headers: {
        'Content-Type': 'application/json',
        Accept: 'application/json',
        'X-Requested-With': 'XMLHttpRequest',
      },
      body: JSON.stringify({ text: text, csrf: cfg.csrf }),
    })
      .then(function (r) {
        return r.json();
      })
      .then(function (j) {
        if (j && j.ok) cbOk(j);
        else cbErr(j);
      })
      .catch(function () {
        cbErr({});
      });
  }

  function openLabelOcr() {
    if (!overlay || !vid) return;
    if (!cfgOk()) {
      window.alert('Endpoint návrhu polí není nastaven.');
      return;
    }
    if (typeof window.Tesseract === 'undefined' || typeof window.Tesseract.createWorker !== 'function') {
      window.alert('Biblioteka OCR se nenačetla.');
      return;
    }
    terminateTess();
    applyHintOpening();
    if (draftTa) draftTa.value = '';
    if (editor) editor.removeAttribute('hidden');
    overlay.hidden = false;
    navigator.mediaDevices
      .getUserMedia({ video: { facingMode: { ideal: 'environment' } } })
      .then(function (s) {
        stream = s;
        vid.srcObject = s;
        return vid.play();
      })
      .then(function () {
        ensureWorker();
      })
      .catch(function () {
        overlay.hidden = true;
        window.alert('Kamera není dostupná.');
      });
  }

  if (!openBtn || !overlay) return;

  openBtn.addEventListener('click', function () {
    openLabelOcr();
  });
  if (readBtn) readBtn.addEventListener('click', performSnapOcr);
  if (suggestBtn) {
    suggestBtn.addEventListener('click', function () {
      var text = normalizeDraft(draftTa ? draftTa.value : '');
      if (!text.length) {
        window.alert('Nejdřív „Přečíst řádek (OCR)“ nebo zadejte text ručně.');
        return;
      }
      if (ocrBusy || suggestBusy) return;
      suggestBusy = true;
      suggestBtn.disabled = true;
      if (readBtn) readBtn.disabled = true;
      postSuggest(
        text,
        function (j) {
          suggestBusy = false;
          suggestBtn.disabled = false;
          if (readBtn && !ocrBusy) readBtn.disabled = false;
          var s = j && j.suggested ? j.suggested : null;
          var keys = s && typeof s === 'object' ? Object.keys(s) : [];
          var applied = keys.length ? applySuggestedFromServer(s) : 0;
          if (hint) {
            if (applied > 0) {
              hint.textContent =
                'Doplněno ' +
                applied +
                ' prázdných polí — zkontrolujte řadu, počet vláken a název; kód zásoby doplňte ručně a uložte.';
            } else if (keys.length) {
              hint.textContent =
                'Z textu nešlo automaticky doplnit nic nového (plná pole jsme nepřepsali). Vyplňte ručně nebo vyprázdněte pole.';
            } else {
              hint.textContent =
                'Ze štítku nešlo vyčíst strukturu — zkuste upravit OCR text a znovu „Doplnit prázdná pole formuláře“.';
            }
          }

        },
        function () {
          suggestBusy = false;
          suggestBtn.disabled = false;
          if (readBtn && !ocrBusy) readBtn.disabled = false;
          window.alert('Požadavek selhal (relace / síť).');
        }
      );
    });
  }
  if (cancelBtn) cancelBtn.addEventListener('click', stopLabelOcr);

  document.addEventListener('keydown', function (ev) {
    if (ev.key !== 'Escape' || !overlay || overlay.hidden) return;
    ev.preventDefault();
    stopLabelOcr();
  });
})();
    </script>
{% endblock %}

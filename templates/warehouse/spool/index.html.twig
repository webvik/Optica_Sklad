{% extends 'base.html.twig' %}
{% block title %}Práce s optikou — cívky{% endblock %}
{% block stylesheets %}
    {{ parent() }}
    <style>
        .work-input-sare {
            min-width: 0;
            width: 100%;
            max-width: 100%;
            flex: 1 1 12rem;
            font-size: 1.25rem;
            line-height: 1.3;
            padding: 0.7rem 1rem;
        }
        @media (min-width: 42rem) {
            .work-input-sare { font-size: 1.6rem; padding: 0.7rem 1.15rem; flex: 1 1 20rem; min-width: 12rem; }
        }
        .work-input-meter {
            min-width: 0;
            width: 100%;
            max-width: 28rem;
            font-size: 1.45rem;
            line-height: 1.3;
            padding: 0.6rem 1rem;
        }
        .work-input-project {
            min-width: 0;
            width: 100%;
            max-width: 40rem;
            font-size: 1.45rem;
            line-height: 1.3;
            padding: 0.6rem 1rem;
        }
        #work-scan-overlay {
            position: fixed;
            inset: 0;
            z-index: 9999;
            background: rgba(0,0,0,.75);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 1rem;
            padding: 1rem;
            box-sizing: border-box;
        }
        #work-scan-overlay[hidden] { display: none !important; }
        #work-scan-video-wrap {
            flex-shrink: 0;
            max-width: min(100%, 640px);
            box-sizing: border-box;
        }
        /* Režim záznamu: velké náhledové video jako dříve */
        #work-scan-video-wrap:not(.work-scan-video-wrap--sare-strip) #work-scan-video {
            display: block;
            max-width: 100%;
            max-height: 50vh;
            width: auto;
            height: auto;
            background: #111;
            border-radius: 6px;
        }
        /* Sken čísla saře: nízký pruh — šířka výběru v JS: sareStripFrac (sladit při změně) */
        .work-scan-overlay--sare-strip #work-scan-video-wrap.work-scan-video-wrap--sare-strip {
            width: min(100%, 34rem);
            height: clamp(4.25rem, 11.5vh, 6.25rem);
            overflow: hidden;
            border-radius: 8px;
            border: 2px solid rgba(85, 220, 175, 0.9);
            box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.35);
            background: #111;
            position: relative;
        }
        .work-scan-overlay--sare-strip #work-scan-video-wrap.work-scan-video-wrap--sare-strip::after {
            content: '';
            position: absolute;
            inset: 0;
            pointer-events: none;
            border: 1px solid rgba(255, 255, 255, 0.08);
            box-sizing: border-box;
            border-radius: inherit;
            z-index: 1;
        }
        .work-scan-overlay--sare-strip #work-scan-video-wrap.work-scan-video-wrap--sare-strip #work-scan-video {
            display: block;
            width: 100%;
            height: 100%;
            max-height: none;
            border-radius: 0;
            object-fit: cover;
            object-position: center center;
        }

        .work-spool-table { width: 100%; }
        .work-spool-table tbody tr.work-spool-row { cursor: pointer; }
        .work-spool-table tbody tr.work-spool-row:hover { background: #f0f7ff; }
        .work-spool-table tbody tr.work-spool-row.is-selected { background: #e0efff; }
        .work-spool-card {
            max-width: 40rem;
            margin-top: 1.25rem;
            padding: 1rem 1.1rem;
            border: 1px solid #c8d4e0;
            border-radius: 6px;
            background: #f9fbfd;
        }
        .work-spool-card[hidden] { display: none !important; }
        .work-data-panel[hidden] { display: none !important; }
        .work-data-panel {
            max-width: 50rem;
            margin-top: 0.5rem;
            margin-bottom: 0;
            padding: 0.9rem 1rem;
            border: 1px solid #c8d4e0;
            border-radius: 6px;
            background: #f9fbfd;
        }
        .work-karta-host-wrap { margin-top: 1.1rem; }
        .spool-karta-embed { max-width: 50rem; }
        .spool-karta-embed table { width: 100%; font-size: 0.95rem; }
        .work-search-field-row { display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: stretch; }
        @media (max-width: 36rem) {
            .work-search-field-row { flex-direction: column; align-items: stretch; }
            /* v řádku dává flex-grow:1 šířku; ve sloupci stejné pravidlo roztahuje pole po výšce — vypnout */
            .work-input-sare { flex: 0 0 auto; width: 100%; font-size: 1rem; line-height: 1.3; padding: 0.5rem 0.75rem; }
            .work-search-field-row > .work-search-action-btn { width: 100%; min-height: 2.75rem; justify-content: center; flex: 0 0 auto; }
        }
        .work-record-scan-row {
            display: flex;
            flex-direction: column;
            align-items: stretch;
            gap: 0.5rem;
            margin: 0.5rem 0 0.75rem;
        }
        .work-record-scan-row .work-search-sare-scan-group {
            width: 100%;
            display: flex;
        }
        .work-record-scan-hint { font-size: 0.88rem; color: #555; max-width: 42rem; line-height: 1.35; margin: 0; }
        .work-spool-table-wrap { margin: 0 -0.15rem; }
        @media (max-width: 36rem) {
            .work-page-footer { max-width: none; }
            .work-result-stack { max-width: 100% !important; }
            .work-spool-table-wrap .work-spool-table { font-size: 0.78rem; }
            .work-spool-table-wrap .work-spool-table th,
            .work-spool-table-wrap .work-spool-table td { padding: 0.28rem 0.3rem; line-height: 1.2; }
            .work-spool-table-wrap .work-spool-table th { font-weight: 600; letter-spacing: -0.02em; }
            .work-spool-table-wrap.table-scroll--wide > .work-spool-table { min-width: 33rem; }
        }
        .work-search-action-btn {
            box-sizing: border-box;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-height: 2.6rem;
            min-width: 5.5rem;
            padding: 0.5rem 1rem;
            font: inherit;
            font-size: 1.1rem;
            line-height: 1.2;
            font-weight: 600;
            white-space: nowrap;
            cursor: pointer;
            border-radius: 6px;
        }
        .work-search-sare-scan-group {
            display: inline-flex;
            flex-wrap: nowrap;
            gap: 0.5rem;
            flex: 0 1 auto;
            align-items: stretch;
            min-width: 0;
        }
        .work-search-sare-scan-group .work-search-action-btn {
            flex: 1 1 0;
            min-width: 0;
            white-space: nowrap;
            text-align: center;
            line-height: 1.2;
        }
        @media (max-width: 36rem) {
            .work-search-sare-scan-group {
                display: flex;
                width: 100%;
                flex: 0 0 auto;
            }
            .work-search-sare-scan-group .work-search-action-btn {
                flex: 1 1 0;
                width: auto;
                min-height: 2.75rem;
                font-size: 1rem;
            }
        }
        .work-page-chrome { max-width: 60rem; width: 100%; margin-bottom: 0.75rem; }
        .work-top-area { max-width: 40rem; width: 100%; }
        .work-page-chrome.is-search-collapsed .work-page-lede { display: none; }
        .work-page-chrome.is-search-collapsed .work-search-form-wrap { display: none; }
        .work-page-header {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            justify-content: space-between;
            gap: 0.45rem 0.5rem;
            width: 100%;
            max-width: 60rem;
            margin: 0 0 0.65rem;
        }
        .work-page-header h1 {
            flex: 1 1 auto;
            min-width: 0;
            margin: 0;
            line-height: 1.2;
        }
        .work-page-header__search-next {
            display: none;
            flex: 0 1 auto;
            max-width: 100%;
            gap: 0.4rem;
            padding: 0.45rem 0.75rem;
            font-size: 0.92rem;
            white-space: normal;
            text-align: center;
            line-height: 1.15;
        }
        .work-page-header__search-next .work-search-next-ico { flex-shrink: 0; }
        .work-page-chrome.is-search-collapsed .work-page-header__search-next { display: inline-flex; }
        @media (max-width: 41.99rem) {
            .work-page-header {
                flex-wrap: nowrap;
                align-items: center;
                gap: 0.35rem;
            }
            .work-page-header h1 { font-size: 1.2rem; }
            .work-page-header__search-next {
                flex: 0 0 auto;
                min-height: 2.75rem;
                max-width: min(11.5rem, 46vw);
                padding: 0.4rem 0.55rem;
                font-size: 0.8rem;
            }
            .work-page-header__search-next .work-search-next-ico { width: 17px; height: 17px; }
            .work-result-h2 { font-size: 0.95rem !important; }
        }
        @media (min-width: 42rem) {
            .work-page-header h1 { font-size: 1.65rem; }
            .work-page-header__search-next { font-size: 0.95rem; max-width: 14rem; }
        }
        .work-spool-mobile-summary { display: none; margin: 0.15rem 0 0.75rem; line-height: 1.42; }
        .work-spool-mobile-summary__row {
            display: flex;
            flex-wrap: wrap;
            align-items: baseline;
            justify-content: space-between;
            gap: 0.35rem 0.65rem;
        }
        .work-spool-mobile-summary__row--head { margin-bottom: 0.45rem; }
        .work-spool-mobile-summary__row--metrics { gap: 0.5rem 1rem; }
        .work-spool-mobile-summary__sare {
            display: flex;
            flex-wrap: wrap;
            align-items: baseline;
            gap: 0.35rem 0.5rem;
            min-width: 0;
            flex: 1 1 auto;
        }
        .work-spool-mobile-summary__lbl {
            font-weight: 500;
            font-size: 0.94rem;
            color: #444;
        }
        .work-spool-mobile-summary__val {
            font-weight: 700;
            font-size: 1.22rem;
            font-variant-numeric: tabular-nums;
            color: #111;
        }
        .work-spool-mobile-summary__brief {
            flex: 0 1 auto;
            max-width: 100%;
            font-size: 1.02rem;
            font-weight: 600;
            color: #222;
            text-align: right;
        }
        .work-spool-mobile-summary__metric {
            display: flex;
            flex-wrap: wrap;
            align-items: baseline;
            gap: 0.3rem 0.45rem;
            min-width: 0;
            flex: 1 1 8rem;
        }
        .work-spool-mobile-summary__warn { color: #a00; cursor: help; }
        /* Mobilní hamburger — jen tato stránka */
        .work-mobile-menu-open {
            display: none;
            align-items: center;
            gap: 0.4rem;
            margin: 0 0 0.65rem;
            min-height: 2.75rem;
            padding: 0.45rem 0.85rem;
            font-size: 1rem;
        }
        .work-mobile-menu-open__icon { font-size: 1.15rem; line-height: 1; }
        .work-mobile-menu-drawer[hidden] { display: none !important; }
        .work-mobile-menu-drawer {
            position: fixed;
            inset: 0;
            z-index: 1200;
            display: flex;
            align-items: stretch;
            justify-content: flex-end;
        }
        .work-mobile-menu-drawer__backdrop {
            position: absolute;
            inset: 0;
            background: rgba(15, 40, 71, 0.45);
        }
        .work-mobile-menu-drawer__panel {
            position: relative;
            z-index: 1;
            width: min(20rem, 92vw);
            max-width: 100%;
            height: 100%;
            overflow: auto;
            -webkit-overflow-scrolling: touch;
            background: #fff;
            box-shadow: -4px 0 24px rgba(0, 0, 0, 0.18);
            padding: 0.65rem 0.75rem max(1rem, env(safe-area-inset-bottom));
            padding-top: max(0.65rem, env(safe-area-inset-top));
        }
        .work-mobile-menu-drawer__head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 0.5rem;
            margin-bottom: 0.5rem;
            padding-bottom: 0.45rem;
            border-bottom: 1px solid #ddd;
        }
        .work-mobile-menu-drawer__title { font-weight: 700; font-size: 1.05rem; color: #1e4a73; }
        .work-mobile-menu-drawer__close {
            -webkit-appearance: none;
            appearance: none;
            border: 0;
            background: transparent;
            font-size: 1.65rem;
            line-height: 1;
            padding: 0.15rem 0.35rem;
            cursor: pointer;
            color: #333;
            min-width: 2.5rem;
            min-height: 2.5rem;
        }
        .work-mobile-menu-drawer__body .app-menu { margin-bottom: 0; }
        .work-mobile-menu-drawer__body hr { margin: 0 0 0.75rem; }
        @media (max-width: 41.99rem) {
            .work-mobile-menu-open { display: inline-flex; }
            .work-page-menu__desktop { display: none !important; }
        }
        @media (min-width: 42rem) {
            .work-mobile-menu-open,
            .work-mobile-menu-drawer { display: none !important; }
        }
        @media (max-width: 41.99rem) {
            .work-results--single-selected .work-result-h2,
            .work-results--single-selected .work-result-h2--count-only,
            .work-results--single-selected .work-spool-table-wrap,
            .work-results--single-selected .work-pick-hint { display: none !important; }
            .work-results--single-selected .work-spool-mobile-summary { display: block; }
        }
        #work-scan-cancel { min-height: 2.75rem; min-width: 7rem; padding: 0.5rem 1.2rem; }
        .work-scan-sare-mode-row {
            display: flex;
            flex-wrap: nowrap;
            gap: 0.5rem;
            width: min(100%, 34rem);
            max-width: 100%;
            box-sizing: border-box;
            margin-top: 0.35rem;
        }
        .work-scan-sare-mode-row[hidden] { display: none !important; }
        .work-scan-mode-btn {
            flex: 1 1 50%;
            box-sizing: border-box;
            min-height: 2.65rem;
            padding: 0.45rem 0.6rem;
            font: inherit;
            font-size: 0.98rem;
            font-weight: 600;
            cursor: pointer;
            border-radius: 6px;
            border: 2px solid rgba(255, 255, 255, 0.35);
            background: rgba(40, 40, 45, 0.95);
            color: #eee;
        }
        .work-scan-mode-btn:hover { background: rgba(55, 55, 62, 0.98); }
        .work-scan-mode-btn.is-active {
            border-color: rgba(85, 220, 175, 0.95);
            background: rgba(25, 55, 45, 0.95);
            color: #fff;
        }
        .work-scan-cancel-btn {
            margin-top: 1rem;
            padding: 0.55rem 1.35rem;
            font-size: 1.05rem;
            min-height: 2.75rem;
            min-width: 7rem;
        }
        #work-not-found-overlay[hidden] { display: none !important; }
        #work-not-found-overlay:not([hidden]) {
            box-sizing: border-box;
            position: fixed;
            inset: 0;
            z-index: 10040;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: max(0.5rem, env(safe-area-inset-top)) max(0.5rem, env(safe-area-inset-right)) max(0.5rem, env(safe-area-inset-bottom)) max(0.5rem, env(safe-area-inset-left));
            background: rgba(0, 0, 0, 0.55);
        }
        .work-not-found-modal__backdrop {
            position: absolute;
            inset: 0;
            background: transparent;
            -webkit-tap-highlight-color: transparent;
        }
        .work-not-found-modal__card {
            position: relative;
            z-index: 1;
            width: min(100%, 24rem);
            max-height: min(88vh, 22rem);
            overflow: auto;
            margin: auto;
            box-sizing: border-box;
            padding: 1.05rem 1.15rem 1.1rem;
            border-radius: 10px;
            background: #fdfefe;
            color: #1a2330;
            border: 1px solid #c5d6e8;
            box-shadow: 0 12px 36px rgba(0, 0, 0, 0.22);
        }
        .work-not-found-modal__title {
            margin: 0 0 0.5rem;
            font-size: 1.05rem;
            font-weight: 700;
            line-height: 1.28;
            text-align: center;
        }
        .work-not-found-modal__body {
            margin: 0 0 0.55rem;
            font-size: 0.93rem;
            line-height: 1.42;
            text-align: center;
            color: #2b3544;
            word-break: break-word;
        }
        .work-not-found-modal__note {
            margin: 0 0 0.85rem;
            font-size: 0.8rem;
            line-height: 1.38;
            text-align: center;
            color: #5a6575;
        }
        .work-not-found-modal__actions {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
            justify-content: center;
        }
        .work-not-found-modal__actions button {
            box-sizing: border-box;
            min-height: 2.55rem;
            padding: 0.45rem 1rem;
            font: inherit;
            font-size: 0.96rem;
            font-weight: 600;
            cursor: pointer;
            border-radius: 6px;
            border: 1px solid #9aa8b8;
            background: #eef2f6;
            color: #1a1a1a;
        }
        .work-not-found-modal__actions button:hover {
            filter: brightness(0.97);
        }
    </style>
{% endblock %}
{% block body %}
    {% include 'warehouse/spool/_work_mobile_menu.html.twig' %}
    <div id="work-page-chrome" class="work-page-chrome{% if searchPerformed and spools|length == 1 %} is-search-collapsed{% endif %}">
        <div class="work-page-header">
            <h1>Práce s optikou</h1>
            <button type="button" id="work-search-expand-btn" class="work-page-header__search-next work-search-action-btn ui-btn-primary" title="Rozbalit hledání další cívky" aria-controls="work-top-area" aria-expanded="false">
                <svg class="work-search-next-ico" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true" focusable="false">
                    <circle cx="10.5" cy="10.5" r="6.5"></circle>
                    <path d="M16 16l4.5 4.5"></path>
                </svg>
                <span>Hledat další cívku</span>
            </button>
        </div>
        <div id="work-top-area" class="work-top-area">
        <p class="lede work-page-lede" id="work-page-lede">Zadejte <strong>číslo saře</strong> a stiskněte <strong>Hledat</strong>, nebo pište — po pauze se hledá samo. Při více shodách <strong>klikněte na řádek</strong>.<span id="work-data-lede"{% if not (searchPerformed and spools|length == 1) %} hidden{% endif %}> U vybrané cívky můžete v bloku <em>Záznam pro práci</em> hned <strong>pod tabulkou</strong> zapsat <strong>zafuk</strong> tlačítkem <strong>Zapsat</strong>.</span></p>

        <div class="work-search-shell">
        <div class="work-search-form-wrap">
        <form id="work-search-form" method="get" action="{{ path('warehouse_spool_index') }}" style="margin: 0;">
            <p style="margin: 0;">
                <label for="work-q" style="display: block; font-weight: 600; margin-bottom: 0.35rem;">Číslo saře</label>
                <span class="work-search-field-row" style="width: 100%;">
                    <input type="text" name="q" id="work-q" class="work-input-sare" value="{{ searchQuery|e('html_attr') }}" autocomplete="off" autocapitalize="off" spellcheck="false" inputmode="search" enterkeyhint="search" placeholder="např. 450-1470">
                    <span class="work-search-sare-scan-group">
                        <button type="submit" class="work-search-action-btn ui-btn-primary">Hledat</button>
                        <button type="button" id="work-scan-btn" class="work-search-action-btn ui-btn-secondary work-scan-tl" data-work-scan-mode="sare" title="Sken čísla saře: úzký pruh nad kódem → pole Číslo saře (upravte před Hledat)">Sken</button>
                    </span>
                </span>
            </p>
        </form>
        </div>
        </div>
        </div>
    </div>

    <p id="work-ajax-hint" style="color: #666; font-size: .9em; min-height: 1.2em; margin: 0.35rem 0 0.6rem;" aria-live="polite"></p>

    <div id="work-result-stack" class="work-result-stack" style="max-width: 60rem;">
        <div id="work-results-dynamic">
    {% if searchPerformed %}
        {% if spools is empty %}
            <p style="color: #333;"><strong>Žádná shoda</strong> pro dotaz «{{ searchQuery|e }}».</p>
        {% else %}
            <div class="work-results-block{% if spools|length == 1 %} work-results--single-selected{% endif %}">
            {% if spools|length > 1 %}
            <h2 class="work-result-h2" style="font-size: 1.1rem; margin: 0.35rem 0 .5rem;">Výsledek ({{ spools|length }})</h2>
            {% else %}
            <h2 class="work-result-h2 work-result-h2--count-only" style="font-size: 1.1rem; margin: 0.35rem 0 .5rem;">Výsledek (1)</h2>
            {% include 'warehouse/spool/_work_spool_mobile_summary.html.twig' with {
                spool: spools[0],
                rem: spoolRemaining[spools[0].id] ?? null,
            } only %}
            {% endif %}
            <div class="table-scroll table-scroll--wide work-spool-table-wrap">
            <table class="work-spool-table">
                <thead>
                    <tr>
                        <th>Číslo saře</th>
                        <th title="Poslední čtení metru (last_visible_m)">Běžný stav (m)</th>
                        <th>Zbývá (m)</th>
                        <th>Typ</th>
                        <th title="Počet optických vláken (z cívky nebo z typu kabelu)">Vláken</th>
                        <th title="Počáteční čtení metru na kabelu (ne délka)">PS (m)</th>
                    </tr>
                </thead>
                <tbody>
                {% for s in spools %}
                    {% set rem = spoolRemaining[s.id] ?? null %}
                    <tr class="work-spool-row{% if spools|length == 1 %} is-selected{% endif %}" data-spool-id="{{ s.id }}" tabindex="0" title="Vybrat tuto cívku">
                        <td>{{ s.reelNumber }}</td>
                        <td>{% if s.lastVisibleM is not null %}{{ s.lastVisibleM }}{% else %}—{% endif %}</td>
                        <td>{% if rem is not null %}{{ rem.remaining }}{% if rem.warning %} <span title="{{ rem.warning|e('html_attr') }}" style="cursor: help; color: #a00;">⚠</span>{% endif %}{% else %}—{% endif %}</td>
                        <td>{{ s.family ?: '—' }}</td>
                        <td>{{ s.effectiveFiberCount }}</td>
                        <td>{{ s.initialVisibleM }}{% if rem is not null and rem.directionLabel %} <span style="font-size: .82em; color: #666;">({{ rem.directionLabel }})</span>{% endif %}</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
            </div>
            {% if spools|length > 1 %}
            <p id="work-pick-hint" class="work-pick-hint" style="margin: .75rem 0 .5rem; color: #444;">Vyberte správnou cívku <strong>kliknutím na řádek</strong> v tabulce; níže můžete zapsat zafuk, pod tím se načte karta a deník.</p>
            {% endif %}
            </div>
        {% endif %}
    {% endif %}
        </div>

    <div id="work-data-panel" class="work-data-panel" role="region" aria-labelledby="work-data-heading"{% if not (searchPerformed and spools|length == 1) %} hidden{% endif %}>
        <h2 id="work-data-heading" style="font-size: 1.05rem; margin: 0 0 0.65rem;">Záznam pro práci s cívkou</h2>
        <p id="work-data-spool-hint" style="margin: 0 0 0.75rem; color: #555; font-size: 0.95rem;">{% if searchPerformed and spools|length == 1 %}<strong>Zapsat</strong> uloží zafuk. Jiné události v <a href="{{ path('warehouse_spool_show', {id: spools[0].id}) }}">kartě cívky</a>.{% else %}Tento blok se zobrazí po <strong>výběru cívky</strong> v tabulce.{% endif %}</p>
        <form id="work-record-form" method="post" action="{{ path('warehouse_spool_work_record') }}">
            <input type="hidden" name="_token" value="{{ csrf_token('spool_work_record') }}">
            <input type="hidden" name="return_q" id="work-record-return-q" value="{{ searchQuery|e('html_attr') }}">
            <input type="hidden" name="spool_id" id="work-record-spool-id" value="{% if searchPerformed and spools|length == 1 %}{{ spools[0].id }}{% endif %}">
            <p style="margin: 0 0 .75rem;">
                <label for="work-meter" style="display: block; font-weight: 600; font-size: 1.05rem; margin-bottom: 0.35rem;">Běžný stav (aktuální metráž, m)</label>
                <input type="number" name="visible_m" id="work-meter" class="work-input-meter" inputmode="numeric" step="1" min="0" placeholder="nové čtení metru">
            </p>
            <p style="margin: 0 0 .75rem; display: none; padding: .5rem .75rem; background: #edf2f7; border-radius: 4px; font-size: .92rem;" id="work-meter-calc" aria-live="polite"></p>
            <p style="margin: 0 0 .9rem;">
                <label for="work-project" style="display: block; font-weight: 600; font-size: 1.05rem; margin-bottom: 0.35rem;">Objekt / zakázka</label>
                <input type="text" name="project" id="work-project" class="work-input-project" autocomplete="off" placeholder="volitelné">
            </p>
            <div class="work-record-scan-row">
                <span class="work-search-sare-scan-group">
                    <button type="button" id="work-record-scan-btn" class="work-search-action-btn ui-btn-secondary work-scan-tl" data-work-scan-mode="record" title="Sken do záznamu: metráž, nebo metráž;zakázka (oddělovač ;, |, tab)">Sken</button>
                    <button type="submit" class="work-search-action-btn ui-btn-primary work-submit-record">Zapsat</button>
                </span>
                <p class="work-record-scan-hint">Jeden kód: jen číslice → <strong>Běžný stav</strong> (m). Dva údaje: <code>7843;Z123</code> nebo tab / <code>|</code> → metráž a <strong>Objekt / zakázka</strong>. Bez kamery: čtečka může psát do pole (stejný formát).</p>
            </div>
        </form>
    </div>

    <div id="work-karta-host" class="work-karta-host-wrap">{% if searchPerformed and spools|length == 1 %}{% include 'warehouse/spool/_karta_work_embed.html.twig' with { spool: spools[0] } only %}{% endif %}</div>
    </div>

    <div id="work-scan-overlay" hidden role="dialog" aria-label="Sken čárového kódu">
        <p id="work-scan-overlay-text" style="color:#fff;margin:0;text-align:center;max-width:34rem"></p>
        <div id="work-scan-video-wrap">
            <video id="work-scan-video" playsinline autoplay muted></video>
        </div>
        <div id="work-scan-sare-mode-row" class="work-scan-sare-mode-row" hidden role="group" aria-label="Způsob skenování čísla saře">
            <button type="button" id="work-scan-mode-barcode" class="work-scan-mode-btn is-active" aria-pressed="true">Čárový kód</button>
            <button type="button" id="work-scan-mode-number" class="work-scan-mode-btn" aria-pressed="false">Číslo</button>
        </div>
        <button type="button" id="work-scan-cancel" class="work-scan-cancel-btn">Zrušit</button>
    </div>

    <div id="work-not-found-overlay" hidden role="dialog" aria-modal="true" aria-labelledby="work-not-found-title">
        <div class="work-not-found-modal__backdrop" id="work-not-found-backdrop" tabindex="-1" aria-hidden="true"></div>
        <div class="work-not-found-modal__card">
            <p class="work-not-found-modal__title" id="work-not-found-title">Cívka není evidována</p>
            <p class="work-not-found-modal__body" id="work-not-found-body"></p>
            <p class="work-not-found-modal__note" id="work-not-found-note">Číslo saře je v systému <strong>jedinečné</strong> — druhou cívku se stejným číslem nelze založit.</p>
            <div class="work-not-found-modal__actions" id="work-not-found-actions-edit">
                <button type="button" class="work-not-found-btn--primary" id="work-not-found-yes">Ano, zapsat do evidence</button>
                <button type="button" id="work-not-found-no">Ne</button>
            </div>
            <div class="work-not-found-modal__actions" id="work-not-found-actions-view" hidden>
                <button type="button" id="work-not-found-ok">Zavřít</button>
            </div>
        </div>
    </div>

    <footer id="work-page-footer" class="work-page-footer" style="margin-top: 2.5rem; padding-top: 1rem; border-top: 1px solid #ddd; max-width: 40rem; font-size: .92rem; color: #444;">
        <p style="margin: 0 0 .5rem;">Pole <strong>Objekt / zakázka</strong> doplňte podle místa práce.</p>
        <p style="margin: 0;">
            {% if is_granted('ROLE_SKLAD_EDIT') %}
                <a href="{{ path('warehouse_spool_new') }}">Nová cívka (evidence)</a> ·
            {% endif %}
            Nové cívky přes příjem → <a href="{{ path('warehouse_receipt_index') }}">Příjem kabelu</a>.
            <a href="{{ path('warehouse_spool_list') }}">Úplný seznam</a>
            · <a href="{{ path('warehouse_browse_index') }}">Přehled s filtry</a>.</p>
    </footer>
    {% if spoolsLookupJson %}
    <script type="application/json" id="work-spools-json">{{ spoolsLookupJson|raw }}</script>
    {% endif %}
    {% if searchPerformed and spools is empty and searchQuery|trim != '' %}
        <div id="work-not-found-ssr" data-q="{{ searchQuery|e('html_attr') }}" hidden></div>
    {% endif %}
{% endblock %}
{% block javascripts %}
    {{ parent() }}
    {# OCR pro režim „Číslo“ (tištěné číslice); čárové kódy neřeší. #}
    <script crossorigin referrerpolicy="no-referrer" src="https://cdn.jsdelivr.net/npm/tesseract.js@5/dist/tesseract.min.js"></script>
    <script>
(function () {
  (function initWorkMobileMenu() {
    var openBtn = document.getElementById('work-mobile-menu-open');
    var drawer = document.getElementById('work-mobile-menu-drawer');
    if (!openBtn || !drawer) return;
    var lastFocus = null;
    function setMenuOpen(on) {
      if (on) {
        lastFocus = document.activeElement;
        drawer.hidden = false;
        openBtn.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
        var closeBtn = drawer.querySelector('.work-mobile-menu-drawer__close');
        if (closeBtn) closeBtn.focus();
      } else {
        drawer.hidden = true;
        openBtn.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
        if (lastFocus && lastFocus.focus) {
          try { lastFocus.focus(); } catch (eMenu) {}
        }
      }
    }
    openBtn.addEventListener('click', function () {
      setMenuOpen(!!drawer.hidden);
    });
    drawer.querySelectorAll('[data-work-menu-close]').forEach(function (el) {
      el.addEventListener('click', function () { setMenuOpen(false); });
    });
    drawer.addEventListener('click', function (ev) {
      if (ev.target.closest('a[href]')) setMenuOpen(false);
    });
    document.addEventListener('keydown', function (ev) {
      if (ev.key === 'Escape' && !drawer.hidden) {
        ev.preventDefault();
        setMenuOpen(false);
      }
    });
  })();

  var form = document.getElementById('work-search-form');
  var qIn = document.getElementById('work-q');
  var hint = document.getElementById('work-ajax-hint');
  var results = document.getElementById('work-results-dynamic');
  var meterIn = document.getElementById('work-meter');
  var projectIn = document.getElementById('work-project');
  var calcBox = document.getElementById('work-meter-calc');
  var dataPanel = document.getElementById('work-data-panel');
  var ledeData = document.getElementById('work-data-lede');
  var workDataHint = document.getElementById('work-data-spool-hint');
  var lookupUrl = {{ path('warehouse_spool_lookup')|json_encode|raw }};
  var spoolShowBase = {{ path('warehouse_spool_show', {id: 0})|json_encode|raw }};
  var kartaEmbedBase = {{ path('warehouse_spool_karta_embed', {id: 0})|json_encode|raw }};
  var workNewSpoolUrl = {{ path('warehouse_spool_new')|json_encode|raw }};
  var workRegisterSpool = {{ work_can_register_spool|default(false)|json_encode|raw }};
  var t = null, seq = 0;
  var debounceMs = 380;
  var meterState = { s: null, bound: false };
  var lastSpoolsList = [];
  var workPageChrome = document.getElementById('work-page-chrome');
  var workTopArea = document.getElementById('work-top-area');
  var expandSearchBtn = document.getElementById('work-search-expand-btn');
  /** Telemetrie skenu (mobil bez konzole): na stránce přidej ?scanDbg=1, logy v Monologu [work-scan-client]. */
  var workScanLogCfg = {% if work_scan_client_log|default(false) %}{{ { url: path('warehouse_spool_client_scan_log'), csrf: csrf_token('work_scan_client') }|json_encode|raw }}{% else %}null{% endif %};
  var workScanLogDetectThrottleMs = 550;
  var workScanLogLastDetectTs = 0;
  function workScanClientLog(payload) {
    if (!workScanLogCfg || !workScanLogCfg.url) return;
    try {
      var ev = payload && payload.event;
      if (ev === 'detect') {
        var t = Date.now();
        if (t - workScanLogLastDetectTs < workScanLogDetectThrottleMs) return;
        workScanLogLastDetectTs = t;
      }
      var body = {
        event: payload.event,
        ui: payload.ui,
        sareMode: payload.sareMode,
        codesCount: payload.codesCount,
        fmtTier: payload.fmtTier,
        pickedLen: payload.pickedLen,
        csrf: workScanLogCfg.csrf,
      };
      fetch(workScanLogCfg.url, {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
        body: JSON.stringify(body),
      }).catch(function () {});
    } catch (eLog) {}
  }

  function setSearchFormCollapsed(c) {
    if (workPageChrome) {
      if (c) { workPageChrome.classList.add('is-search-collapsed'); }
      else { workPageChrome.classList.remove('is-search-collapsed'); }
    }
    if (expandSearchBtn) {
      expandSearchBtn.setAttribute('aria-expanded', c ? 'false' : 'true');
    }
  }
  function spoolShowUrl(id) { return spoolShowBase.replace(/\/[0-9]+$/, '/' + id); }
  function esc(t) { if (t == null) return ''; return String(t).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
  var workNfOverlay = document.getElementById('work-not-found-overlay');
  var workNfBody = document.getElementById('work-not-found-body');
  var workNfActEdit = document.getElementById('work-not-found-actions-edit');
  var workNfActView = document.getElementById('work-not-found-actions-view');
  var workNfYes = document.getElementById('work-not-found-yes');
  var workNfNo = document.getElementById('work-not-found-no');
  var workNfOk = document.getElementById('work-not-found-ok');
  var workNfBackdrop = document.getElementById('work-not-found-backdrop');
  var workNfPendingQ = '';

  function closeWorkNotFoundModal() {
    if (!workNfOverlay) return;
    workNfOverlay.hidden = true;
    workNfOverlay.setAttribute('aria-hidden', 'true');
    workNfPendingQ = '';
  }
  function openWorkNotFoundModal(qRaw) {
    if (!workNfOverlay || !workNfBody) return;
    var q = String(qRaw || '').trim();
    if (!q.length) return;
    workNfPendingQ = q;
    var html =
      'Pro číslo saře «<strong>' +
      esc(q) +
      '</strong>» není ve skladové evidenci zaevidovaná žádná cívka.';
    if (workRegisterSpool) {
      html += ' Chcete ji nyní přidat do evidence?';
      if (workNfActEdit) workNfActEdit.hidden = false;
      if (workNfActView) workNfActView.hidden = true;
    } else {
      html +=
        ' Nemáte oprávnění k zápisům — požádejte správce, aby cívku založil, nebo vám rozšířil oprávnění.';
      if (workNfActEdit) workNfActEdit.hidden = true;
      if (workNfActView) workNfActView.hidden = false;
    }
    workNfBody.innerHTML = html;
    workNfOverlay.hidden = false;
    workNfOverlay.setAttribute('aria-hidden', 'false');
    try {
      if (workRegisterSpool && workNfYes) workNfYes.focus();
      else if (workNfOk) workNfOk.focus();
    } catch (eFoc) {}
  }
  if (workNfYes) {
    workNfYes.addEventListener('click', function () {
      var q = workNfPendingQ;
      closeWorkNotFoundModal();
      if (!q.length || !workNewSpoolUrl) return;
      try {
        var u = new URL(workNewSpoolUrl, window.location.origin);
        u.searchParams.set('reel', q);
        window.location.assign(u.toString());
      } catch (eU) {
        window.location.href = workNewSpoolUrl + '?reel=' + encodeURIComponent(q);
      }
    });
  }
  if (workNfNo) workNfNo.addEventListener('click', closeWorkNotFoundModal);
  if (workNfOk) workNfOk.addEventListener('click', closeWorkNotFoundModal);
  if (workNfBackdrop) workNfBackdrop.addEventListener('click', closeWorkNotFoundModal);
  function maybeOfferWorkSpoolRegistration(apiQuery) {
    var qs = String(apiQuery || '').trim();
    if (qs.length < 1) return;
    openWorkNotFoundModal(qs);
  }
  document.addEventListener(
    'keydown',
    function (ev) {
      if (ev.key !== 'Escape' || !workNfOverlay || workNfOverlay.hidden) return;
      ev.preventDefault();
      ev.stopImmediatePropagation();
      closeWorkNotFoundModal();
    },
    true
  );
  function setWorkDataPanel(s) {
    if (!dataPanel) return;
    if (s) {
      dataPanel.removeAttribute('hidden');
      if (ledeData) ledeData.removeAttribute('hidden');
      if (workDataHint) workDataHint.innerHTML = '<strong>Zapsat</strong> uloží zafuk. Jiné události v <a href="' + spoolShowUrl(s.id) + '">kartě cívky</a>.';
    } else {
      dataPanel.setAttribute('hidden', '');
      if (ledeData) ledeData.setAttribute('hidden', '');
      if (workDataHint) workDataHint.textContent = 'Tento blok se zobrazí po výběru cívky v tabulce nahoře.';
    }
  }
  function formatPsCell(p) {
    if (p == null) return '—';
    var v = esc(p.initialVisibleM);
    var dir = p.meterNumberingLabel ? (' <span style="font-size:.82em;color:#666">(' + esc(p.meterNumberingLabel) + ')</span>') : '';
    return v + dir;
  }
  function formatRemainingCell(p) {
    if (p == null) return '—';
    var v = (p.currentRemainingM != null) ? esc(p.currentRemainingM) : '—';
    var w = p.remainingWarning ? String(p.remainingWarning) : '';
    var bad = p.remainingDirectionOk === false || (w && w.length);
    var flag = bad ? (' <span title="' + esc(w) + '" style="cursor:help;color:#a00">⚠</span>') : '';
    return v + flag;
  }
  function findSpoolInList(id) {
    for (var i = 0; i < lastSpoolsList.length; i++) { if (lastSpoolsList[i].id == id) return lastSpoolsList[i]; }
    return null;
  }
  function tableShell(rowsInner) {
    return '<div class="table-scroll table-scroll--wide work-spool-table-wrap"><table class="work-spool-table"><thead><tr><th>Číslo saře</th><th title="Poslední čtení metru">Běžný stav (m)</th><th>Zbývá (m)</th><th>Typ</th><th>Vláken</th><th>PS (m)</th></tr></thead><tbody>' + rowsInner + '</tbody></table></div>';
  }
  function isWorkMobileLayout() {
    return window.matchMedia('(max-width: 41.99rem)').matches;
  }
  function formatRemainingPlain(p) {
    if (p == null) return '—';
    var v = (p.currentRemainingM != null) ? esc(p.currentRemainingM) + ' m' : '—';
    var w = p.remainingWarning ? String(p.remainingWarning) : '';
    var bad = p.remainingDirectionOk === false || (w && w.length);
    var flag = bad ? (' <span class="work-spool-mobile-summary__warn" title="' + esc(w) + '">⚠</span>') : '';
    return v + flag;
  }
  function formatLastVisiblePlain(p) {
    if (p == null || p.lastVisibleM == null) return '—';
    return esc(p.lastVisibleM) + ' m';
  }
  function mobileSummaryHtml(p) {
    var brief = esc((p.briefInventuraLabel != null && p.briefInventuraLabel !== '') ? p.briefInventuraLabel : '—');
    return '<div class="work-spool-mobile-summary" data-spool-id="' + esc(p.id) + '">'
      + '<div class="work-spool-mobile-summary__row work-spool-mobile-summary__row--head">'
      + '<div class="work-spool-mobile-summary__sare"><span class="work-spool-mobile-summary__lbl">Číslo saře</span>'
      + '<span class="work-spool-mobile-summary__val">' + esc(p.reelNumber) + '</span></div>'
      + '<span class="work-spool-mobile-summary__brief">' + brief + '</span></div>'
      + '<div class="work-spool-mobile-summary__row work-spool-mobile-summary__row--metrics">'
      + '<div class="work-spool-mobile-summary__metric"><span class="work-spool-mobile-summary__lbl">Zbývá</span>'
      + '<span class="work-spool-mobile-summary__val">' + formatRemainingPlain(p) + '</span></div>'
      + '<div class="work-spool-mobile-summary__metric"><span class="work-spool-mobile-summary__lbl">Běžný stav</span>'
      + '<span class="work-spool-mobile-summary__val">' + formatLastVisiblePlain(p) + '</span></div>'
      + '</div></div>';
  }
  function buildResultsHtml(list, selectedSpool) {
    var n = list.length;
    var mobile = isWorkMobileLayout();
    var single = n === 1;
    var picked = selectedSpool || (single ? list[0] : null);
    var mobileCard = mobile && !!picked;
    var h = '<div class="work-results-block' + (mobileCard ? ' work-results--single-selected' : '') + '">';
    if (!mobileCard) {
      h += '<h2 class="work-result-h2" style="font-size:1.1rem;margin:.35rem 0 .5rem">Výsledek (' + n + ')</h2>';
    } else if (!mobile && single) {
      h += '<h2 class="work-result-h2 work-result-h2--count-only" style="font-size:1.1rem;margin:.35rem 0 .5rem">Výsledek (1)</h2>';
    }
    if (mobileCard) { h += mobileSummaryHtml(picked); }
    var rows = list.map(function (p) {
      return rowHtml(p, picked && String(picked.id) === String(p.id));
    }).join('');
    h += tableShell(rows);
    if (n > 1 && !mobileCard) {
      h += '<p id="work-pick-hint" class="work-pick-hint" style="margin:.75rem 0 .5rem;color:#444">Vyberte správnou cívku <strong>kliknutím na řádek</strong> (záznam a karta pod tabulkou).</p>';
    }
    h += '</div>';
    return h;
  }
  function formatLastVisibleCell(p) {
    if (p == null) return '—';
    return (p.lastVisibleM != null) ? esc(p.lastVisibleM) : '—';
  }
  function highlightSpoolRow(selectedId) {
    if (!results) return;
    var rows = results.querySelectorAll('tr.work-spool-row');
    for (var j = 0; j < rows.length; j++) {
      var tr = rows[j];
      tr.classList.toggle('is-selected', String(selectedId) == tr.getAttribute('data-spool-id'));
    }
  }
  function kartaEmbedUrl(id) { return kartaEmbedBase.replace(/\/0\/karta-embed/, '/' + id + '/karta-embed'); }
  function loadKarta(id) {
    var host = document.getElementById('work-karta-host');
    if (!host) return;
    host.innerHTML = '<p class="work-karta-loading" style="color:#666;margin:.5rem 0">Načítám kartu…</p>';
    fetch(kartaEmbedUrl(id), { credentials: 'same-origin', headers: { 'X-Requested-With': 'XMLHttpRequest' } })
      .then(function (r) { if (!r.ok) throw new Error('embed'); return r.text(); })
      .then(function (html) { host.innerHTML = html; })
      .catch(function () {
        host.innerHTML = '<p style="color:#a00">Karta se nepodařila načíst. <a href="' + spoolShowUrl(id) + '">Otevřít v evidenci</a></p>';
      });
  }
  function collapseToSelected(p0) {
    if (!results || !p0) return;
    lastSpoolsList = [p0];
    results.innerHTML = buildResultsHtml([p0], p0);
    loadKarta(p0.id);
    setMeterSpool(p0);
    setSearchFormCollapsed(true);
  }
  function showSpoolDetail(p0) {
    if (!p0) return;
    if (lastSpoolsList.length > 1) {
      collapseToSelected(p0);
      if (hint) hint.textContent = 'Vybraná cívka — můžete doplnit metr v bloku Záznam níže.';
    } else {
      loadKarta(p0.id);
      setMeterSpool(p0);
      highlightSpoolRow(p0.id);
    }
  }
  function bindSpoolTableClicks() {
    if (!results) return;
    results.addEventListener('click', function (ev) {
      if (ev.target.closest('a[href]')) return;
      var tr = ev.target.closest('tr.work-spool-row');
      if (!tr) return;
      var sid = tr.getAttribute('data-spool-id');
      if (!sid) return;
      var p0 = findSpoolInList(sid);
      if (p0) { showSpoolDetail(p0); if (ev.preventDefault) ev.preventDefault(); }
    });
    results.addEventListener('keydown', function (ev) {
      if (ev.key !== 'Enter' && ev.key !== ' ') return;
      if (ev.target.closest && ev.target.closest('a[href]')) return;
      var tr = ev.target.closest('tr.work-spool-row');
      if (!tr) return;
      var sid = tr.getAttribute('data-spool-id');
      var p0 = findSpoolInList(sid);
      if (p0) { showSpoolDetail(p0); ev.preventDefault(); }
    });
  }
  function bindMeter() {
    if (meterState.bound) return;
    meterState.bound = true;
    if (meterIn) { meterIn.addEventListener('input', updateMeter); meterIn.addEventListener('change', updateMeter); }
  }
  function updateMeter() {
    if (!calcBox || !meterIn) return;
    var s = meterState.s;
    if (!s) { calcBox.style.display = 'none'; return; }
    var p = (typeof s.previewPrevVisibleM === 'number')
      ? s.previewPrevVisibleM
      : (s.lastVisibleM != null ? s.lastVisibleM : s.initialVisibleM);
    var rem = s.currentRemainingM != null ? s.currentRemainingM : s.totalLengthM;
    var raw = (meterIn.value || '').trim();

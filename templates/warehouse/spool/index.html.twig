{% extends 'base.html.twig' %}
{% block title %}Práce s optikou — cívky{% endblock %}
{% block stylesheets %}
    {{ parent() }}
    <style>
        .work-input-sare {
            min-width: 32rem;
            max-width: 100%;
            flex: 1 1 20rem;
            font-size: 1.45rem;
            line-height: 1.3;
            padding: 0.6rem 1rem;
        }
    </style>
{% endblock %}
{% block body %}
    {% include '_app_menu_cz.html.twig' %}
    <h1>Práce s optikou</h1>
    <p class="lede" style="max-width: 40rem;">Zadejte <strong>číslo saře</strong> a stiskněte <strong>Hledat</strong>, nebo pište — po krátké pauze se hledá samo (AJAX). U jedné shody můžete doplnit <strong>aktuální metr (m)</strong>. Odkazy do jiných částí skladu jsou v zápatí.</p>

    <form id="work-search-form" method="get" action="{{ path('warehouse_spool_index') }}" style="max-width: 40rem; margin-bottom: 1.25rem;">
        <p style="margin: 0 0 .75rem;">
            <label for="work-q" style="display: block; font-weight: 600;">Číslo saře</label>
            <span style="display: flex; flex-wrap: wrap; gap: .5rem; align-items: center;">
                <input type="text" name="q" id="work-q" class="work-input-sare" value="{{ searchQuery|e('html_attr') }}" autocomplete="off" autocapitalize="off" spellcheck="false" placeholder="např. 450-1470">
                <button type="submit" style="white-space: nowrap;">Hledat</button>
                <button type="button" id="work-scan-btn" disabled style="white-space: nowrap;" title="Sken (čárový kód) — zatím nepřipojeno">Sken</button>
            </span>
            <span style="display: block; font-size: .86em; color: #555; margin-top: .3rem;">Hledá se v <code>reel_number</code> (podřetězec + shoda v číslicích). Bez JavaScriptu se použije odeslání formuláře a přenačte se stránka.</span>
        </p>
        <p style="margin: 0 0 .75rem;">
            <label for="work-meter" style="display: block; font-weight: 600;">Běžný stav (aktuální metráž, m)</label>
            <input type="number" name="visible_m" id="work-meter" inputmode="numeric" step="1" min="0" placeholder="po nalezení jedné cívky" style="min-width: 10rem; max-width: 100%;">
        </p>
        <p style="margin: 0 0 .75rem; display: none; padding: .5rem .75rem; background: #f5f5f5; border-radius: 4px; font-size: .92rem;" id="work-meter-calc" aria-live="polite"></p>
        <p style="margin: 0;">
            <label for="work-project" style="display: block; font-weight: 600;">Objekt / zakázka</label>
            <input type="text" name="project" id="work-project" autocomplete="off" style="min-width: 20rem; width: 100%;" placeholder="volitelné">
        </p>
    </form>

    <p id="work-ajax-hint" style="color: #666; font-size: .9em; min-height: 1.2em;" aria-live="polite"></p>

    <div id="work-results">
    {% if searchPerformed %}
        {% if spools is empty %}
            <p style="color: #333;"><strong>Žádná shoda</strong> pro dotaz «{{ searchQuery|e }}».</p>
        {% else %}
            <h2 style="font-size: 1.1rem; margin: 1rem 0 .5rem;">Výsledek ({{ spools|length }})</h2>
            <table>
                <thead>
                    <tr>
                        <th>Číslo saře</th>
                        <th>Typ</th>
                        <th>L (m)</th>
                        <th>Zbývá (m)</th>
                        <th>Stav</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                {% for s in spools %}
                    <tr>
                        <td>{{ s.reelNumber }}</td>
                        <td>{{ s.cableType ? s.cableType.code : '—' }}</td>
                        <td>{{ s.totalLengthM }}</td>
                        <td>{{ s.currentRemainingM ?? '—' }}</td>
                        <td>{% if s.status.value == 'in_stock' %}na skladě{% elseif s.status.value == 'transferred' %}předáno{% elseif s.status.value == 'written_off' %}vyřazeno{% else %}{{ s.status.value }}{% endif %}</td>
                        <td><a href="{{ path('warehouse_spool_show', {id: s.id}) }}">Karta</a></td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>

            {% if spools|length == 1 %}
                {% set sp = spools[0] %}
                <h2 style="font-size: 1.1rem; margin: 1.25rem 0 .5rem;">Poslední záznamy (náhled)</h2>
                {% if sp.events|length %}
                    <table>
                        <thead>
                            <tr><th>Kdy</th><th>Typ</th><th>m (čtení)</th><th>Odběr (m)</th><th>Zakázka</th></tr>
                        </thead>
                        <tbody>
                        {% for e in sp.events|slice(-5, 5) %}
                            <tr>
                                <td>{{ e.occurredAt|date('Y-m-d H:i') }}</td>
                                <td>{% if e.type.value == 'meter_reading' %}odběr dle metru{% elseif e.type.value == 'transfer' %}předání{% elseif e.type.value == 'writeoff' %}vyřazení{% elseif e.type.value == 'inventory' %}inventura{% elseif e.type.value == 'correction' %}oprava{% elseif e.type.value == 'laid_section' %}úsek (štítek){% else %}{{ e.type.value }}{% endif %}</td>
                                <td>{{ e.visibleM ?? '—' }}</td>
                                <td>{{ e.usedMeters ?? '—' }}</td>
                                <td>{{ e.projectLabel|default('—') }}</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                {% else %}
                    <p>Žádné události v deníku.</p>
                {% endif %}
                <p style="margin-top: .75rem;"><a href="{{ path('warehouse_spool_show', {id: sp.id}) }}">Otevřít kartu cívky (trvalý zápis) →</a></p>
            {% endif %}
        {% endif %}
    {% endif %}
    </div>

    <footer id="work-page-footer" class="work-page-footer" style="margin-top: 2.5rem; padding-top: 1rem; border-top: 1px solid #ddd; max-width: 40rem; font-size: .92rem; color: #444;">
        <p style="margin: 0 0 .5rem;">Pole <strong>Objekt / zakázka</strong> doplňte podle místa práce.</p>
        <p style="margin: 0;">Nové cívky → <a href="{{ path('warehouse_receipt_index') }}">Příjem kabelu</a>. <a href="{{ path('warehouse_spool_list') }}">Úplný seznam</a> · <a href="{{ path('warehouse_browse_index') }}">Přehled s filtry</a>.</p>
    </footer>
    {% if oneSpoolJson %}
    <script type="application/json" id="work-spool-json">{{ oneSpoolJson|raw }}</script>
    {% endif %}
{% endblock %}
{% block javascripts %}
    {{ parent() }}
    <script>
(function () {
  var form = document.getElementById('work-search-form');
  var qIn = document.getElementById('work-q');
  var hint = document.getElementById('work-ajax-hint');
  var results = document.getElementById('work-results');
  var meterIn = document.getElementById('work-meter');
  var calcBox = document.getElementById('work-meter-calc');
  var lookupUrl = {{ path('warehouse_spool_lookup')|json_encode|raw }};
  var spoolShowBase = {{ path('warehouse_spool_show', {id: 0})|json_encode|raw }};
  var t = null, seq = 0;
  var debounceMs = 380;
  var meterState = { s: null, bound: false };

  function spoolShowUrl(id) { return spoolShowBase.replace(/\/[0-9]+$/, '/' + id); }
  function esc(t) { if (t == null) return ''; return String(t).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
  function eventLabel(v) {
    if (v === 'meter_reading') return 'odběr dle metru';
    if (v === 'transfer') return 'předání';
    if (v === 'writeoff') return 'vyřazení';
    if (v === 'inventory') return 'inventura';
    if (v === 'correction') return 'oprava';
    if (v === 'laid_section') return 'úsek (štítek)';
    return esc(v);
  }
  function bindMeter() {
    if (meterState.bound) return;
    meterState.bound = true;
    if (meterIn) { meterIn.addEventListener('input', updateMeter); meterIn.addEventListener('change', updateMeter); }
  }
  function updateMeter() {
    if (!calcBox || !meterIn) return;
    var s = meterState.s;
    if (!s) { calcBox.style.display = 'none'; return; }
    var p = s.lastVisibleM != null ? s.lastVisibleM : s.initialVisibleM;
    var rem = s.currentRemainingM != null ? s.currentRemainingM : s.totalLengthM;
    var raw = (meterIn.value || '').trim();
    var n = raw === '' ? null : parseInt(raw, 10);
    if (n === null || n !== n) {
      calcBox.style.display = 'block';
      calcBox.innerHTML = '<strong>Evidence:</strong> m₀ = ' + esc(s.initialVisibleM) + (p != null ? ', poslední m = ' + esc(p) : '') + (rem != null ? ', zůstatek nyní ' + esc(rem) + ' m' : '') + '.';
      return;
    }
    if (p == null) { calcBox.style.display = 'block'; calcBox.textContent = 'Chybí referenční m v evidenci.'; return; }
    var used = Math.abs(n - p);
    var after = rem != null ? (rem - used) : null;
    var w = 'Předchozí m = ' + p + ' → odběr ≈ ' + used + ' m' + (after != null ? ' → zůstatek ≈ ' + after + ' m' : '') + '.';
    if (rem != null && used > rem) w += ' <span style="color:#a00">Odběr přesahuje zůstatek.</span>';
    calcBox.style.display = 'block';
    calcBox.innerHTML = w;
  }
  function setMeterSpool(s) {
    meterState.s = s;
    if (s && meterIn) { meterIn.value = ''; }
    if (!s) { if (calcBox) { calcBox.style.display = 'none'; calcBox.innerHTML = ''; } return; }
    bindMeter();
    updateMeter();
  }
  function renderFromApi(data) {
    if (!results) return;
    if (!data || data.ok === false) {
      results.innerHTML = '<p style="color:#a00">Chyba: ' + esc((data && data.message) || 'neznámá') + '</p>';
      setMeterSpool(null);
      return;
    }
    var list = data.spools || [];
    if (list.length === 0) {
      results.innerHTML = '<p><strong>Žádná shoda</strong> pro «' + esc(data.query) + '».</p>';
      setMeterSpool(null);
      return;
    }
    var rows = list.map(function (p) {
      var ctc = (p.cableTypeCode != null && p.cableTypeCode !== '') ? esc(p.cableTypeCode) : '—';
      return '<tr><td>' + esc(p.reelNumber) + '</td><td>' + ctc + '</td><td>' + esc(p.totalLengthM) + '</td><td>' + (p.currentRemainingM != null ? esc(p.currentRemainingM) : '—') + '</td><td>' + esc(p.statusLabel) + '</td><td><a href="' + spoolShowUrl(p.id) + '">Karta</a></td></tr>';
    }).join('');
    var h = '<h2 style="font-size:1.1rem;margin:1rem 0 .5rem">Výsledek (' + list.length + ')</h2><table><thead><tr><th>Číslo saře</th><th>Typ</th><th>L (m)</th><th>Zbývá (m)</th><th>Stav</th><th></th></tr></thead><tbody>' + rows + '</tbody></table>';
    if (list.length === 1) {
      var p0 = list[0];
      h += '<h2 style="font-size:1.1rem;margin:1.25rem 0 .5rem">Poslední záznamy (náhled)</h2>';
      var le = (p0.lastEvents || []).slice().sort(function (a, b) {
        return (a.occurredAt || '').localeCompare(b.occurredAt || '');
      });
      if (le.length) {
        h += '<table><thead><tr><th>Kdy</th><th>Typ</th><th>m (čtení)</th><th>Odběr (m)</th><th>Zakázka</th></tr></thead><tbody>';
        le.forEach(function (e) {
          var d = (e.occurredAt || '').replace('T', ' ').slice(0, 16);
          h += '<tr><td>' + esc(d) + '</td><td>' + esc(e.typeLabel || eventLabel(e.type)) + '</td><td>' + (e.visibleM != null ? esc(e.visibleM) : '—') + '</td><td>' + (e.usedMeters != null ? esc(e.usedMeters) : '—') + '</td><td>' + esc(e.projectLabel || '—') + '</td></tr>';
        });
        h += '</tbody></table>';
      } else {
        h += '<p>Žádné události v deníku.</p>';
      }
      h += '<p style="margin-top:.75rem"><a href="' + spoolShowUrl(p0.id) + '">Otevřít kartu cívky (trvalý zápis) →</a></p>';
      setMeterSpool(p0);
    } else {
      setMeterSpool(null);
    }
    results.innerHTML = h;
  }
  function runFetch(q, force) {
    q = (q || '').trim();
    if (q.length < 1) { if (hint) hint.textContent = ''; if (results) results.innerHTML = ''; setMeterSpool(null); return; }
    var my = ++seq;
    if (hint) hint.textContent = 'Načítám…';
    var u = new URL(lookupUrl, window.location.origin);
    u.searchParams.set('q', q);
    fetch(u.toString(), { credentials: 'same-origin', headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' } })
      .then(function (r) {
        var ct = (r.headers.get('content-type') || '');
        if (ct.indexOf('application/json') === -1) { return r.text().then(function () { throw new Error('not json'); }); }
        return r.json();
      })
      .then(function (data) {
        if (my !== seq) return;
        if (data && data.ok === false) {
          if (hint) hint.textContent = (data.message) ? ('Chyba: ' + data.message) : 'Chyba hledání.';
          renderFromApi(data);
          return;
        }
        if (hint) {
          if (!data || data.count === 0) hint.textContent = 'Žádná shoda — podle zadaného saře.';
          else if (data.count === 1) hint.textContent = 'Jedna shoda — můžete doplnit metr výše.';
          else hint.textContent = 'Nalezeno ' + data.count + ' cívek.';
        }
        if (window.history && window.history.replaceState) {
          var url = new URL(window.location.href);
          url.searchParams.set('q', q);
          window.history.replaceState(null, '', url.toString());
        }
        renderFromApi(data);
      })
      .catch(function (e) {
        if (my !== seq) return;
        if (hint) hint.textContent = 'Chyba spojení — použije se odeslání stránky.';
        if (form) form.submit();
      });
  }
  function onQueryChange() {
    var q = (qIn && qIn.value) ? qIn.value.trim() : '';
    if (q.length < 1) { if (hint) hint.textContent = ''; clearTimeout(t); if (results) results.innerHTML = ''; setMeterSpool(null); return; }
    clearTimeout(t);
    t = setTimeout(function () {
      var qNow = (qIn && qIn.value) ? String(qIn.value).trim() : '';
      if (qNow.length < 1) { if (hint) hint.textContent = ''; if (results) results.innerHTML = ''; setMeterSpool(null); return; }
      runFetch(qNow, false);
    }, debounceMs);
  }
  if (form && qIn) {
    form.addEventListener('submit', function (e) {
      e.preventDefault();
      runFetch(qIn.value, true);
    });
    qIn.addEventListener('input', onQueryChange);
    qIn.addEventListener('paste', function () { setTimeout(onQueryChange, 0); });
  }
  var boot = document.getElementById('work-spool-json');
  if (boot && boot.textContent) {
    try {
      setMeterSpool(JSON.parse(boot.textContent));
    } catch (err) {}
  }
})();
    </script>
{% endblock %}

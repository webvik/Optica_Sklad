{% extends 'base.html.twig' %}
{% block title %}Práce s optikou — cívky{% endblock %}
{% block stylesheets %}
    {{ parent() }}
    <style>
        .work-input-sare {
            min-width: 0;
            width: 100%;
            max-width: 100%;
            flex: 1 1 12rem;
            font-size: 1.25rem;
            line-height: 1.3;
            padding: 0.7rem 1rem;
        }
        @media (min-width: 42rem) {
            .work-input-sare { font-size: 1.6rem; padding: 0.7rem 1.15rem; flex: 1 1 20rem; min-width: 12rem; }
        }
        .work-input-meter {
            min-width: 0;
            width: 100%;
            max-width: 28rem;
            font-size: 1.45rem;
            line-height: 1.3;
            padding: 0.6rem 1rem;
        }
        .work-input-project {
            min-width: 0;
            width: 100%;
            max-width: 40rem;
            font-size: 1.45rem;
            line-height: 1.3;
            padding: 0.6rem 1rem;
        }
        #work-scan-overlay {
            position: fixed;
            inset: 0;
            z-index: 9999;
            background: rgba(0,0,0,.75);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 1rem;
            padding: 1rem;
            box-sizing: border-box;
        }
        #work-scan-overlay[hidden] { display: none !important; }
        #work-scan-video-wrap {
            flex-shrink: 0;
            max-width: min(100%, 640px);
            box-sizing: border-box;
        }
        /* Režim záznamu: velké náhledové video jako dříve */
        #work-scan-video-wrap:not(.work-scan-video-wrap--sare-strip) #work-scan-video {
            display: block;
            max-width: 100%;
            max-height: 50vh;
            width: auto;
            height: auto;
            background: #111;
            border-radius: 6px;
        }
        /* Sken čísla saře: nízký pruh (≈ řádek štítku), rozpoznává se jen prostředek snímku */
        .work-scan-overlay--sare-strip #work-scan-video-wrap.work-scan-video-wrap--sare-strip {
            width: min(100%, 34rem);
            height: clamp(5.75rem, 16vh, 8.75rem);
            overflow: hidden;
            border-radius: 8px;
            border: 2px solid rgba(85, 220, 175, 0.9);
            box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.35);
            background: #111;
            position: relative;
        }
        .work-scan-overlay--sare-strip #work-scan-video-wrap.work-scan-video-wrap--sare-strip::after {
            content: '';
            position: absolute;
            inset: 0;
            pointer-events: none;
            border: 1px solid rgba(255, 255, 255, 0.08);
            box-sizing: border-box;
            border-radius: inherit;
            z-index: 1;
        }
        .work-scan-overlay--sare-strip #work-scan-video-wrap.work-scan-video-wrap--sare-strip #work-scan-video {
            display: block;
            width: 100%;
            height: 100%;
            max-height: none;
            border-radius: 0;
            object-fit: cover;
            object-position: center center;
        }

        .work-spool-table { width: 100%; }
        .work-spool-table tbody tr.work-spool-row { cursor: pointer; }
        .work-spool-table tbody tr.work-spool-row:hover { background: #f0f7ff; }
        .work-spool-table tbody tr.work-spool-row.is-selected { background: #e0efff; }
        .work-spool-card {
            max-width: 40rem;
            margin-top: 1.25rem;
            padding: 1rem 1.1rem;
            border: 1px solid #c8d4e0;
            border-radius: 6px;
            background: #f9fbfd;
        }
        .work-spool-card[hidden] { display: none !important; }
        .work-data-panel[hidden] { display: none !important; }
        .work-data-panel {
            max-width: 50rem;
            margin-top: 0.5rem;
            margin-bottom: 0;
            padding: 0.9rem 1rem;
            border: 1px solid #c8d4e0;
            border-radius: 6px;
            background: #f9fbfd;
        }
        .work-karta-host-wrap { margin-top: 1.1rem; }
        .spool-karta-embed { max-width: 50rem; }
        .spool-karta-embed table { width: 100%; font-size: 0.95rem; }
        .work-search-field-row { display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: stretch; }
        @media (max-width: 36rem) {
            .work-search-field-row { flex-direction: column; align-items: stretch; }
            /* v řádku dává flex-grow:1 šířku; ve sloupci stejné pravidlo roztahuje pole po výšce — vypnout */
            .work-input-sare { flex: 0 0 auto; width: 100%; font-size: 1rem; line-height: 1.3; padding: 0.5rem 0.75rem; }
            .work-search-field-row .work-search-action-btn { width: 100%; min-height: 2.75rem; justify-content: center; flex: 0 0 auto; }
        }
        .work-record-scan-row { display: flex; flex-wrap: wrap; align-items: center; gap: 0.5rem 0.75rem; margin: 0.5rem 0 0.75rem; }
        @media (max-width: 36rem) {
            .work-record-scan-row { flex-direction: column; align-items: stretch; }
            .work-record-scan-row .work-scan-tl { width: 100%; min-height: 2.75rem; justify-content: center; }
        }
        .work-record-scan-hint { font-size: 0.88rem; color: #555; max-width: 42rem; line-height: 1.35; }
        .work-spool-table-wrap { margin: 0 -0.15rem; }
        @media (max-width: 36rem) {
            .work-page-footer { max-width: none; }
            .work-result-stack { max-width: 100% !important; }
            .work-spool-table-wrap .work-spool-table { font-size: 0.78rem; }
            .work-spool-table-wrap .work-spool-table th,
            .work-spool-table-wrap .work-spool-table td { padding: 0.28rem 0.3rem; line-height: 1.2; }
            .work-spool-table-wrap .work-spool-table th { font-weight: 600; letter-spacing: -0.02em; }
            .work-spool-table-wrap.table-scroll--wide > .work-spool-table { min-width: 33rem; }
        }
        #work-data-panel .work-submit-record, #work-record-form [type="submit"] { min-height: 2.6rem; padding: 0.5rem 1.1rem; }
        @media (max-width: 36rem) {
            #work-data-panel .work-submit-record, #work-record-form [type="submit"] { min-height: 2.75rem; width: 100%; font-size: 1.05rem; }
        }
        #work-search-form .work-search-action-btn {
            box-sizing: border-box;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-height: 2.6rem;
            min-width: 5.5rem;
            padding: 0.5rem 1rem;
            font: inherit;
            font-size: 1.1rem;
            line-height: 1.2;
            font-weight: 500;
            white-space: nowrap;
            cursor: pointer;
            border: 1px solid #bbb;
            border-radius: 4px;
            background: #f5f5f5;
            color: inherit;
        }
        #work-search-form .work-search-action-btn:hover {
            background: #eaeaec;
        }
        #work-search-form .work-search-action-btn:active {
            background: #e0e0e2;
        }
        .work-search-sare-scan-group {
            display: inline-flex;
            flex-wrap: wrap;
            gap: 0.5rem;
            flex: 0 1 auto;
            align-items: stretch;
            min-width: 0;
        }
        .work-search-sare-scan-group .work-search-action-btn {
            flex: 1 1 min(9rem, 100%);
            min-width: 0;
            white-space: normal;
            text-align: center;
            line-height: 1.2;
        }
        @media (max-width: 36rem) {
            .work-search-sare-scan-group { width: 100%; }
            .work-search-sare-scan-group .work-search-action-btn {
                flex: 1 1 calc(50% - 0.25rem);
                min-height: 2.75rem;
                font-size: 1rem;
            }
        }
        .work-top-area { max-width: 40rem; width: 100%; margin-bottom: 0.75rem; }
        .work-top-area.is-search-collapsed .work-page-lede { display: none; }
        .work-top-area.is-search-collapsed .work-search-form-wrap { display: none; }
        .work-search-next-tl {
            display: none;
            box-sizing: border-box;
            align-items: center;
            gap: 0.5rem;
            width: 100%;
            max-width: 40rem;
            min-height: 2.6rem;
            padding: 0.55rem 1rem;
            font: inherit;
            font-size: 1.05rem;
            font-weight: 500;
            cursor: pointer;
            text-align: left;
            border: 1px solid #b8c4d0;
            border-radius: 6px;
            background: #eef2f6;
            color: #1a1a1a;
        }
        .work-search-next-tl:hover { background: #e2e8f0; }
        .work-search-next-tl .work-search-next-ico { flex-shrink: 0; }
        .work-top-area.is-search-collapsed .work-search-next-tl { display: inline-flex; }
        @media (max-width: 36rem) {
            .work-search-next-tl { min-height: 2.75rem; }
            h1 { font-size: 1.35rem; }
            .work-result-h2 { font-size: 0.95rem !important; }
        }
        #work-scan-cancel { min-height: 2.75rem; min-width: 7rem; padding: 0.5rem 1.2rem; }
    </style>
{% endblock %}
{% block body %}
    {% include '_app_menu_cz.html.twig' %}
    <h1>Práce s optikou</h1>
    <div id="work-top-area" class="work-top-area{% if searchPerformed and spools|length == 1 %} is-search-collapsed{% endif %}">
    <p class="lede work-page-lede" id="work-page-lede">Zadejte <strong>číslo saře</strong> a stiskněte <strong>Hledat</strong>, nebo pište — po pauze se hledá samo. Při více shodách <strong>klikněte na řádek</strong>. <strong>PS (m)</strong> = počáteční stav metru <em>na kabelu</em>; <strong>Délka (m)</strong> = délka kabelu na cívce.<span id="work-data-lede"{% if not (searchPerformed and spools|length == 1) %} hidden{% endif %}> U vybrané cívky můžete v bloku <em>Záznam pro práci</em> hned <strong>pod tabulkou</strong> zapsat <strong>zafuk</strong> tlačítkem <strong>Zapsat</strong>.</span> Odkazy v zápatí.</p>

    <div class="work-search-shell">
    <div class="work-search-form-wrap">
    <form id="work-search-form" method="get" action="{{ path('warehouse_spool_index') }}" style="margin: 0;">
        <p style="margin: 0;">
            <label for="work-q" style="display: block; font-weight: 600; margin-bottom: 0.35rem;">Číslo saře</label>
            <span class="work-search-field-row" style="width: 100%;">
                <input type="text" name="q" id="work-q" class="work-input-sare" value="{{ searchQuery|e('html_attr') }}" autocomplete="off" autocapitalize="off" spellcheck="false" inputmode="search" enterkeyhint="search" placeholder="např. 450-1470">
                <button type="submit" class="work-search-action-btn">Hledat</button>
                <button type="button" id="work-scan-btn" class="work-search-action-btn work-scan-tl" data-work-scan-mode="sare" title="Sken čísla saře: úzký pruh nad kódem → pole Číslo saře (upravte před Hledat)">Sken</button>
            </span>
        </p>
    </form>
    </div>
    <button type="button" id="work-search-expand-btn" class="work-search-next-tl" title="Rozbalit nápovědu a hledání další cívky" aria-controls="work-top-area" aria-expanded="false">
        <svg class="work-search-next-ico" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true" focusable="false">
            <circle cx="10.5" cy="10.5" r="6.5"></circle>
            <path d="M16 16l4.5 4.5"></path>
        </svg>
        <span>Hledat další cívku</span>
    </button>
    </div>
    </div>

    <p id="work-ajax-hint" style="color: #666; font-size: .9em; min-height: 1.2em; margin: 0.35rem 0 0.6rem;" aria-live="polite"></p>

    <div id="work-result-stack" class="work-result-stack" style="max-width: 60rem;">
        <div id="work-results-dynamic">
    {% if searchPerformed %}
        {% if spools is empty %}
            <p style="color: #333;"><strong>Žádná shoda</strong> pro dotaz «{{ searchQuery|e }}».</p>
        {% else %}
            <h2 class="work-result-h2" style="font-size: 1.1rem; margin: 0.35rem 0 .5rem;">Výsledek ({{ spools|length }})</h2>
            <div class="table-scroll table-scroll--wide work-spool-table-wrap">
            <table class="work-spool-table">
                <thead>
                    <tr>
                        <th>Číslo saře</th>
                        <th title="Poslední čtení metru (last_visible_m)">Běžný stav (m)</th>
                        <th>Zbývá (m)</th>
                        <th>Typ</th>
                        <th title="Počet optických vláken (z cívky nebo z typu kabelu)">Vláken</th>
                        <th title="Počáteční čtení metru na kabelu (ne délka)">PS (m)</th>
                    </tr>
                </thead>
                <tbody>
                {% for s in spools %}
                    {% set rem = spoolRemaining[s.id] ?? null %}
                    <tr class="work-spool-row{% if spools|length == 1 %} is-selected{% endif %}" data-spool-id="{{ s.id }}" tabindex="0" title="Vybrat tuto cívku">
                        <td>{{ s.reelNumber }}</td>
                        <td>{% if s.lastVisibleM is not null %}{{ s.lastVisibleM }}{% else %}—{% endif %}</td>
                        <td>{% if rem is not null %}{{ rem.remaining }}{% if rem.warning %} <span title="{{ rem.warning|e('html_attr') }}" style="cursor: help; color: #a00;">⚠</span>{% endif %}{% else %}—{% endif %}</td>
                        <td>{{ s.family ?: '—' }}</td>
                        <td>{{ s.effectiveFiberCount }}</td>
                        <td>{{ s.initialVisibleM }}{% if rem is not null and rem.directionLabel %} <span style="font-size: .82em; color: #666;">({{ rem.directionLabel }})</span>{% endif %}</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
            </div>
            {% if spools|length > 1 %}
            <p id="work-pick-hint" class="work-pick-hint" style="margin: .75rem 0 .5rem; color: #444;">Vyberte správnou cívku <strong>kliknutím na řádek</strong> v tabulce; níže můžete zapsat zafuk, pod tím se načte karta a deník.</p>
            {% endif %}
        {% endif %}
    {% endif %}
        </div>

    <div id="work-data-panel" class="work-data-panel" role="region" aria-labelledby="work-data-heading"{% if not (searchPerformed and spools|length == 1) %} hidden{% endif %}>
        <h2 id="work-data-heading" style="font-size: 1.05rem; margin: 0 0 0.65rem;">Záznam pro práci s cívkou</h2>
        <p id="work-data-spool-hint" style="margin: 0 0 0.75rem; color: #555; font-size: 0.95rem;">{% if searchPerformed and spools|length == 1 %}Cívka <strong>{{ spools[0].reelNumber|e }}</strong> — zapsat <strong>zafuk</strong> (očekává se nové čtení m na kabelu). Doplňte také <a href="{{ path('warehouse_spool_show', {id: spools[0].id}) }}">plnou kartu</a> pro jiné typy událostí.{% else %}Tento blok se zobrazí po <strong>výběru cívky</strong> v tabulce.{% endif %}</p>
        <form id="work-record-form" method="post" action="{{ path('warehouse_spool_work_record') }}">
            <input type="hidden" name="_token" value="{{ csrf_token('spool_work_record') }}">
            <input type="hidden" name="return_q" id="work-record-return-q" value="{{ searchQuery|e('html_attr') }}">
            <input type="hidden" name="spool_id" id="work-record-spool-id" value="{% if searchPerformed and spools|length == 1 %}{{ spools[0].id }}{% endif %}">
            <p style="margin: 0 0 .75rem;">
                <label for="work-meter" style="display: block; font-weight: 600; font-size: 1.05rem; margin-bottom: 0.35rem;">Běžný stav (aktuální metráž, m)</label>
                <input type="number" name="visible_m" id="work-meter" class="work-input-meter" inputmode="numeric" step="1" min="0" placeholder="nové čtení metru">
            </p>
            <p style="margin: 0 0 .75rem; display: none; padding: .5rem .75rem; background: #edf2f7; border-radius: 4px; font-size: .92rem;" id="work-meter-calc" aria-live="polite"></p>
            <p style="margin: 0 0 .9rem;">
                <label for="work-project" style="display: block; font-weight: 600; font-size: 1.05rem; margin-bottom: 0.35rem;">Objekt / zakázka</label>
                <input type="text" name="project" id="work-project" class="work-input-project" autocomplete="off" placeholder="volitelné">
            </p>
            <div class="work-record-scan-row">
                <button type="button" id="work-record-scan-btn" class="work-scan-tl" data-work-scan-mode="record" style="white-space: nowrap; font-size: 1.1rem; padding: 0.45rem 0.9rem;" title="Sken do záznamu: metráž, nebo metráž;zakázka (oddělovač ;, |, tab)">Sken</button>
                <span class="work-record-scan-hint">Jeden kód: jen číslice → <strong>Běžný stav</strong> (m). Dva údaje: <code>7843;Z123</code> nebo tab / <code>|</code> → metráž a <strong>Objekt / zakázka</strong>. Bez kamery: čtečka může psát do pole (stejný formát).</span>
            </div>
            <p style="margin: 0;">
                <button type="submit" class="work-submit-record" style="font-size: 1rem;">Zapsat</button>
            </p>
        </form>
    </div>

    <div id="work-karta-host" class="work-karta-host-wrap">{% if searchPerformed and spools|length == 1 %}{% include 'warehouse/spool/_karta_work_embed.html.twig' with { spool: spools[0] } only %}{% endif %}</div>
    </div>

    <div id="work-scan-overlay" hidden role="dialog" aria-label="Sken čárového kódu">
        <p id="work-scan-overlay-text" style="color:#fff;margin:0;text-align:center;max-width:34rem"></p>
        <div id="work-scan-video-wrap">
            <video id="work-scan-video" playsinline autoplay muted></video>
        </div>
        <button type="button" id="work-scan-cancel" style="padding:0.5rem 1.2rem;font-size:1rem">Zrušit</button>
    </div>

    <footer id="work-page-footer" class="work-page-footer" style="margin-top: 2.5rem; padding-top: 1rem; border-top: 1px solid #ddd; max-width: 40rem; font-size: .92rem; color: #444;">
        <p style="margin: 0 0 .5rem;">Pole <strong>Objekt / zakázka</strong> doplňte podle místa práce.</p>
        <p style="margin: 0;">Nové cívky → <a href="{{ path('warehouse_receipt_index') }}">Příjem kabelu</a>. <a href="{{ path('warehouse_spool_list') }}">Úplný seznam</a> · <a href="{{ path('warehouse_browse_index') }}">Přehled s filtry</a>.</p>
    </footer>
    {% if spoolsLookupJson %}
    <script type="application/json" id="work-spools-json">{{ spoolsLookupJson|raw }}</script>
    {% endif %}
{% endblock %}
{% block javascripts %}
    {{ parent() }}
    <script>
(function () {
  var form = document.getElementById('work-search-form');
  var qIn = document.getElementById('work-q');
  var hint = document.getElementById('work-ajax-hint');
  var results = document.getElementById('work-results-dynamic');
  var meterIn = document.getElementById('work-meter');
  var projectIn = document.getElementById('work-project');
  var calcBox = document.getElementById('work-meter-calc');
  var dataPanel = document.getElementById('work-data-panel');
  var ledeData = document.getElementById('work-data-lede');
  var workDataHint = document.getElementById('work-data-spool-hint');
  var lookupUrl = {{ path('warehouse_spool_lookup')|json_encode|raw }};
  var spoolShowBase = {{ path('warehouse_spool_show', {id: 0})|json_encode|raw }};
  var kartaEmbedBase = {{ path('warehouse_spool_karta_embed', {id: 0})|json_encode|raw }};
  var t = null, seq = 0;
  var debounceMs = 380;
  var meterState = { s: null, bound: false };
  var lastSpoolsList = [];
  var workTopArea = document.getElementById('work-top-area');
  var expandSearchBtn = document.getElementById('work-search-expand-btn');

  function setSearchFormCollapsed(c) {
    if (workTopArea) {
      if (c) { workTopArea.classList.add('is-search-collapsed'); }
      else { workTopArea.classList.remove('is-search-collapsed'); }
    }
    if (expandSearchBtn) {
      expandSearchBtn.setAttribute('aria-expanded', c ? 'false' : 'true');
    }
  }
  function spoolShowUrl(id) { return spoolShowBase.replace(/\/[0-9]+$/, '/' + id); }
  function esc(t) { if (t == null) return ''; return String(t).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
  function setWorkDataPanel(s) {
    if (!dataPanel) return;
    if (s) {
      dataPanel.removeAttribute('hidden');
      if (ledeData) ledeData.removeAttribute('hidden');
      if (workDataHint) workDataHint.innerHTML = 'Cívka <strong>' + esc(s.reelNumber) + '</strong> — zadejte čtení a volitelně zakázku, <strong>Zapsat</strong> uloží zafuk. Jiné události v <a href="' + spoolShowUrl(s.id) + '">kartě cívky</a>.';
    } else {
      dataPanel.setAttribute('hidden', '');
      if (ledeData) ledeData.setAttribute('hidden', '');
      if (workDataHint) workDataHint.textContent = 'Tento blok se zobrazí po výběru cívky v tabulce nahoře.';
    }
  }
  function formatPsCell(p) {
    if (p == null) return '—';
    var v = esc(p.initialVisibleM);
    var dir = p.meterNumberingLabel ? (' <span style="font-size:.82em;color:#666">(' + esc(p.meterNumberingLabel) + ')</span>') : '';
    return v + dir;
  }
  function formatRemainingCell(p) {
    if (p == null) return '—';
    var v = (p.currentRemainingM != null) ? esc(p.currentRemainingM) : '—';
    var w = p.remainingWarning ? String(p.remainingWarning) : '';
    var bad = p.remainingDirectionOk === false || (w && w.length);
    var flag = bad ? (' <span title="' + esc(w) + '" style="cursor:help;color:#a00">⚠</span>') : '';
    return v + flag;
  }
  function findSpoolInList(id) {
    for (var i = 0; i < lastSpoolsList.length; i++) { if (lastSpoolsList[i].id == id) return lastSpoolsList[i]; }
    return null;
  }
  function tableShell(rowsInner) {
    return '<div class="table-scroll table-scroll--wide work-spool-table-wrap"><table class="work-spool-table"><thead><tr><th>Číslo saře</th><th title="Poslední čtení metru">Běžný stav (m)</th><th>Zbývá (m)</th><th>Typ</th><th>Vláken</th><th>PS (m)</th></tr></thead><tbody>' + rowsInner + '</tbody></table></div>';
  }
  function formatLastVisibleCell(p) {
    if (p == null) return '—';
    return (p.lastVisibleM != null) ? esc(p.lastVisibleM) : '—';
  }
  function highlightSpoolRow(selectedId) {
    if (!results) return;
    var rows = results.querySelectorAll('tr.work-spool-row');
    for (var j = 0; j < rows.length; j++) {
      var tr = rows[j];
      tr.classList.toggle('is-selected', String(selectedId) == tr.getAttribute('data-spool-id'));
    }
  }
  function kartaEmbedUrl(id) { return kartaEmbedBase.replace(/\/0\/karta-embed/, '/' + id + '/karta-embed'); }
  function loadKarta(id) {
    var host = document.getElementById('work-karta-host');
    if (!host) return;
    host.innerHTML = '<p class="work-karta-loading" style="color:#666;margin:.5rem 0">Načítám kartu…</p>';
    fetch(kartaEmbedUrl(id), { credentials: 'same-origin', headers: { 'X-Requested-With': 'XMLHttpRequest' } })
      .then(function (r) { if (!r.ok) throw new Error('embed'); return r.text(); })
      .then(function (html) { host.innerHTML = html; })
      .catch(function () {
        host.innerHTML = '<p style="color:#a00">Karta se nepodařila načíst. <a href="' + spoolShowUrl(id) + '">Otevřít v evidenci</a></p>';
      });
  }
  function collapseToSelected(p0) {
    if (!results || !p0) return;
    lastSpoolsList = [p0];
    var h = '<h2 class="work-result-h2" style="font-size:1.1rem;margin:.35rem 0 .5rem">Výsledek (1)</h2>'
      + tableShell(rowHtml(p0, true));
    results.innerHTML = h;
    loadKarta(p0.id);
    setMeterSpool(p0);
  }
  function showSpoolDetail(p0) {
    if (!p0) return;
    if (lastSpoolsList.length > 1) {
      collapseToSelected(p0);
      if (hint) hint.textContent = 'Vybraná cívka — můžete doplnit metr v bloku Záznam níže.';
    } else {
      loadKarta(p0.id);
      setMeterSpool(p0);
      highlightSpoolRow(p0.id);
    }
  }
  function bindSpoolTableClicks() {
    if (!results) return;
    results.addEventListener('click', function (ev) {
      if (ev.target.closest('a[href]')) return;
      var tr = ev.target.closest('tr.work-spool-row');
      if (!tr) return;
      var sid = tr.getAttribute('data-spool-id');
      if (!sid) return;
      var p0 = findSpoolInList(sid);
      if (p0) { showSpoolDetail(p0); if (ev.preventDefault) ev.preventDefault(); }
    });
    results.addEventListener('keydown', function (ev) {
      if (ev.key !== 'Enter' && ev.key !== ' ') return;
      if (ev.target.closest && ev.target.closest('a[href]')) return;
      var tr = ev.target.closest('tr.work-spool-row');
      if (!tr) return;
      var sid = tr.getAttribute('data-spool-id');
      var p0 = findSpoolInList(sid);
      if (p0) { showSpoolDetail(p0); ev.preventDefault(); }
    });
  }
  function bindMeter() {
    if (meterState.bound) return;
    meterState.bound = true;
    if (meterIn) { meterIn.addEventListener('input', updateMeter); meterIn.addEventListener('change', updateMeter); }
  }
  function updateMeter() {
    if (!calcBox || !meterIn) return;
    var s = meterState.s;
    if (!s) { calcBox.style.display = 'none'; return; }
    var p = (typeof s.previewPrevVisibleM === 'number')
      ? s.previewPrevVisibleM
      : (s.lastVisibleM != null ? s.lastVisibleM : s.initialVisibleM);
    var rem = s.currentRemainingM != null ? s.currentRemainingM : s.totalLengthM;
    var raw = (meterIn.value || '').trim();
    var n = raw === '' ? null : parseInt(raw, 10);
    if (n === null || n !== n) {
      calcBox.style.display = 'none';
      calcBox.innerHTML = '';
      return;
    }
    if (p == null) { calcBox.style.display = 'block'; calcBox.textContent = 'Chybí referenční m v evidenci.'; return; }
    var used = Math.abs(n - p);
    var after = rem != null ? (rem - used) : null;
    var w = 'Předchozí m = ' + p + ' → krok ≈ ' + used + ' m' + (after != null ? ' → zůstatek ≈ ' + after + ' m' : '') + '.';
    if (rem != null && used > rem) w += ' <span style="color:#a00">Krok přesahuje zůstatek.</span>';
    calcBox.style.display = 'block';
    calcBox.innerHTML = w;
  }
  function setRecordSpoolId(id) {
    var el = document.getElementById('work-record-spool-id');
    if (el) el.value = (id != null && id !== '') ? String(id) : '';
    var f = document.getElementById('work-record-form');
    if (f) {
      var sub = f.querySelector('button[type="submit"]');
      if (sub) sub.disabled = !el || !el.value;
    }
  }
  function syncReturnQ() {
    var rq = document.getElementById('work-record-return-q');
    if (!rq) return;
    if (meterState.s && meterState.s.reelNumber != null && meterState.s.reelNumber !== '') {
      rq.value = String(meterState.s.reelNumber);
    } else if (qIn) {
      rq.value = (qIn.value != null) ? String(qIn.value) : '';
    }
  }
  function setMeterSpool(s) {
    setWorkDataPanel(s);
    setRecordSpoolId(s ? s.id : '');
    if (!s) {
      var kh = document.getElementById('work-karta-host');
      if (kh) kh.innerHTML = '';
    }
    meterState.s = s;
    if (s) {
      if (qIn && s.reelNumber) qIn.value = String(s.reelNumber);
      syncReturnQ();
      if (meterIn) meterIn.value = '';
      if (projectIn) projectIn.value = '';
    } else {
      if (calcBox) { calcBox.style.display = 'none'; calcBox.innerHTML = ''; }
      highlightSpoolRow(null);
      syncReturnQ();
    }
    setSearchFormCollapsed(!!s);
    if (!s) return;
    bindMeter();
    updateMeter();
  }
  if (expandSearchBtn) {
    expandSearchBtn.addEventListener('click', function () {
      setMeterSpool(null);
      if (qIn) { qIn.focus(); try { qIn.select(); } catch (e) {} }
    });
  }
  function rowHtml(p, selected) {
    var fam = (p.family != null && p.family !== '') ? esc(p.family) : '—';
    var fib = (p.fiberCount != null) ? esc(String(p.fiberCount)) : '—';
    return '<tr class="work-spool-row' + (selected ? ' is-selected' : '') + '" data-spool-id="' + esc(p.id) + '" tabindex="0" title="Vybrat tuto cívku">'
      + '<td>' + esc(p.reelNumber) + '</td><td>' + formatLastVisibleCell(p) + '</td><td>' + formatRemainingCell(p) + '</td><td>' + fam + '</td><td>' + fib + '</td><td>' + formatPsCell(p) + '</td></tr>';
  }
  function renderFromApi(data) {
    if (!results) return;
    if (!data || data.ok === false) {
      results.innerHTML = '<p style="color:#a00">Chyba: ' + esc((data && data.message) || 'neznámá') + '</p>';
      setMeterSpool(null);
      lastSpoolsList = [];
      syncReturnQ();
      return;
    }
    var list = data.spools || [];
    lastSpoolsList = list.slice();
    if (list.length === 0) {
      results.innerHTML = '<p><strong>Žádná shoda</strong> pro «' + esc(data.query) + '».</p>';
      setMeterSpool(null);
      syncReturnQ();
      return;
    }
    var rows = list.map(function (p) { return rowHtml(p, list.length === 1); }).join('');
    var h = '<h2 class="work-result-h2" style="font-size:1.1rem;margin:.35rem 0 .5rem">Výsledek (' + list.length + ')</h2>' + tableShell(rows);
    if (list.length > 1) {
      h += '<p id="work-pick-hint" class="work-pick-hint" style="margin:.75rem 0 .5rem;color:#444">Vyberte správnou cívku <strong>kliknutím na řádek</strong> (záznam a karta pod tabulkou).</p>';
      setMeterSpool(null);
    } else {
      setMeterSpool(list[0]);
    }
    results.innerHTML = h;
    if (list.length === 1) {
      loadKarta(list[0].id);
      highlightSpoolRow(list[0].id);
    }
    syncReturnQ();
  }
  function runFetch(q, force) {
    q = (q || '').trim();
    if (q.length < 1) { if (hint) hint.textContent = ''; if (results) results.innerHTML = ''; setMeterSpool(null); lastSpoolsList = []; syncReturnQ(); return; }
    var my = ++seq;
    if (hint) hint.textContent = 'Načítám…';
    var u = new URL(lookupUrl, window.location.origin);
    u.searchParams.set('q', q);
    fetch(u.toString(), { credentials: 'same-origin', headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' } })
      .then(function (r) {
        var ct = (r.headers.get('content-type') || '');
        if (ct.indexOf('application/json') === -1) { return r.text().then(function () { throw new Error('not json'); }); }
        return r.json();
      })
      .then(function (data) {
        if (my !== seq) return;
        if (data && data.ok === false) {
          if (hint) hint.textContent = (data.message) ? ('Chyba: ' + data.message) : 'Chyba hledání.';
          renderFromApi(data);
          return;
        }
        if (hint) {
          if (!data || data.count === 0) hint.textContent = 'Žádná shoda — podle zadaného saře.';
          else if (data.count === 1) hint.textContent = 'Jedna shoda — vyplňte Záznam pod tabulkou a stiskněte Zapsat.';
          else hint.textContent = 'Nalezeno ' + data.count + ' cívek — vyberte řádek.';
        }
        if (window.history && window.history.replaceState) {
          var url = new URL(window.location.href);
          url.searchParams.set('q', q);
          window.history.replaceState(null, '', url.toString());
        }
        renderFromApi(data);
      })
      .catch(function (e) {
        if (my !== seq) return;
        if (hint) hint.textContent = 'Chyba spojení — použije se odeslání stránky.';
        if (form) form.submit();
      });
  }
  function onQueryChange() {
    var q = (qIn && qIn.value) ? qIn.value.trim() : '';
    if (q.length < 1) { if (hint) hint.textContent = ''; clearTimeout(t); if (results) results.innerHTML = ''; setMeterSpool(null); lastSpoolsList = []; return; }
    clearTimeout(t);
    t = setTimeout(function () {
      var qNow = (qIn && qIn.value) ? String(qIn.value).trim() : '';
      if (qNow.length < 1) { if (hint) hint.textContent = ''; if (results) results.innerHTML = ''; setMeterSpool(null); lastSpoolsList = []; syncReturnQ(); return; }
      runFetch(qNow, false);
    }, debounceMs);
  }
  if (form && qIn) {
    form.addEventListener('submit', function (e) {
      e.preventDefault();
      runFetch(qIn.value, true);
    });
    qIn.addEventListener('input', function () { syncReturnQ(); onQueryChange(); });
    qIn.addEventListener('paste', function () { setTimeout(function () { syncReturnQ(); onQueryChange(); }, 0); });
  }
  if (results) { bindSpoolTableClicks(); }
  var wjson = document.getElementById('work-spools-json');
  if (wjson && wjson.textContent) {
    try {
      var arr = JSON.parse(wjson.textContent);
      if (Array.isArray(arr)) {
        lastSpoolsList = arr;
        if (arr.length === 1) setMeterSpool(arr[0]);
        else setMeterSpool(null);
      }
    } catch (err) {}
  }
  if (workTopArea && !workTopArea.classList.contains('is-search-collapsed') && expandSearchBtn) {
    expandSearchBtn.setAttribute('aria-expanded', 'true');
  }
  syncReturnQ();
  (function initRecordBtn() {
    var sid = document.getElementById('work-record-spool-id');
    setRecordSpoolId(sid && sid.value ? sid.value : null);
  })();

  /** Eskalace formátů jen pro sken „Číslo saře“ (žádné QR / DataMatrix).
   *  Kladné ms (~900): úzký seznam čárovek → po této době automaticky rozšíří o EAN/UPC/Codabar.
   *  Infinity: bez eskalace, pořád jen úzký seznam (= snadný návrat při problému).
   *  0: od začátku rovnou rozšířené lineární kódy (bez čekání v 1. fázi). */
  var WORK_SARE_SCAN_PHASE2_AFTER_MS = 900;

  var scanBtn = document.getElementById('work-scan-btn');
  var scanRecordBtn = document.getElementById('work-record-scan-btn');
  var scanOverlay = document.getElementById('work-scan-overlay');
  var scanVideoWrap = document.getElementById('work-scan-video-wrap');
  var scanVideo = document.getElementById('work-scan-video');
  var scanCancel = document.getElementById('work-scan-cancel');
  var scanOverlayText = document.getElementById('work-scan-overlay-text');
  var scanRaf = null;
  var scanStream = null;
  var scanCropCanvas = null;
  /** 'sare' = pole vyhledávání; 'record' = Běžný stav + Objekt / zakázka */
  var scanMode = 'sare';
  function syncScanOverlayLayout() {
    if (!scanOverlay || !scanVideoWrap) return;
    var sare = scanMode === 'sare';
    scanOverlay.classList.toggle('work-scan-overlay--sare-strip', sare);
    scanVideoWrap.classList.toggle('work-scan-video-wrap--sare-strip', sare);
  }
  function setScanOverlayCopy() {
    if (!scanOverlayText) return;
    if (scanMode === 'sare') {
      var tierNote = '';
      if (Number.isFinite(WORK_SARE_SCAN_PHASE2_AFTER_MS) && WORK_SARE_SCAN_PHASE2_AFTER_MS === 0) {
        tierNote = ' Používají se hned všechny podporované čárové kódy (bez QR/DM).';
      } else if (Number.isFinite(WORK_SARE_SCAN_PHASE2_AFTER_MS) && WORK_SARE_SCAN_PHASE2_AFTER_MS > 0 && WORK_SARE_SCAN_PHASE2_AFTER_MS < 1e12) {
        tierNote = ' Po ~' + Math.round(WORK_SARE_SCAN_PHASE2_AFTER_MS / 50) * 50 + ' ms sama přejde také na EAN/UPC apod. (bez QR/DM).';
      } else {
        tierNote = ' Pouze úzký seznam čárových typů — bez automatického rozšíření.';
      }
      scanOverlayText.textContent = 'Sken čísla saře: úzký pruh nad čárovým kódem. Po přečtení zkontrolujte pole;' +
        tierNote +
        ' hledání může spustit pauza nebo Hledat.';
    } else {
      scanOverlayText.textContent = 'Sken do záznamu: samostatné číslo = metráž (m). Dva údaje: metráž;zakázka nebo oddělovač | nebo tabulátor (např. 7843;Z123).';
    }
  }
  function stopBarcodeScan() {
    if (scanRaf) { cancelAnimationFrame(scanRaf); scanRaf = null; }
    if (scanStream) {
      scanStream.getTracks().forEach(function (t) { t.stop(); });
      scanStream = null;
    }
    if (scanVideo) scanVideo.srcObject = null;
    if (scanOverlay) {
      scanOverlay.hidden = true;
      scanOverlay.classList.remove('work-scan-overlay--sare-strip');
    }
    if (scanVideoWrap) scanVideoWrap.classList.remove('work-scan-video-wrap--sare-strip');
  }
  function focusSareForHardwareScan() {
    if (qIn) {
      qIn.focus();
      try { qIn.select(); } catch (e) {}
    }
    if (hint) hint.textContent = 'Naskenujte kód do pole Číslo saře (hw čtečka) nebo zadejte ručně.';
  }
  function focusRecordForHardwareScan() {
    if (meterIn) {
      meterIn.focus();
      try { meterIn.select(); } catch (e) {}
    } else if (projectIn) {
      projectIn.focus();
    }
    if (hint) {
      hint.textContent = 'Čtečka: jedno číslo → Běžný stav. Formát dva údaje: 7843;zakázka nebo 7843|zakázka nebo tab. Jinak zadejte ručně.';
    }
  }
  /** Pro sken Číslo saře: na štítku bývá kromě evid. čísla i délka kabelu (vždy jen ≤4 číslice podle výroby).
   *  Takové čistě číselné hodnoty 1–4 znaků jako saři nebereme (přeskočíme a zkusíme jiného kandidáta / další frame). */
  function sareDecodedLooksLikeCableLengthMeters(raw) {
    var s = String(raw == null ? '' : raw).trim();
    return /^\d{1,4}$/.test(s);
  }
  /** Z výsledku BarcodeDetector vybere první řetězec, který není pravděpodobně jen délka (m). */
  function pickSareBarcodeFromDetections(codes) {
    if (!codes || !codes.length) return '';
    for (var i = 0; i < codes.length; i++) {
      var rv = codes[i].rawValue;
      if (rv == null || rv === '') continue;
      var v = String(rv).trim();
      if (!v.length) continue;
      if (!sareDecodedLooksLikeCableLengthMeters(v)) return v;
    }
    return '';
  }

  function onBarcodeValueSare(val) {
    if (!val || !qIn) return;
    qIn.value = String(val).trim();
    syncReturnQ();
    if (!qIn.value.length) return;
    qIn.focus();
    try { qIn.select(); } catch (eSel) {}
    try {
      qIn.dispatchEvent(new Event('input', { bubbles: true }));
    } catch (eIn) {
      onQueryChange();
    }
    if (hint) hint.textContent = 'Údaje z kamery zkontrolujte v poli Číslo saře — po opravě počkejte na hledání nebo stiskněte Hledat.';
  }
  /** Oddělovač tab, ; nebo | — první výskyt. Čisté číslo = metráž, jinak zakázka; dva segmenty dle pravidel. */
  function applyRecordScan(val) {
    if (!val) return;
    var raw = String(val).trim();
    if (!raw) return;
    var d = -1;
    if (raw.indexOf('\t') >= 0) d = raw.indexOf('\t');
    else if (raw.indexOf(';') >= 0) d = raw.indexOf(';');
    else if (raw.indexOf('|') >= 0) d = raw.indexOf('|');
    if (d < 0) {
      if (/^\d+$/.test(raw)) {
        if (meterIn) meterIn.value = raw;
        if (projectIn) projectIn.value = '';
      } else {
        if (projectIn) projectIn.value = raw;
      }
    } else {
      var a = raw.slice(0, d).trim();
      var b = raw.slice(d + 1).trim();
      if (/^\d+$/.test(a)) {
        if (meterIn) meterIn.value = a;
        if (projectIn) projectIn.value = b;
      } else if (/^\d+$/.test(b)) {
        if (meterIn) meterIn.value = b;
        if (projectIn) projectIn.value = a;
      } else {
        if (projectIn) projectIn.value = raw;
      }
    }
    updateMeter();
  }
  function onScanDecoded(str) {
    var v = String(str).trim();
    if (!v.length) return;
    var mode = scanMode;
    stopBarcodeScan();
    if (mode === 'sare') onBarcodeValueSare(v);
    else applyRecordScan(v);
  }
  function startBarcodeScan() {
    if (scanMode === 'sare') {
      if (!scanOverlay || !scanVideo) { focusSareForHardwareScan(); return; }
    } else {
      if (!scanOverlay || !scanVideo) { focusRecordForHardwareScan(); return; }
    }
    setScanOverlayCopy();
    syncScanOverlayLayout();
    scanOverlay.hidden = false;
    navigator.mediaDevices.getUserMedia({ video: { facingMode: { ideal: 'environment' } } })
      .then(function (stream) {
        scanStream = stream;
        scanVideo.srcObject = stream;
        return scanVideo.play();
      })
      .then(function () {
        function makeRecordDetector() {
          return new window.BarcodeDetector({ formats: ['code_128', 'code_39', 'code_93', 'ean_13', 'qr_code', 'itf', 'data_matrix'] });
        }
        /** QR a Data Matrix pro „Číslo saře“ vyloučené – jen čárové kódy. */
        function makeSareBarcodeDetector(wideTier) {
          var narrowLin = ['code_128', 'code_39', 'code_93', 'itf'];
          var extraLin = ['ean_13', 'ean_8', 'upc_a', 'upc_e', 'codabar'];
          var fmts = wideTier ? narrowLin.concat(extraLin) : narrowLin.slice();
          return new window.BarcodeDetector({ formats: fmts });
        }
        /** Fáze 0 = úzké lineární; fáze 1 = rozšířená lineární sada */
        var sareFmtTierStartedWide = WORK_SARE_SCAN_PHASE2_AFTER_MS <= 0;
        var sareFmtTier = sareFmtTierStartedWide ? 1 : 0;
        var sareScanOpenedAtMs = scanMode === 'sare' ? performance.now() : 0;
        var detector = scanMode === 'sare' ? makeSareBarcodeDetector(sareFmtTierStartedWide) : makeRecordDetector();
        function maybeEscalateSareFormats() {
          if (scanMode !== 'sare' || sareFmtTier !== 0) return;
          if (!Number.isFinite(WORK_SARE_SCAN_PHASE2_AFTER_MS) || WORK_SARE_SCAN_PHASE2_AFTER_MS <= 0) {
            return;
          }
          if (performance.now() - sareScanOpenedAtMs < WORK_SARE_SCAN_PHASE2_AFTER_MS) return;
          sareFmtTier = 1;
          detector = makeSareBarcodeDetector(true);
        }
        function getCropCanvasEl() {
          if (!scanCropCanvas) scanCropCanvas = document.createElement('canvas');
          return scanCropCanvas;
        }
        /** Středový horizontální pás kamery → méně falešných čtení z okolí; viz CSS pruh „sare“. */
        var sareStripFrac = 0.26;
        function tick() {
          if (!scanVideo || scanStream === null) return;
          if (scanVideo.readyState < 2) {
            scanRaf = requestAnimationFrame(tick);
            return;
          }
          function decodeFrom(src) {
            detector.detect(src).then(function (codes) {
              var val = '';
              if (scanMode === 'sare') val = pickSareBarcodeFromDetections(codes);
              else if (codes && codes.length && codes[0].rawValue) val = String(codes[0].rawValue).trim();
              if (val.length) {
                onScanDecoded(val);
                return;
              }
              scanRaf = requestAnimationFrame(tick);
            }).catch(function () { scanRaf = requestAnimationFrame(tick); });
          }
          if (scanMode === 'sare') {
            maybeEscalateSareFormats();
            var vw = scanVideo.videoWidth;
            var vh = scanVideo.videoHeight;
            if (vw < 2 || vh < 2) {
              scanRaf = requestAnimationFrame(tick);
              return;
            }
            var sh = Math.max(12, Math.round(vh * sareStripFrac));
            var sy = Math.round((vh - sh) / 2);
            var cw = Math.min(720, vw);
            var ch = Math.max(12, Math.round(sh * (cw / vw)));
            var canv = getCropCanvasEl();
            if (canv.width !== cw || canv.height !== ch) {
              canv.width = cw;
              canv.height = ch;
            }
            var ctx = canv.getContext('2d');
            ctx.drawImage(scanVideo, 0, sy, vw, sh, 0, 0, cw, ch);
            decodeFrom(canv);
          } else {
            decodeFrom(scanVideo);
          }
        }
        scanRaf = requestAnimationFrame(tick);
      })
      .catch(function () {
        stopBarcodeScan();
        if (scanMode === 'sare') {
          focusSareForHardwareScan();
          if (hint) hint.textContent = 'Kamera nedostupná — použijte čtečku do pole Číslo saře nebo zadejte ručně.';
        } else {
          focusRecordForHardwareScan();
          if (hint) hint.textContent = 'Kamera nedostupná — použijte čtečku (formát 7843;zakázka) nebo zadejte ručně.';
        }
      });
  }
  function wireScanButton(btn) {
    if (!btn) return;
    btn.addEventListener('click', function () {
      scanMode = btn.getAttribute('data-work-scan-mode') === 'record' ? 'record' : 'sare';
      if (typeof window.BarcodeDetector !== 'undefined') startBarcodeScan();
      else if (scanMode === 'sare') focusSareForHardwareScan();
      else focusRecordForHardwareScan();
    });
  }
  wireScanButton(scanBtn);
  wireScanButton(scanRecordBtn);
  if (scanCancel) scanCancel.addEventListener('click', function () { stopBarcodeScan(); });
  document.addEventListener('keydown', function (ev) {
    if (ev.key === 'Escape' && scanOverlay && !scanOverlay.hidden) { ev.preventDefault(); stopBarcodeScan(); }
  });
})();
    </script>

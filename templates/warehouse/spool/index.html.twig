      if (sareOverlayReadMode === 'barcode') return;
      sareOverlayReadMode = 'barcode';
      workScanClientLog({ event: 'sare_mode', ui: 'sare', sareMode: 'barcode' });
      syncSareOverlayModeButtons();
      setScanOverlayCopy();
      if (sareScanLive && typeof sareScanLive.rebuild === 'function') sareScanLive.rebuild();
      window.setTimeout(function () {
        if (scanMode === 'sare' && sareScanLive && sareScanLive.rebuild) sareScanLive.rebuild();
      }, 0);
    });
    sareModeNumberBtn.addEventListener('click', function (ev) {
      ev.preventDefault();
      if (sareOverlayReadMode === 'number') return;
      sareOverlayReadMode = 'number';
      workScanClientLog({ event: 'sare_mode', ui: 'sare', sareMode: 'number' });
      syncSareOverlayModeButtons();
      setScanOverlayCopy();
      if (sareScanLive && typeof sareScanLive.rebuild === 'function') sareScanLive.rebuild();
      window.setTimeout(function () {
        if (scanMode === 'sare' && sareScanLive && sareScanLive.rebuild) sareScanLive.rebuild();
      }, 0);
    });
  }
  wireSareOverlayModeToggle();
  function wireScanButton(btn) {
    if (!btn) return;
    btn.addEventListener('click', function () {

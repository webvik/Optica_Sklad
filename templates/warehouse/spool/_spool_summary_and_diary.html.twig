{# Sdílené s karta cívky (show) a pracovní stránkou. Proměnná: spool #}
<style>
  .spool-card-summary { line-height: 1.55; }
  .spool-card-summary__zbyva { font-size: 1.45em; font-weight: 600; font-variant-numeric: tabular-nums; letter-spacing: -0.02em; }
  .spool-cable-end-suffix { font-weight: 400; font-variant-numeric: tabular-nums; color: #555; font-size: 0.92em; }
  .spool-correction-box {
      margin: 0.65rem 0 0;
      padding: 0.65rem 0.75rem;
      border: 1px solid #e0c080;
      border-radius: 6px;
      background: #fffbf0;
      max-width: 36rem;
  }
  .spool-correction-box__note-read {
      margin: 0.35rem 0 0;
      white-space: pre-wrap;
      font-size: 0.92rem;
      line-height: 1.45;
      color: #333;
  }
  .spool-correction-form textarea {
      width: 100%;
      max-width: 100%;
      min-height: 4.5rem;
      box-sizing: border-box;
      font: inherit;
      margin-top: 0.35rem;
  }
  .spool-correction-form__actions { margin-top: 0.5rem; }
  .spool-correction-form__expand[hidden] { display: none !important; }
  .spool-correction-history {
      margin: 0.65rem 0 0;
      max-width: 36rem;
      font-size: 0.9rem;
  }
  .spool-correction-history > summary {
      cursor: pointer;
      color: #555;
      padding: 0.35rem 0;
  }
  .spool-correction-history__body {
      margin: 0.35rem 0 0;
      padding: 0.55rem 0.65rem;
      border: 1px solid #ddd;
      border-radius: 6px;
      background: #f5f5f5;
  }
  .spool-correction-form__actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      align-items: center;
  }
  .spool-diary-row--editable { cursor: pointer; }
  .spool-diary-row--editable:hover { background: rgba(0,0,0,0.04); }
  .spool-diary-table__edit {
      width: 4.2rem;
      max-width: 4.5rem;
      padding: 0.35rem 0.3rem;
      text-align: center;
      white-space: nowrap;
      font-size: 0.88rem;
  }
  .spool-diary-table__edit a {
      text-decoration: none;
      font-weight: 600;
  }
</style>
{% set diaryReturnUrl = diaryReturnUrl|default(path('warehouse_spool_show', {id: spool.id})) %}
{% set diaryCanEdit = spool_diary_show_edit_column(spool) %}
<div class="spool-card-summary">
    <p style="margin: 0 0 0.5rem;">
        <strong>zbývá:</strong>
        {% if spool.currentRemainingM is not null %}
            <span class="spool-card-summary__zbyva">{{ spool.currentRemainingM }}</span> m{% include 'warehouse/spool/_spool_cable_end_suffix.html.twig' %}
        {% else %}
            —
        {% endif %}
    </p>
    <p style="margin: 0 0 0.5rem;">
        {% if spool.family %}
            <strong>řada:</strong> {{ spool.family }} ·
        {% endif %}
        <strong>vláken:</strong> {{ spool.effectiveFiberCount }} ·
        <strong>průměr:</strong> {% set _d = spool.effectiveDiameterMm %}{% if _d is not null and _d != '' %}{{ _d }} mm{% else %}—{% endif %}
    </p>
    <p style="margin: 0 0 0.5rem;">
        <strong>poslední m:</strong> {% if spool.lastVisibleM is not null %}{{ spool.lastVisibleM }} m{% else %}—{% endif %},
        <strong>PS:</strong> {% if spool.initialVisibleM is not null %}{{ spool.initialVisibleM }}{% else %}—{% endif %},
        <strong>Délka:</strong> {{ spool.totalLengthM }} m
    </p>
    <p style="margin: 0 0 0.5rem;">
        <strong>směr čtení metru:</strong> {{ spool.meterSign is null ? '—' : (spool.meterSign == 1 ? 'rostoucí' : 'klesající') }}<br>
        <strong>Stav:</strong> {% if spool.status.value == 'in_stock' %}na skladě{% elseif spool.status.value == 'received_sealed' %}nerozbaleno{% elseif spool.status.value == 'transferred' %}předáno{% elseif spool.status.value == 'written_off' %}vyřazeno{% else %}{{ spool.status.value }}{% endif %}
    </p>
    {% if spool.needsCorrection and spool.correctionNote and not is_granted(constant('App\\Security\\WarehouseRole::CORRECTION_FLAG_MANAGER')) %}
        <div class="spool-correction-box" role="note">
            <strong style="color:#a60;">Ke korekci</strong>
            <div class="spool-correction-box__note-read">{{ spool.correctionNote }}</div>
        </div>
    {% elseif spool.needsCorrection and not is_granted(constant('App\\Security\\WarehouseRole::CORRECTION_FLAG_MANAGER')) %}
        <p style="margin:0.35rem 0 0;color:#a60;"><strong>Ke korekci</strong></p>
    {% endif %}
    {% if spool.correctionResolvedAt %}
        <details class="spool-correction-history">
            <summary>Korekce provedena ({{ spool.correctionResolvedAt|date('d.m.Y H:i') }})</summary>
            <div class="spool-correction-history__body">
                {% if spool.correctionResolvedNote %}
                    <div class="spool-correction-box__note-read">{{ spool.correctionResolvedNote }}</div>
                {% else %}
                    <span style="color:#666;">Bez uložené poznámky.</span>
                {% endif %}
            </div>
        </details>
    {% endif %}
    {% if is_granted(constant('App\\Security\\WarehouseRole::CORRECTION_FLAG_MANAGER')) %}
        <form method="post" action="{{ path('warehouse_spool_needs_correction', {id: spool.id}) }}" class="spool-correction-form spool-correction-box">
            <input type="hidden" name="_token" value="{{ csrf_token('spool_needs_correction_' ~ spool.id) }}">
            <label style="display:flex;align-items:flex-start;gap:0.4rem;cursor:pointer;font-size:0.95rem;">
                <input type="checkbox" name="needsCorrection" value="1" class="js-spool-needs-correction-cb"{% if spool.needsCorrection %} checked{% endif %}>
                <span><strong>Označit ke korekci</strong></span>
            </label>
            <div class="spool-correction-form__expand js-spool-correction-details"{% if not spool.needsCorrection %} hidden{% endif %}>
                <label for="spool-correction-note" style="display:block;margin-top:0.5rem;font-size:0.9rem;">
                    Poznámka (co je špatně / co opravit)
                    <textarea id="spool-correction-note" name="correctionNote" rows="4" placeholder="např. nesedí zůstatek s deníkem, chybné m u zafuku…">{{ spool.correctionNote|default('') }}</textarea>
                </label>
                <p style="margin:0.35rem 0 0;font-size:0.82rem;color:#555;">Po opravě dat v deníku klikněte <strong>Korekce provedena</strong> — cívka zmizí z filtru, poznámka zůstane v historii níže.</p>
                <div class="spool-correction-form__actions">
                    <button type="submit" name="correctionAction" value="save">Uložit</button>
                    {% if spool.needsCorrection %}
                        <button type="submit" name="correctionAction" value="resolve" class="ui-btn-secondary">Korekce provedena</button>
                    {% endif %}
                </div>
            </div>
        </form>
        <script>
        (function () {
            var cb = document.querySelector('.js-spool-needs-correction-cb');
            var panel = document.querySelector('.js-spool-correction-details');
            if (!cb || !panel) return;
            function sync() { panel.hidden = !cb.checked; }
            cb.addEventListener('change', sync);
            sync();
        })();
        </script>
    {% endif %}
</div>
<h2>Deník</h2>
<div class="table-scroll table-scroll--wide">
<table class="spool-diary-table{% if diaryCanEdit %} spool-diary-table--editable{% endif %}">
    <thead>
        <tr><th>m (čtení)</th><th>Délka (m)</th><th>Zakázka</th><th>Kdy</th><th>Technik</th><th>Pozn.</th>{% if diaryCanEdit %}<th class="spool-diary-table__edit"></th>{% endif %}</tr>
    </thead>
    <tbody>
    {% for e in spool.eventsSortedByVisibleM %}
        {% set diary = spool_diary_cells(e) %}
        {% set canEditEvent = spool_event_user_can_edit(e) %}
        {% set eventEditUrl = path('warehouse_spool_event_edit', {id: spool.id, eventId: e.id, return: diaryReturnUrl}) %}
        <tr class="spool-diary-row{% if canEditEvent %} spool-diary-row--editable js-spool-diary-row{% endif %}"
            {% if canEditEvent %}data-edit-url="{{ eventEditUrl|e('html_attr') }}" tabindex="0" title="Dvojklik nebo Upravit — otevřít úpravu záznamu"{% endif %}>
            <td>{{ diary.visibleM is not null ? diary.visibleM : '—' }}</td>
            <td>{{ diary.usedMeters is not null ? diary.usedMeters : '—' }}</td>
            <td>{{ diary.projectLabel|default('—') }}</td>
            <td>{{ e.occurredAt|date('Y-m-d') }}</td>
            <td class="spool-diary-table__author" title="{{ spool_event_author(e) }}">{{ spool_event_author(e) }}</td>
            <td class="spool-diary-table__note" title="{{ e.note|default('') }}">{{ e.note|default('') }}</td>
            {% if canEditEvent %}
            <td class="spool-diary-table__edit"><a href="{{ eventEditUrl }}" class="js-spool-diary-edit-link">Upravit</a></td>
            {% elseif diaryCanEdit %}
            <td class="spool-diary-table__edit"></td>
            {% endif %}
        </tr>
    {% else %}
        <tr><td colspan="{{ diaryCanEdit ? 7 : 6 }}">Žádné záznamy</td></tr>
    {% endfor %}
    </tbody>
</table>
</div>
{% if diaryCanEdit %}
<script>
(function () {
  var rows = document.querySelectorAll('tr.js-spool-diary-row[data-edit-url]');
  for (var i = 0; i < rows.length; i++) {
    (function (row) {
      var url = row.getAttribute('data-edit-url');
      if (!url) return;
      row.addEventListener('dblclick', function (ev) {
        if (ev.target && ev.target.closest && ev.target.closest('a.js-spool-diary-edit-link')) return;
        window.location.href = url;
      });
      row.addEventListener('keydown', function (ev) {
        if (ev.key === 'Enter') {
          ev.preventDefault();
          window.location.href = url;
        }
      });
    })(rows[i]);
  }
})();
</script>
{% endif %}

{# Hned pod nadpisem karty: Cívka … / Karta cívky: … #}
<p class="spool-card-typ" style="margin: 0 0 0.6rem; line-height: 1.45;">
    <strong>Typ:</strong>
    {% if spool.cableType %}
        {{ spool.cableType.name }} ({{ spool.cableType.code }})
    {% else %}
        <span style="color:#8a6d00;">— nerozpoznán</span>
        {% if is_granted('ROLE_SKLAD_EDIT') %}
            <a href="{{ path('warehouse_spool_show', { id: spool.id, upravit: 1 }) }}#doplnit-typ" style="margin-left:0.35rem;">doplnit</a>
        {% endif %}
    {% endif %}
</p>

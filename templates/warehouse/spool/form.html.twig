    if (j && j.matched) return;

    var cand = j && j.candidates ? j.candidates : [];
    var hintLine = formatOcrHintLine(j && j.hints);
    var hasCand = !!(cand && cand.length);

    if (ocrSugSub) {
      if (hasCand && hintLine) {
        ocrSugSub.textContent =
          hintLine + ' Vyberte typ níže nebo otevřete nový typ (přenos textu).';
      } else if (hasCand) {
        ocrSugSub.textContent =
          'Vyberte nejlepší typ ze seznamu nebo použijte tlačítko nového typu.';
      } else if (hintLine) {
        ocrSugSub.textContent =
          hintLine + ' Žádná dostatečná shoda — upravte text a klepněte znovu, nebo nový typ níže.';
      } else {
        ocrSugSub.textContent =
          'Žádné blízké typy — upravte text a porovnejte znovu, nebo použijte nový typ níže.';
      }
    }

    ocrNewTypeStashBtn.hidden = false;
    ocrSugPanel.removeAttribute('hidden');

    for (var ci = 0; ci < cand.length; ci++) {
      var row = cand[ci];
      var ct = row && row.cableType ? row.cableType : null;
      if (!ct || ct.id == null) continue;
      var b = document.createElement('button');
      b.type = 'button';
      b.className = 'spool-cable-ocr-sug-pick';
      var score = row.score != null ? String(row.score) : '?';
      b.textContent =
        score + ' — ' + String(ct.code || '') + ' — ' + String(ct.name || '');
      (function pickCt(picked) {
        b.addEventListener('click', function () {
          stopCableOcr();
          terminateTessLocal();
          applyCableFromMatch(picked);
        });
      })(ct);
      ocrSugList.appendChild(b);
    }
  }

  function terminateTessLocal() {
    tessWorkerPromise = null;
    var w = tessWorker;
    tessWorker = null;
    if (!w) return;
    try { Promise.resolve(w.terminate()).catch(function () {}); } catch (eT) {}
  }

  function stopCableOcr() {
    ocrBusy = false;
    setCableCaptureUiBusy(false);
    setCableMatchUiBusy(false);
    clearCableOcrSuggestions();
    setCableOcrEditorVisible(false);
    if (scanRaf != null) {
      try { window.cancelAnimationFrame(scanRaf); } catch (eRaf) {}
      try { window.clearTimeout(scanRaf); } catch (eTo) {}
      scanRaf = null;
    }
    if (scanStream) {
      scanStream.getTracks().forEach(function (t) { t.stop(); });
      scanStream = null;
    }

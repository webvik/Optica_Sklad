                      : 'Text je krátký — doplňte ručně v poli níže nebo zkuste OCR znovu, pak „Porovnat s katalogem“.';
                }
              }
            }
            endOcrSnapCycle();
          })
          .catch(function () {
            if (scanStream === null) {
              endOcrSnapCycle();
              return;
            }
            if (ocrTextHint) {
              ocrTextHint.textContent =
                'OCR selhal — zkuste znovu (držte řádek v pruhu, dobré světlo) nebo zadejte ručně.';
            }
            endOcrSnapCycle();
          });
      })
      .catch(function () {
        endOcrSnapCycle();
      });
  }

  function postMatch(text, cbOk, cbErr) {
    fetch(cfg.matchUrl, {
      method: 'POST',
      credentials: 'same-origin',
      headers: {
        'Content-Type': 'application/json',
        Accept: 'application/json',
        'X-Requested-With': 'XMLHttpRequest',
      },
      body: JSON.stringify({ text: text, csrf: cfg.csrfMatch }),
    })
      .then(function (r) {
        return r.json();
      })
      .then(function (j) {
        if (!j.ok) cbErr(j);
        else cbOk(j);
      })
      .catch(function () {
        cbErr({});
      });
  }

  function applyCableFromMatch(ct) {
    if (!ct || ct.id == null) return false;
    if (famSelOcr) {
      famSelOcr.removeAttribute('hidden');
      famSelOcr.value = '';
      try {
        famSelOcr.dispatchEvent(new Event('change', { bubbles: true }));
      } catch (eCf) {}
    }
    cableSelOcr.value = String(ct.id);
    try {
      cableSelOcr.dispatchEvent(new Event('change', { bubbles: true }));
    } catch (eCc) {}
    try {
      cableSelOcr.dispatchEvent(new Event('input', { bubbles: true }));
    } catch (eCi) {}
    return true;
  }

  function submitCableDraftForMatch() {
    if (!cableReady || !cableTextDraft) return;
    if (ocrBusy || cableMatchBusy) return;
    hideCableChoiceModal();
    var text = normalizeDraftText(cableTextDraft.value);
    if (!text.length) {
      window.alert(
        'Pole „Text ze štítku“ je prázdné — použijte „Přečíst řádek (OCR)“ nebo zadejte text ručně, pak zkuste porovnat znovu.'
      );
      return;
    }
    if (text.length < MIN_CHARS) {
      if (
        !window.confirm(
          'Text má méně než ' +
            MIN_CHARS +
            ' znaků — výsledek párování může být nespolehlivý. Pokračovat v porovnání?'
        )
      ) {
        return;
      }
    }
    setCableMatchUiBusy(true);
    if (cableCaptureBtn) cableCaptureBtn.disabled = true;
    postMatch(
      text,
      function (j) {
        setCableMatchUiBusy(false);
        if (cableCaptureBtn && !overlay.hidden && scanStream) cableCaptureBtn.disabled = false;
        if (ocrTextHint) {
          ocrTextHint.textContent =
            'Vyberte v dialogu: typ z katalogu, nový typ, nebo zpět na úpravu štítku.';
        }
        showCableChoiceModal(j);
      },
      function () {
        setCableMatchUiBusy(false);
        if (cableCaptureBtn && !overlay.hidden && scanStream) cableCaptureBtn.disabled = false;
        window.alert('Službu porovnání se nepodařilo zavolat (relace/síť).');
      }

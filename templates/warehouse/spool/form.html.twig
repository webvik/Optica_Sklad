{% extends 'base.html.twig' %}
{% block title %}{{ title }}{% endblock %}
{% block stylesheets %}
    {{ parent() }}
    {% include '_styles_spool_form_layout.html.twig' %}
    <style>
        .sk-karta-queue-banner {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            gap: 0.5rem 0.75rem;
            margin: 0 0 0.85rem;
            padding: 0.55rem 0.7rem;
            border: 1px solid #9ec4e6;
            border-radius: 8px;
            background: #edf5fc;
            max-width: 40rem;
        }
        .sk-karta-queue-banner__text { margin: 0; font-size: 0.92rem; }
        .sk-karta-queue-banner__link { font-size: 0.88rem; }
        #spool-form-scan-overlay[hidden] { display: none !important; }
        #spool-form-scan-overlay {
            position: fixed;
            inset: 0;
            z-index: 9999;
            background: rgba(0, 0, 0, .75);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 1rem;
            padding: 1rem;
            box-sizing: border-box;
        }
        /* Stejné proporce jako sken vyhledávání (Úzký pruh). JS: sareStripFrac 0.17 — měnit společně s work-scan u spool/index */
        #spool-form-scan-video-wrap {
            flex-shrink: 0;
            max-width: min(100%, 640px);
            box-sizing: border-box;
        }
        .spool-form-scan-overlay--strip #spool-form-scan-video-wrap.spool-form-scan-video-wrap--strip {
            width: min(100%, 34rem);
            height: clamp(4.25rem, 11.5vh, 6.25rem);
            overflow: hidden;
            border-radius: 8px;
            border: 2px solid rgba(85, 220, 175, 0.9);
            box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.35);
            background: #111;
            position: relative;
        }
        .spool-form-scan-overlay--strip #spool-form-scan-video-wrap.spool-form-scan-video-wrap--strip::after {
            content: '';
            position: absolute;
            inset: 0;
            pointer-events: none;
            border: 1px solid rgba(255, 255, 255, 0.08);
            box-sizing: border-box;
            border-radius: inherit;
            z-index: 1;
        }
        .spool-form-scan-overlay--strip #spool-form-scan-video-wrap.spool-form-scan-video-wrap--strip #spool-form-scan-video {
            display: block;
            width: 100%;
            height: 100%;
            max-height: none;
            border-radius: 0;
            object-fit: cover;
            object-position: center center;
        }
        #spool-cable-ocr-overlay[hidden] { display: none !important; }
        #spool-cable-ocr-overlay {
            position: fixed; inset: 0; z-index: 10000;
            background: rgba(0, 0, 0, 0.76);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 0.85rem;
            padding: 1rem;
            box-sizing: border-box;
        }
        #spool-cable-ocr-overlay-text {
            color: #fff;
            margin: 0;
            text-align: center;
            max-width: 38rem;
            font-size: 0.93rem;
            line-height: 1.42;
            padding: 0 0.35rem;
        }
        #spool-cable-ocr-video-wrap {
            width: min(100%, 22.5rem);
            height: clamp(3.6rem, 9vh, 5.2rem);
            overflow: hidden;
            border-radius: 8px;
            border: 2px solid rgba(95, 200, 255, 0.85);
            background: #111;
            flex-shrink: 0;
            box-sizing: border-box;
        }
        #spool-cable-ocr-capture-row {
            display: flex;
            flex-wrap: wrap;
            gap: 0.65rem;
            align-items: center;
            justify-content: center;
            max-width: min(100%, 24rem);
        }
        #spool-cable-ocr-capture {
            flex: 1 1 auto;
            min-width: min(100%, 12rem);
            min-height: 2.65rem;
            box-sizing: border-box;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 0.5rem 1rem;
            font: inherit;
            font-size: 1rem;
            font-weight: 600;
            line-height: 1.15;
            color: #1a1a1a;
            cursor: pointer;
            border-radius: 6px;
            border: 2px solid rgba(95, 200, 255, 0.95);
            background: rgba(200, 240, 255, 0.98);
            -webkit-tap-highlight-color: rgba(95, 200, 255, 0.25);
        }
        #spool-cable-ocr-capture:hover:not(:disabled) {
            background: rgba(170, 230, 255, 1);
            border-color: rgba(130, 220, 255, 1);
        }
        #spool-cable-ocr-capture:disabled {
            opacity: 0.55;
            cursor: progress;
            pointer-events: none;
        }
        #spool-cable-ocr-cable-editor[hidden] { display: none !important; }
        #spool-cable-ocr-cable-editor {
            width: min(100%, 24rem);
            box-sizing: border-box;
        }
        #spool-cable-ocr-draft-label {
            display: block;
            color: rgba(255, 255, 255, 0.92);
            font-size: 0.94rem;
            font-weight: 600;
            margin: 0 0 0.35rem;
            text-align: center;
        }
        #spool-cable-ocr-text-draft {
            display: block;
            width: 100%;
            box-sizing: border-box;
            min-height: 6.5rem;
            max-height: min(36vh, 18rem);
            padding: 0.55rem 0.65rem;
            font: inherit;
            font-size: 1.22rem;
            line-height: 1.48;
            -webkit-text-size-adjust: 100%;
            border-radius: 6px;
            border: 1px solid rgba(180, 220, 255, 0.55);
            background: rgba(18, 22, 28, 0.95);
            color: #f2f6fa;
            resize: vertical;
        }
        #spool-cable-ocr-text-draft::placeholder {
            color: rgba(255, 255, 255, 0.38);
        }
        #spool-cable-ocr-match-row {
            display: flex;
            flex-wrap: wrap;
            gap: 0.65rem;
            align-items: stretch;
            justify-content: center;
            margin-top: 0.65rem;
            width: 100%;
        }
        #spool-cable-ocr-match {
            flex: 1 1 auto;
            min-width: min(100%, 14rem);
            min-height: 2.6rem;
            box-sizing: border-box;
            padding: 0.5rem 1rem;
            font: inherit;
            font-size: 1rem;
            font-weight: 600;
            color: #fff;
            cursor: pointer;
            border-radius: 6px;
            border: 2px solid rgba(120, 200, 140, 0.95);
            background: rgba(40, 110, 65, 0.95);
        }
        #spool-cable-ocr-match:hover:not(:disabled) {
            background: rgba(50, 135, 78, 1);
            border-color: rgba(150, 235, 175, 1);
        }
        #spool-cable-ocr-match:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            pointer-events: none;
        }
        #spool-cable-ocr-direct-new {
            flex: 1 1 auto;
            min-width: min(100%, 14rem);
            min-height: 2.6rem;
            box-sizing: border-box;
            padding: 0.5rem 1rem;
            font: inherit;
            font-size: 1rem;
            font-weight: 600;
            color: #1a1a1a;
            cursor: pointer;
            border-radius: 6px;
            border: 2px solid rgba(95, 200, 255, 0.95);
            background: rgba(200, 240, 255, 0.98);
            -webkit-tap-highlight-color: rgba(95, 200, 255, 0.25);
        }
        #spool-cable-ocr-direct-new:hover:not(:disabled) {
            background: rgba(170, 230, 255, 1);
            border-color: rgba(130, 220, 255, 1);
        }
        #spool-cable-ocr-direct-new:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            pointer-events: none;
        }
        #spool-cable-ocr-choice-modal[hidden] {
            display: none !important;
        }
        #spool-cable-ocr-choice-modal:not([hidden]) {
            display: flex;
        }
        #spool-cable-ocr-choice-modal {
            box-sizing: border-box;
            position: fixed;
            inset: 0;
            z-index: 10002;
            padding: max(0.5rem, env(safe-area-inset-top)) max(0.5rem, env(safe-area-inset-right)) max(0.5rem, env(safe-area-inset-bottom)) max(0.5rem, env(safe-area-inset-left));
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }
        .spool-cable-ocr-choice-modal__backdrop {
            position: absolute;
            inset: 0;
            background: rgba(0, 0, 0, 0.5);
            -webkit-tap-highlight-color: transparent;
        }
        .spool-cable-ocr-choice-modal__card {
            position: relative;
            z-index: 1;
            width: min(100%, 23rem);
            max-height: min(88vh, 28rem);
            overflow: auto;
            margin: auto;
            box-sizing: border-box;
            padding: 1rem 1.05rem 1.1rem;
            border-radius: 10px;
            background: linear-gradient(170deg, #232b38 0%, #1a1f28 100%);
            color: #eaf0f8;
            box-shadow:
                0 10px 40px rgba(0, 0, 0, 0.55),
                inset 0 1px 0 rgba(255, 255, 255, 0.06);
            border: 1px solid rgba(120, 180, 255, 0.22);
        }
        .spool-cable-ocr-choice-modal__heading {
            margin: 0 0 0.5rem;
            font-size: 1.05rem;
            font-weight: 700;
            text-align: center;
            line-height: 1.28;
            color: #fff;
        }
        .spool-cable-ocr-choice-modal__lead {
            margin: 0 0 0.65rem;
            font-size: 0.92rem;
            line-height: 1.42;
            text-align: center;
            color: rgba(236, 244, 255, 0.88);
        }
        .spool-cable-ocr-choice-modal__best {
            margin: 0 0 0.5rem;
            padding: 0.55rem 0.65rem;
            border-radius: 8px;
            border: 1px solid rgba(130, 200, 255, 0.35);
            background: rgba(12, 16, 24, 0.65);
            font-size: 0.94rem;
            line-height: 1.37;
            text-align: center;
            word-break: break-word;
        }
        .spool-cable-ocr-choice-modal__best-strong {
            display: block;
            font-weight: 700;
            color: #fff;
            margin-bottom: 0.2rem;
        }
        .spool-cable-ocr-choice-modal__meta {
            margin: 0 0 0.85rem;
            font-size: 0.82rem;
            line-height: 1.38;
            text-align: center;
            color: rgba(200, 215, 235, 0.78);
            min-height: 0;
        }
        .spool-cable-ocr-choice-modal__actions {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }
        .spool-cable-ocr-choice-modal__btn {
            width: 100%;
            box-sizing: border-box;
            min-height: 2.55rem;
            padding: 0.45rem 0.85rem;
            border-radius: 8px;
            font: inherit;
            font-size: 0.96rem;
            font-weight: 600;
            cursor: pointer;
            border: 1px solid rgba(140, 200, 255, 0.45);
            background: rgba(35, 50, 72, 0.95);
            color: #f0f6ff;
        }
        .spool-cable-ocr-choice-modal__btn:hover:not(:disabled) {
            border-color: rgba(180, 228, 255, 0.75);
            background: rgba(45, 60, 86, 0.98);
        }
        .spool-cable-ocr-choice-modal__btn:disabled {
            opacity: 0.45;
            cursor: not-allowed;
            pointer-events: none;
        }
        .spool-cable-ocr-choice-modal__btn--primary {
            border-color: rgba(120, 200, 140, 0.85);
            background: rgba(34, 95, 58, 0.95);
            color: #fff;
        }
        .spool-cable-ocr-choice-modal__btn--primary:hover:not(:disabled) {
            border-color: rgba(150, 235, 170, 0.95);
            background: rgba(42, 115, 70, 0.98);
        }
        .spool-cable-ocr-choice-modal__btn--ghost {
            font-weight: 500;
            border-style: dashed;
            border-color: rgba(255, 255, 255, 0.25);
            background: transparent;
            color: rgba(255, 255, 255, 0.82);
        }
        .spool-cable-ocr-choice-modal__btn--ghost:hover:not(:disabled) {
            border-color: rgba(255, 255, 255, 0.42);
            background: rgba(255, 255, 255, 0.06);
        }
        #spool-cable-ocr-video {
            display: block;
            width: 100%;
            height: 100%;
            object-fit: cover;
            object-position: center center;
        }
        {% include 'warehouse/_cable_type_picker_core_styles.html.twig' %}
        @media (min-width: 42rem) {
            .spool-form__value--cable .cable-type-mobile-picker {
                max-width: 24rem;
                margin-left: auto;
            }
        }
        @media (min-width: 42rem) {
            .cable-type-mobile-picker--open .cable-type-mobile-picker__full-desc.has-content {
                max-height: min(20rem, 32vh);
            }
        }
        .cable-type-hover-group { max-width: 100%; }
        .spool-form__cable-full-desc-row {
            width: 100%;
            max-width: 100%;
            margin: -0.35rem 0 0.45rem;
            min-width: 0;
            box-sizing: border-box;
        }
        .cable-type-full-desc {
            display: none;
            width: 100%;
            max-width: 100%;
            box-sizing: border-box;
            font-size: 0.86rem; line-height: 1.45; color: #333;
            border: 1px solid #e0e0e0;
            border-left: 3px solid #bbb;
            padding: 0.45rem 0.6rem; margin: 0;
            text-align: left; background: #fafafa; border-radius: 4px; white-space: pre-wrap; word-break: break-word;
        }
        .cable-type-full-desc:empty { display: none !important; }
        /* Po výběru typu nechat plný popis viditelný (ne jen při :hover / :focus-within). */
        .cable-type-full-desc.has-content { display: block; }
        /* Plný popis v okně: vždy viditelný, když je pikr otevřený a pro vybraný typ existuje text.
           (Nelze spoléhat na :hover na .panel — nad nativním <select> v některých prohlížečích se :hover nepropaguje a řádek mizel.) */
        .cable-type-mobile-picker__full-desc {
            display: none;
            flex-shrink: 0;
            width: 100%;
            min-width: 0;
            box-sizing: border-box;
            font-size: 0.86rem; line-height: 1.45; color: #333;
            border-top: 1px solid #e0e0e0;
            border-left: 3px solid #bbb;
            margin: 0;
            padding: 0.45rem 0.6rem 0.55rem;
            text-align: left;
            background: #f8f8f8;
            white-space: pre-wrap;
            word-break: break-word;
            max-height: min(9rem, 32vh);
            overflow: auto;
            -webkit-overflow-scrolling: touch;
        }
        .cable-type-mobile-picker__full-desc:empty { display: none !important; }
        .cable-type-mobile-picker--open .cable-type-mobile-picker__full-desc.has-content {
            display: block;
        }
        .spool-cable-family-filter[hidden] { display: none !important; }
        {% include 'warehouse/_mobile_menu_styles.html.twig' %}
    </style>
{% endblock %}
{% block body %}
    {% include 'warehouse/_mobile_menu.html.twig' %}
    <h1>{{ title }}</h1>
    {% include 'warehouse/spool/_skladova_karta_print_queue_banner.html.twig' %}
    {% set cable_type_meta = {} %}
    {% for ch in form.cableType.vars.choices|default([]) %}
        {% if ch.data is defined and ch.data %}
            {% set cable_type_meta = cable_type_meta|merge({ (ch.value): { family: ch.data.family|default(''), full: ch.data.fullDescription|default(''), name: ch.data.name|default('') } }) %}
        {% endif %}
    {% endfor %}
    <script type="application/json" id="cable-type-meta-json">{{ cable_type_meta|json_encode|raw }}</script>
    <script type="application/json" id="spool-cable-family-labels-json">{{ cable_family_labels_json|default('{}')|raw }}</script>
    <script type="application/json" id="spool-cable-ocr-api-json">{{ {
        matchUrl: path('warehouse_spool_cable_type_ocr_match'),
        stashUrl: path('warehouse_cable_type_ocr_prefill_stash'),
        newCableUrl: path('warehouse_cable_type_new'),
        csrfMatch: csrf_token('spool_cable_type_ocr_match'),
        csrfStash: csrf_token('cable_type_ocr_stash'),
    }|json_encode(256)|raw }}</script>
    {{ form_start(form, { attr: { class: 'spool-form', id: 'spool-new-form' } }) }}
        <div class="cable-type-hover-group" id="cable-type-hover-zone">
        <div class="spool-form__field spool-form__field--cable">
            <button type="button" class="spool-form__label-scan" id="spool-form-cable-ocr" title="OCR řádku se značením kabelu → výběr typu z katalogu nebo nový typ">
                {{- form.cableType.vars.label -}}
            </button>
            <div class="spool-form__value spool-form__value--cable">
                <div class="cable-type-mobile-picker" id="cable-type-mobile-picker">
                    <button type="button" class="cable-type-mobile-picker__toggle" id="cable-type-mobile-btn" aria-haspopup="listbox" aria-expanded="false" aria-controls="cable-type-mobile-panel">
                        <span class="cable-type-mobile-picker__text" id="cable-type-mobile-label">— vyberte typ —</span>
                        <span class="cable-type-mobile-picker__chev" aria-hidden="true">▼</span>
                    </button>
                    <div class="cable-type-mobile-picker__backdrop" id="cable-type-mobile-backdrop" hidden></div>
                    <div class="cable-type-mobile-picker__panel" id="cable-type-mobile-panel" role="dialog" aria-label="Typ kabelu" hidden>
                        <div class="cable-type-mobile-picker__bar">
                            <span class="cable-type-mobile-picker__title">Typ kabelu</span>
                            <button type="button" class="cable-type-mobile-picker__close" id="cable-type-mobile-close" aria-label="Zavřít">×</button>
                        </div>
                        <div class="cable-type-mobile-picker__scroller">
                            {{ form_widget(form.cableType, { attr: { 'aria-label': form.cableType.vars.label } }) }}
                        </div>
                        <div class="cable-type-mobile-picker__full-desc" id="cable-type-full-desc-in-panel" role="region" aria-label="Plný popis kabelu"></div>
                    </div>
                </div>
                {{ form_errors(form.cableType) }}
            </div>
        </div>
        <div class="spool-form__cable-full-desc-row" aria-live="polite">
            <div id="cable-type-full-desc" class="cable-type-full-desc" role="region" aria-label="Plný popis kabelu"></div>
        </div>
        </div>
        <div class="spool-form__field" id="spool-kabel-typ-row" aria-live="polite">
            {{ form_label(form.cableFamilyFilter) }}
            <div class="spool-form__value">
                {{ form_widget(form.cableFamilyFilter) }}
                <p class="spool-form__readout" id="spool-kabel-typ-readout" hidden>—</p>
                {{ form_errors(form.cableFamilyFilter) }}
            </div>
        </div>
        <div class="spool-form__field">
            <button type="button" class="spool-form__label-scan" id="spool-reel-barcode-scan" title="Skenovat čárový kód čísla saře">
                {{- form.reelNumber.vars.label -}}
            </button>
            <div class="spool-form__value">
                {{ form_widget(form.reelNumber, { attr: { 'aria-label': form.reelNumber.vars.label } }) }}
                {{ form_errors(form.reelNumber) }}
            </div>
        </div>
        <div class="spool-form__field">
            <button type="button" class="spool-form__label-scan" id="spool-length-barcode-scan" title="Skenovat čárový kód délky (m)">
                {{- form.totalLengthM.vars.label -}}
            </button>
            <div class="spool-form__value">
                {{ form_widget(form.totalLengthM, { attr: { 'aria-label': form.totalLengthM.vars.label } }) }}
                {{ form_errors(form.totalLengthM) }}
            </div>
        </div>
        <div class="spool-form__field">
            <button type="button" class="spool-form__label-scan" id="spool-ps-ocr-scan" title="OCR čísla PS (viditelných metrů) na štítku — bez čárového kódu">
                {{- form.initialVisibleM.vars.label -}}
            </button>
            <div class="spool-form__value">
                {{ form_widget(form.initialVisibleM, { attr: { 'aria-label': form.initialVisibleM.vars.label } }) }}
                {{ form_errors(form.initialVisibleM) }}
            </div>
        </div>
        <div class="spool-form__field">
            {{ form_label(form.fiberCount) }}
            <div class="spool-form__value">
                {{ form_widget(form.fiberCount) }}
                {{ form_errors(form.fiberCount) }}
            </div>
        </div>
        <div class="spool-form__field">
            {{ form_label(form.diameterMm) }}
            <div class="spool-form__value">
                {{ form_widget(form.diameterMm) }}
                {{ form_errors(form.diameterMm) }}
            </div>
        </div>
        <div class="spool-form__field">
            {{ form_label(form.status) }}
            <div class="spool-form__value">
                {{ form_widget(form.status) }}
                {{ form_errors(form.status) }}
            </div>
        </div>
        <div class="spool-form__field">
            {{ form_label(form.note) }}
            <div class="spool-form__value">
                {{ form_widget(form.note) }}
                {{ form_errors(form.note) }}
            </div>
        </div>
        <div class="spool-form__field">
            {{ form_label(form.registeredAt) }}
            <div class="spool-form__value">
                {{ form_widget(form.registeredAt) }}
                {{ form_errors(form.registeredAt) }}
            </div>
        </div>
        <div class="spool-form__field spool-form__row--actions" style="margin-top: 0.25rem; margin-bottom: 0.25rem;">
            <span class="spool-form__row--action-spacer" aria-hidden="true"></span>
            <div class="spool-form__value spool-form__value--actions">
                <div class="spool-form__actions spool-form__actions--submit-only" role="group" aria-label="Akce">
                    <button type="submit" class="spool-form__btn">Uložit</button>
                </div>
            </div>
        </div>
        {{ form_rest(form) }}
    {{ form_end(form, { render_rest: false }) }}

    <div id="spool-form-scan-overlay" class="spool-form-scan-overlay--strip" hidden role="dialog" aria-label="Sken čárového kódu">
        <p id="spool-form-scan-overlay-text" style="color:#fff;margin:0;text-align:center;max-width:34rem"></p>
        <div id="spool-form-scan-video-wrap" class="spool-form-scan-video-wrap--strip">
            <video id="spool-form-scan-video" playsinline autoplay muted></video>
        </div>
        <button type="button" id="spool-form-scan-cancel" class="spool-form__btn" style="color:#1a1a1a">Zrušit</button>
    </div>
    <div id="spool-cable-ocr-overlay" hidden role="dialog" aria-label="Sken štítku typu kabelu (OCR)">
        <p id="spool-cable-ocr-overlay-text"></p>
        <div id="spool-cable-ocr-video-wrap"><video id="spool-cable-ocr-video" playsinline autoplay muted></video></div>
        <div id="spool-cable-ocr-capture-row" role="presentation">
            <button type="button" id="spool-cable-ocr-capture">Přečíst řádek (OCR)</button>
        </div>
        <div id="spool-cable-ocr-cable-editor" hidden>

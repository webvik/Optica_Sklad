  }

  function formatOcrHintLine(h) {
    if (!h || typeof h !== 'object') return '';
    var p = [];
    if (h.fiberCount != null) p.push('vláken: ' + String(h.fiberCount));
    if (h.diameterMm != null) p.push('\u00d8 ' + String(h.diameterMm) + ' mm');
    if (h.constructionCode) p.push(String(h.constructionCode));
    if (h.familyGuess) p.push(String(h.familyGuess));
    return p.length ? 'Z textu: ' + p.join(' · ') + '.' : '';
  }

  function stashOcrDraftAndOpenNewType(draftText) {
    hideCableChoiceModal();
    if (!cfg.newCableUrl || !cfg.stashUrl || !cfg.csrfStash) {
      window.alert('Formul\u00e1\u0159 nov\u00e9ho typu nen\u00ed na str\u00e1nce nakonfigurov\u00e1n.');
      return;
    }
    setCableMatchUiBusy(true);
    if (cableCaptureBtn) cableCaptureBtn.disabled = true;
    fetch(cfg.stashUrl, {
      method: 'POST',
      credentials: 'same-origin',
      headers: {
        'Content-Type': 'application/json',
        Accept: 'application/json',
        'X-Requested-With': 'XMLHttpRequest',
      },
      body: JSON.stringify({ text: draftText, csrf: cfg.csrfStash }),
    })
      .then(function (r) {
        var ct = (r.headers.get('content-type') || '').toLowerCase();
        if (!r.ok) {
          return r.text().then(function () {
            throw new Error('http');
          });
        }
        if (ct.indexOf('application/json') === -1) {
          throw new Error('notjson');
        }
        return r.json();
      })
      .then(function (j) {
        setCableMatchUiBusy(false);
        if (cableCaptureBtn && !overlay.hidden && scanStream) cableCaptureBtn.disabled = false;
        if (j && j.ok) {
          terminateTessLocal();
          stopCableOcr();
          window.location.assign(cfg.newCableUrl);
          return;
        }
        var er = j && j.error ? String(j.error) : '';
        window.alert(
          er === 'csrf'
            ? 'P\u0159enos textu selhal (CSRF). Obnovte str\u00e1nku a zkuste znovu.'
            : er === 'text'
              ? 'Text je neplatn\u00fd nebo p\u0159\u00edli\u0161 dlouh\u00fd.'
              : 'P\u0159enos textu selhal (relace / s\u00ed\u0165).'
        );
      })
      .catch(function () {
        setCableMatchUiBusy(false);
        if (cableCaptureBtn && !overlay.hidden && scanStream) cableCaptureBtn.disabled = false;
        window.alert('P\u0159enos textu selhal.');
      });
  }

  function tryStashDraftAndGoToNewCableForm() {
    var draft = normalizeDraftText(cableTextDraft ? cableTextDraft.value : '');
    if (!draft.length) {
      window.alert(
        '\u017d\u00e1dn\u00fd text v poli \u2014 nejd\u0159\xedv OCR nebo ru\u010dn\xed \xfapravu.'
      );
      return;
    }
    stashOcrDraftAndOpenNewType(draft);
  }

  function terminateTessLocal() {
    tessWorkerPromise = null;
    var w = tessWorker;
    tessWorker = null;
    if (!w) return;
    try { Promise.resolve(w.terminate()).catch(function () {}); } catch (eT) {}
  }

  function stopCableOcr() {
    ocrBusy = false;
    setCableCaptureUiBusy(false);
    setCableMatchUiBusy(false);
    hideCableChoiceModal();
    setCableOcrEditorVisible(false);
    if (scanRaf != null) {
      try { window.cancelAnimationFrame(scanRaf); } catch (eRaf) {}
      try { window.clearTimeout(scanRaf); } catch (eTo) {}
      scanRaf = null;
    }
    if (scanStream) {
      scanStream.getTracks().forEach(function (t) { t.stop(); });
      scanStream = null;
    }
    if (ocrVideo) ocrVideo.srcObject = null;
    overlay.hidden = true;
  }

  function ensureWorker() {
    if (typeof window.Tesseract === 'undefined' || typeof window.Tesseract.createWorker !== 'function') {
      return Promise.resolve(null);
    }
    if (tessWorker) return Promise.resolve(tessWorker);
    if (!tessWorkerPromise) {
      tessWorkerPromise = window.Tesseract.createWorker('eng', 1, { logger: function () {} })
        .then(function (worker) {
          return worker
            .setParameters({
              user_defined_dpi: '300',
            })
            .then(function () {
              tessWorker = worker;
              tessWorkerPromise = null;
              return worker;
            });
        })
        .catch(function () {
          tessWorkerPromise = null;
          return null;
        });
    }
    return tessWorkerPromise;
  }

  function getCropCanvas() {
    if (!ocrCropCanvas) ocrCropCanvas = document.createElement('canvas');
    return ocrCropCanvas;
  }

  function recognizeCanvasWithMode(worker, canvas, psm) {
    return worker
      .setParameters({ tessedit_pageseg_mode: String(psm) })
      .then(function () {
        return worker.recognize(canvas);
      })
      .then(function (res) {
        var txt = res && res.data && res.data.text ? String(res.data.text) : '';
        return txt;
      })
      .catch(function () {
        return '';
      });
  }

  function selectBestOcrText(textList) {
    var bestRaw = '';
    var bestNorm = '';
    var i;
    for (i = 0; i < textList.length; i++) {
      var raw = String(textList[i] || '');
      var norm = normalizeDraftText(raw);
      if (norm.length > bestNorm.length) {
        bestNorm = norm;
        bestRaw = raw;
      }
    }
    return bestRaw;
  }

  /**
   * Zvětšení + lehká normalizace kontrastu — u úzkého videa jinak Tesseract ztrácí detaily.
   * Vrací nový canvas (zdrojový výřez zůstává v okenním bufferu pro další snímek).
   */
  function enhanceStripCanvasForOcr(canvSrc) {
    var w = canvSrc.width;
    var h = canvSrc.height;
    if (w < 8 || h < 4) return canvSrc;

    var scale = 1;
    if (w < OCR_TARGET_MIN_WIDTH) {
      scale = Math.min(OCR_MAX_UPSCALE, OCR_TARGET_MIN_WIDTH / w);
    }
    var nw = Math.round(w * scale);
    var nh = Math.round(h * scale);
    if (nw > OCR_MAX_OUTPUT_WIDTH) {
      var r = OCR_MAX_OUTPUT_WIDTH / nw;
      nw = OCR_MAX_OUTPUT_WIDTH;
      nh = Math.max(12, Math.round(nh * r));
    }

    var out = document.createElement('canvas');
    out.width = nw;
    out.height = nh;
    var x = out.getContext('2d');
    if (!x) return canvSrc;
    x.imageSmoothingEnabled = true;
    x.imageSmoothingQuality = 'high';
    try {
      x.filter = 'grayscale(1) contrast(1.38) brightness(1.05)';
    } catch (eFl) {}
    x.drawImage(canvSrc, 0, 0, nw, nh);
    try {
      x.filter = 'none';
    } catch (eFn) {}

    return out;
  }

  /**
   * Druhý průchod: silnější kontrast + lehká binarizace pro vytažení znaků.
   * Ne vždy je lepší, proto níže porovnáváme oba OCR výstupy a bereme kvalitnější.
   */
  function enhanceStripCanvasForOcrBinary(canvSrc) {
    var w = canvSrc.width;
    var h = canvSrc.height;
    if (w < 8 || h < 4) return canvSrc;

    var out = document.createElement('canvas');
    out.width = w;
    out.height = h;
    var x = out.getContext('2d');
    if (!x) return canvSrc;
    x.imageSmoothingEnabled = true;
    x.imageSmoothingQuality = 'high';
    x.drawImage(canvSrc, 0, 0, w, h);
    var img;
    try {
      img = x.getImageData(0, 0, w, h);
    } catch (eImg) {
      return out;
    }
    var d = img.data;
    var i;
    for (i = 0; i < d.length; i += 4) {
      var r = d[i];
      var g = d[i + 1];
      var b = d[i + 2];
      var y = (0.299 * r) + (0.587 * g) + (0.114 * b);
      var bw = y >= 152 ? 255 : 0;
      d[i] = bw;
      d[i + 1] = bw;
      d[i + 2] = bw;
    }
    x.putImageData(img, 0, 0);
    return out;
  }

  function captureCableOcrCropCanvas() {
    if (!ocrVideo || scanStream === null) return null;
    if (ocrVideo.readyState < 2) return null;
    var vw = ocrVideo.videoWidth;
    var vh = ocrVideo.videoHeight;
    if (vw < 2 || vh < 2) return null;
    var isCableMode = ocrMode === 'cable';
    var stripFrac = isCableMode ? CABLE_STRIP_FRAC : 0.24;
    var widthFrac = isCableMode ? CABLE_WIDTH_FRAC : 1;
    var sh = Math.max(12, Math.round(vh * stripFrac));
    var sy = Math.round((vh - sh) / 2);
    var sw = Math.max(24, Math.round(vw * widthFrac));
    var sx = Math.round((vw - sw) / 2);
    /** Plná šířka snímku — upscaling řeší enhanceStripCanvasForOcr (dříve cap 960 škodil na telefonu) */
    var cw = sw;
    var ch = Math.max(12, Math.round(sh * (cw / sw)));
    var canv = getCropCanvas();
    if (canv.width !== cw || canv.height !== ch) {
      canv.width = cw;
      canv.height = ch;
    }
    var ctx = canv.getContext('2d');
    if (!ctx) return null;
    ctx.filter = 'none';
    ctx.drawImage(ocrVideo, sx, sy, sw, sh, 0, 0, cw, ch);
    return enhanceStripCanvasForOcr(canv);
  }

  function performCableOcrSnap() {
    if (!overlay || overlay.hidden || scanStream === null) return;
    if (ocrBusy) return;
    var canv = captureCableOcrCropCanvas();
    if (!canv) {
      if (ocrTextHint && ocrMode === 'cable') {
        ocrTextHint.textContent =
          'Kamera ještě nenačetla obrázek — chvili počkejte, nebo zavřete a zkuste znovu. Pak klepněte „Přečíst řádek (OCR)“.';
      } else if (ocrTextHint) {
        ocrTextHint.textContent = 'Zkuste počkat na náhled, pak klepněte „Přečíst řádek (OCR)“.';
      }
      return;
    }
    ocrBusy = true;
    setCableCaptureUiBusy(true);
    if (cableMatchBtn && ocrMode === 'cable') cableMatchBtn.disabled = true;
    if (cableDirectNewBtn && ocrMode === 'cable') cableDirectNewBtn.disabled = true;
    ensureWorker()
      .then(function (worker) {
        if (!worker) {
          endOcrSnapCycle();
          if (ocrTextHint) {
            ocrTextHint.textContent = 'Worker OCR nedostupný — obnovte stránku.';
          }
          return;
        }
        if (scanStream === null) {
          endOcrSnapCycle();
          return;
        }
        var canvBinary = enhanceStripCanvasForOcrBinary(canv);
        var tasks = [];
        var iMode;
        for (iMode = 0; iMode < OCR_PAGE_SEG_MODES.length; iMode++) {
          tasks.push(recognizeCanvasWithMode(worker, canv, OCR_PAGE_SEG_MODES[iMode]));
          tasks.push(recognizeCanvasWithMode(worker, canvBinary, OCR_PAGE_SEG_MODES[iMode]));
        }
        Promise.all(tasks)
          .then(function (texts) {
            if (scanStream === null) {
              endOcrSnapCycle();
              return;
            }
            var txt = selectBestOcrText(texts || []);
            if (ocrMode === 'ps') {
              var psVal = tryExtractPs(txt);
              if (psVal) {
                finishPsFromOcr(psVal);
                return;
              }
              if (ocrTextHint) {
                ocrTextHint.textContent =
                  'Nepodařilo se přečíst číslo — lépe držte znaky PS v modrém pruhu a klepněte znovu.';
              }
            } else {
              var draft = normalizeDraftText(txt);
              if (!draft.length) {
                if (ocrTextHint) {
                  ocrTextHint.textContent =
                    'OCR nepřečetl žádný text — lépe držte řádek v modrém pruhu a klepněte „Přečíst řádek (OCR)“ znovu.';
                }

  /** Jedno vstupní okno po Porovnat — doporučený jeden typ nebo jen nový / zpět */
  function showCableChoiceModal(j) {
    if (!choiceModal || !choiceLead) return;

    pendingPickCableType = pickBestCableAfterMatch(j);
    var sch = !!(j && j.matched && j.cableType);
    var hasBest = !!(pendingPickCableType && pendingPickCableType.id != null);
    var sc = pickBestScoreAfterMatch(j, pendingPickCableType);

    if (sch && hasBest) {
      choiceLead.textContent =
        'Nejspíše odpovídá text štítku níže uvedenému typu v katalogu — zkontrolujte a potvrďte, nebo zadejte nový typ.';
    } else if (hasBest) {
      choiceLead.textContent =
        'Shoda nemusí být správná — jako nejbližší nabízíme tento typ. Ověřte nebo použijte nový typ.';
    } else {
      choiceLead.textContent =
        'V katalogu není rozumně blízký typ — upravte text a zkuste znovu, nebo pokračujte jako novým typem.';
    }

    var hintFmt = formatOcrHintLine(j && j.hints);
    var metaParts = [];
    if (hintFmt) metaParts.push(hintFmt.replace(/\.$/, ''));
    if (hasBest && sc != null) metaParts.push('blízkost ' + String(sc));
    if (choiceMeta)
      choiceMeta.textContent =
        metaParts.length > 0
          ? metaParts.join(' — ') + '.'
          : '';

    if (choiceBestPanel && choiceBestLine) {
      if (hasBest) {
        choiceBestLine.textContent =
          String(pendingPickCableType.code || '') +
          ' — ' +
          String(pendingPickCableType.name || '');
        if (choiceBestSub) {
          var sp = [];
          if (pendingPickCableType.fiberCount)
            sp.push(String(pendingPickCableType.fiberCount) + ' vl.');
          if (pendingPickCableType.diameterMm)
            sp.push('\u00d8 ' + String(pendingPickCableType.diameterMm) + ' mm');
          choiceBestSub.textContent = sp.join(' · ');
        }
        choiceBestPanel.removeAttribute('hidden');
      } else {
        choiceBestPanel.setAttribute('hidden', '');
        if (choiceBestSub) choiceBestSub.textContent = '';
      }
    }

    if (choicePickBtn) choicePickBtn.disabled = !hasBest;

    choiceModal.removeAttribute('hidden');
    choiceModal.setAttribute('aria-hidden', 'false');

    window.setTimeout(function () {
      try {
        if (hasBest && choicePickBtn) choicePickBtn.focus();
        else if (choiceNewBtn) choiceNewBtn.focus();
      } catch (eFoc) {}

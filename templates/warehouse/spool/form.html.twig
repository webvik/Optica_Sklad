  function closePanel() {
    if (!panel) return;
    root.classList.remove('cable-type-mobile-picker--open');
    panel.setAttribute('hidden', '');
    if (backdrop) backdrop.setAttribute('hidden', '');
    document.body.classList.remove('spool-cable-panel-open');
    if (btn) { btn.setAttribute('aria-expanded', 'false'); try { btn.focus(); } catch (e) {} }
  }
  function syncAll() {
    syncLabel();
    if (typeof window.spoolFormSyncSpoolKabelBlock === 'function') { window.spoolFormSyncSpoolKabelBlock(); }
  }
  if (btn) {
    btn.addEventListener('click', function (ev) {
      ev.preventDefault();
      if (panel && panel.hasAttribute('hidden')) { openPanel(); }
    });
  }
  if (closeBtn) closeBtn.addEventListener('click', function () { closePanel(); });
  if (backdrop) {
    backdrop.addEventListener('click', function () { closePanel(); });
  }
  sel.addEventListener('change', function () {
    syncAll();
    if (!panel.hasAttribute('hidden')) { closePanel(); }
  });
  document.addEventListener('keydown', function (ev) {
    if (ev.key !== 'Escape' || !panel || panel.hasAttribute('hidden')) return;
    ev.preventDefault();
    closePanel();
  });
  function mqChange() {
    syncAll();
    if (!panel.hasAttribute('hidden') && typeof window.spoolFormScheduleCableTypeListbox === 'function') {
      window.spoolFormScheduleCableTypeListbox();
    }
  }
  if (mq.addEventListener) mq.addEventListener('change', mqChange);
  else if (mq.addListener) mq.addListener(mqChange);
  window.addEventListener('pageshow', syncAll);
  syncAll();
})();
(function () {
  var cableSel = document.getElementById({{ form.cableType.vars.id|json_encode|raw }});
  if (!cableSel) return;
  var fiberCountIn = document.getElementById({{ form.fiberCount.vars.id|json_encode|raw }});
  var diameterMmIn = document.getElementById({{ form.diameterMm.vars.id|json_encode|raw }});
  var famSel = document.getElementById({{ form.cableFamilyFilter.vars.id|json_encode|raw }});
  var readout = document.getElementById('spool-kabel-typ-readout');
  var metaEl = document.getElementById('cable-type-meta-json');
  var labelsEl = document.getElementById('spool-cable-family-labels-json');
  var desc = document.getElementById('cable-type-full-desc');
  var descInPanel = document.getElementById('cable-type-full-desc-in-panel');
  var meta = {};
  var familyLabels = {};
  var scroller = cableSel.closest('.cable-type-mobile-picker__scroller');
  var mobileMq = window.matchMedia('(max-width: 41.99rem)');
  var sizeListT = null;
  try { if (metaEl && metaEl.textContent) { meta = JSON.parse(metaEl.textContent); } } catch (e) {}
  try { if (labelsEl && labelsEl.textContent) { familyLabels = JSON.parse(labelsEl.textContent); } } catch (e) {}
  /**
   * Nativní listbox (size>1) skoro nikde nerozšiřuje šířku podle nejdelší option — max-content nefunguje.
   * Změříme texty a nastavíme širší <select>, aby roloval rodič .cable-type-mobile-picker__scroller.
   */
  function sizeCableTypeListbox() {
    if (!scroller) return;
    var measure = document.createElement('div');
    measure.setAttribute('aria-hidden', 'true');
    measure.style.cssText = 'position:absolute;left:-9999px;top:0;white-space:nowrap;visibility:hidden;pointer-events:none;';
    var cs = window.getComputedStyle(cableSel);
    measure.style.font = cs.font;
    measure.style.letterSpacing = cs.letterSpacing;
    measure.style.textTransform = cs.textTransform;
    document.body.appendChild(measure);
    var maxW = 0;
    var k;
    for (k = 0; k < cableSel.options.length; k++) {
      measure.textContent = cableSel.options[k].text || ' ';
      maxW = Math.max(maxW, measure.offsetWidth);
    }
    document.body.removeChild(measure);
    var pad = mobileMq.matches ? 40 : 36;
    var cw = scroller.clientWidth;
    if (cw < 2) {
      cw = mobileMq.matches ? (window.innerWidth || 400) : 300;
    }
    var need = Math.max(cw, maxW + pad);
    cableSel.style.minWidth = need + 'px';
    cableSel.style.width = need + 'px';
  }
  function scheduleSizeCableTypeListbox() {
    if (sizeListT) { clearTimeout(sizeListT); }
    sizeListT = setTimeout(function () {
      sizeListT = null;
      sizeCableTypeListbox();
    }, 50);
  }
  window.spoolFormScheduleCableTypeListbox = scheduleSizeCableTypeListbox;
  function optionFamily(opt) {
    if (!opt || opt.value === '') return '';
    if (opt.dataset && opt.dataset.family) return String(opt.dataset.family);
    var a = opt.getAttribute('data-family');
    return a ? String(a) : '';
  }
  function applyFamilyFilter() {
    if (!famSel || !cableSel) return;
    var want = (famSel.value && String(famSel.value).length) ? String(famSel.value) : '';
    var opts = cableSel.querySelectorAll('option');
    for (var i = 0; i < opts.length; i++) {
      var o = opts[i];
      if (!o.value) { o.hidden = false; continue; }
      var fam = optionFamily(o);
      o.hidden = (want !== '' && fam !== want);
    }
    if (cableSel.value) {
      var cur = getCableTypeOption();
      if (cur && (cur.value === '' || cur.hidden)) {
        cableSel.value = '';
        try { cableSel.dispatchEvent(new Event('change', { bubbles: true })); } catch (e) {}
      }
    }
  }
  /**
   * Plný text bereme z <option> (data b64) — to je ta samá věc v DOM jako název řádku, žádný mapování z JSON.
   */
  function b64ToUtf8(b64) {
    if (b64 == null || b64 === '') {
      return '';
    }
    try {
      b64 = String(b64).replace(/\s/g, '');
      if (!b64.length) {
        return '';
      }
      var bin = atob(b64);
      if (typeof TextDecoder !== 'undefined') {
        var a = new Uint8Array(bin.length);
        for (var u = 0; u < bin.length; u++) {
          a[u] = bin.charCodeAt(u);
        }
        return new TextDecoder('utf-8').decode(a);
      }
      return decodeURIComponent(escape(bin));
    } catch (e) {
      return '';
    }
  }
  /**
   * U listboxu může selectedIndex o pár míst dál od řádku odpovídajícího cableSel.value
   * (o hlášeném „+2“). Vždy bereme <option> podle aktuálního value / selectedOptions[0].
   */
  function getCableTypeOption() {
    var v = String(cableSel.value || '');
    if (!v) {
      return null;
    }
    if (cableSel.selectedOptions && cableSel.selectedOptions[0] && String(cableSel.selectedOptions[0].value) === v) {
      return cableSel.selectedOptions[0];
    }
    var oi;
    for (oi = 0; oi < cableSel.options.length; oi++) {
      if (String(cableSel.options[oi].value) === v) {
        return cableSel.options[oi];
      }
    }
    if (cableSel.selectedIndex >= 0) {
      return cableSel.options[cableSel.selectedIndex] || null;
    }
    return null;
  }
  function applySpoolFieldsFromCableType() {
    var opt = getCableTypeOption();
    if (!opt) {
      return;
    }
    if (fiberCountIn) {
      var f = (opt.getAttribute('data-fiber-count') != null) ? String(opt.getAttribute('data-fiber-count')).trim() : '';
      if (f !== '') {
        fiberCountIn.value = f;
      }
    }
    if (diameterMmIn) {
      var d = (opt.getAttribute('data-diameter-mm') != null) ? String(opt.getAttribute('data-diameter-mm')).trim() : '';
      if (d !== '') {
        diameterMmIn.value = d;
      }
    }
  }
  function setDesc() {
    function clearDescPair() {
      if (desc) {
        desc.textContent = '';
        desc.classList.remove('has-content');
      }
      if (descInPanel) {
        descInPanel.textContent = '';
        descInPanel.classList.remove('has-content');
      }
    }
    if (!desc && !descInPanel) {
      return;
    }
    clearDescPair();
    var opt = getCableTypeOption();
    if (!opt) {
      return;
    }
    var val = String(opt.value || '');
    if (!val) {
      return;
    }
    var t = b64ToUtf8(opt.getAttribute('data-b64-cable-full')).trim();
    if (!t.length) {
      var nm = opt.getAttribute('data-cable-name');
      if (nm) {
        t = String(nm).trim();
      }
    }
    if (!t.length) {
      var m = meta[val];
      if (m == null) {
        m = meta[Number(val)];
      }
      t = m && m.full != null ? String(m.full) : '';
      t = t.trim();
      if (!t.length && m && m.name) {
        t = String(m.name).trim();
      }
    }
    if (!t.length) {
      return;
    }
    if (desc) {
      desc.textContent = t;
      desc.classList.add('has-content');
    }
    if (descInPanel) {
      descInPanel.textContent = t;
      descInPanel.classList.add('has-content');
    }
  }
  function syncKabelTyp() {
    if (!readout) return;
    if (cableSel.value) {
      if (famSel) { famSel.setAttribute('hidden', ''); }
      var opt = getCableTypeOption();
      var code = optionFamily(opt);
      var label = (code && familyLabels[code]) ? familyLabels[code] : (code || '—');
      readout.textContent = label;
      readout.removeAttribute('hidden');
    } else {
      if (famSel) { famSel.removeAttribute('hidden'); }
      readout.setAttribute('hidden', '');
    }
  }
  function syncAllBlock() {
    applyFamilyFilter();
    syncKabelTyp();
    setDesc();
    requestAnimationFrame(function () {
      sizeCableTypeListbox();
    });
  }
  window.spoolFormSyncSpoolKabelBlock = syncAllBlock;
  if (famSel) famSel.addEventListener('change', syncAllBlock);
  function onCableTypeUserPicked() {
    applySpoolFieldsFromCableType();
    syncAllBlock();
  }
  cableSel.addEventListener('change', onCableTypeUserPicked);
  cableSel.addEventListener('input', onCableTypeUserPicked);
  window.addEventListener('resize', scheduleSizeCableTypeListbox);
  if (mobileMq.addEventListener) {
    mobileMq.addEventListener('change', function () { scheduleSizeCableTypeListbox(); });
  } else if (mobileMq.addListener) {
    mobileMq.addListener(function () { scheduleSizeCableTypeListbox(); });
  }
  if (document.fonts && document.fonts.ready) {
    document.fonts.ready.then(function () { scheduleSizeCableTypeListbox(); });
  }
  syncAllBlock();
})();
    </script>

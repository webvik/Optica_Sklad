            </div>
        </div>
        <button type="button" id="spool-cable-ocr-cancel" class="spool-form__btn" style="color:#1a1a1a">Zrušit</button>
    </div>
    <div style="max-width: 40rem; margin: 0 auto; box-sizing: border-box;">
        <p style="margin: 0.85rem 0 0.35rem; display: flex; flex-wrap: wrap; gap: 0.65rem; align-items: center; justify-content: center;">
            <a class="warehouse-pill" href="{{ path('warehouse_cable_type_new') }}">Nový typ kabelu v katalogu</a>
        </p>
        <p style="margin: 0; text-align: center;"><a href="{{ path('warehouse_spool_index') }}">← zpět na seznam</a></p>
    </div>

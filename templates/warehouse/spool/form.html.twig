{% extends 'base.html.twig' %}
{% block title %}{{ title }}{% endblock %}
{% block stylesheets %}
    {{ parent() }}
    <style>
        .spool-form { max-width: 40rem; line-height: 1.6; }
        .spool-form__field {
            display: grid;
            grid-template-columns: minmax(0, 8rem) minmax(0, 1fr);
            column-gap: 0.45rem;
            row-gap: 0.2rem;
            margin: 0 0 0.75rem;
            align-items: start;
        }
        .spool-form__field > label,
        .spool-form__field > .spool-form__static-label,
        .spool-form__field > .spool-form__label-scan {
            font-weight: 600;
            font-size: 0.84rem;
            line-height: 1.25;
            padding-top: 0.28rem;
            word-break: break-word;
            hyphens: auto;
        }
        .spool-form__label-scan {
            box-sizing: border-box;
            margin: 0;
            justify-self: start;
            align-self: start;
            max-width: 100%;
            text-align: left;
            font: inherit;
            font-weight: 600;
            font-size: 0.84rem;
            line-height: 1.25;
            color: inherit;
            cursor: pointer;
            padding: 0.28rem 0.45rem;
            border: 1px solid rgba(0, 0, 0, 0.26);
            background: rgba(250, 250, 250, 0.65);
            border-radius: 4px;
            -webkit-tap-highlight-color: rgba(0, 0, 0, 0.08);
            word-break: break-word;
            hyphens: auto;
            min-height: 2rem;
            display: inline-block;
            vertical-align: top;
        }
        .spool-form__label-scan:hover {
            border-color: rgba(0, 0, 0, 0.42);
            background: rgba(0, 0, 0, 0.04);
        }
        .spool-form__label-scan:active {
            background: rgba(0, 0, 0, 0.07);
            border-color: rgba(0, 0, 0, 0.48);
        }
        .spool-form__label-scan:focus-visible {
            outline: 2px solid #2563eb;
            outline-offset: 2px;
        }
        .spool-form__readout { margin: 0; font-size: 0.88rem; line-height: 1.35; color: #333; }
        .spool-form__value { min-width: 0; text-align: left; }
        .spool-form__value .form-error, .spool-form__value ul, .spool-form__value p.help-text { margin: 0.25rem 0 0; display: block; }
        .spool-form__value p.form-text, .spool-form__value p.help-text, .spool-form__value small { font-size: 0.85rem; line-height: 1.4; color: #555; text-align: left; }
        .spool-form__value [type="date"], .spool-form__value [type="number"],
        .spool-form__value [type="text"], .spool-form__value textarea, .spool-form__value select {
            max-width: 100%; box-sizing: border-box;
        }
        .spool-form__value input, .spool-form__value select, .spool-form__value textarea { text-align: left; width: 100%; }
        .spool-form__value select.cable-type-list { max-width: 100%; }
        @media (min-width: 42rem) {
            .spool-form__field { grid-template-columns: 12.5rem 1fr; column-gap: 1.5rem; margin-bottom: 0.9rem; }
            .spool-form__row--actions { grid-template-columns: 12.5rem 1fr; }
            .spool-form__field > label,
            .spool-form__field > .spool-form__static-label,
            .spool-form__field > .spool-form__label-scan { font-size: 1.06rem; line-height: 1.45; padding-top: 0.2rem; min-height: 0; }
            .spool-form__value > input, .spool-form__value > select, .spool-form__value > textarea {
                max-width: 24rem;
            }
            .spool-form__value > input, .spool-form__value > select, .spool-form__value > textarea { margin-left: auto; display: block; }
            .spool-form__value p.form-text, .spool-form__value p.help-text { max-width: 24rem; margin-left: auto; }
            .spool-form__value--actions .spool-form__actions { max-width: 24rem; margin-left: auto; }
            .spool-form__value > ul, .spool-form__value .form-error { text-align: left; margin-left: auto; max-width: 24rem; }
        }
        @media (max-width: 41.99rem) {
            .spool-form__row--action-spacer { display: none !important; }
            .spool-form__row--actions .spool-form__value--actions { grid-column: 1 / -1; }
            .spool-form__label-scan {
                min-height: 2.75rem;
                padding-top: 0.45rem;
                padding-bottom: 0.45rem;
                display: flex;
                align-items: center;
            }
        }
        .spool-form__actions { display: flex; flex-direction: row; justify-content: space-between; align-items: center; gap: 0.65rem; flex-wrap: wrap; width: 100%; }
        .spool-form__actions--submit-only { justify-content: flex-end; }
        @media (min-width: 42rem) {
            .spool-form__row--actions .spool-form__value--actions { width: 100%; }
        }
        .spool-form__btn, .spool-form__actions button[type="submit"] {
            box-sizing: border-box; display: inline-flex; align-items: center; justify-content: center;
            min-height: 2.55rem; min-width: 5.5rem; padding: 0.45rem 1rem; font: inherit; font-size: 1rem; font-weight: 500;
            line-height: 1.2; border: 1px solid #bbb; border-radius: 4px; background: #f5f5f5; color: #1a1a1a; cursor: pointer;
        }
        .spool-form__btn:hover, .spool-form__actions button[type="submit"]:hover { background: #eaeaec; }
        .spool-form__btn:active, .spool-form__actions button[type="submit"]:active { background: #e0e0e2; }
        .spool-form__row--action-spacer { display: none; }
        @media (min-width: 42rem) {
            .spool-form__row--action-spacer { display: block; min-height: 1px; }
        }
        #spool-form-scan-overlay[hidden] { display: none !important; }
        #spool-form-scan-overlay {
            position: fixed;
            inset: 0;
            z-index: 9999;
            background: rgba(0, 0, 0, .75);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 1rem;
            padding: 1rem;
            box-sizing: border-box;
        }
        /* Stejné proporce jako sken vyhledávání (Úzký pruh). JS: sareStripFrac 0.17 — měnit společně s work-scan u spool/index */
        #spool-form-scan-video-wrap {
            flex-shrink: 0;
            max-width: min(100%, 640px);
            box-sizing: border-box;
        }
        .spool-form-scan-overlay--strip #spool-form-scan-video-wrap.spool-form-scan-video-wrap--strip {
            width: min(100%, 34rem);
            height: clamp(4.25rem, 11.5vh, 6.25rem);
            overflow: hidden;
            border-radius: 8px;
            border: 2px solid rgba(85, 220, 175, 0.9);
            box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.35);
            background: #111;
            position: relative;
        }
        .spool-form-scan-overlay--strip #spool-form-scan-video-wrap.spool-form-scan-video-wrap--strip::after {
            content: '';
            position: absolute;
            inset: 0;
            pointer-events: none;
            border: 1px solid rgba(255, 255, 255, 0.08);
            box-sizing: border-box;
            border-radius: inherit;
            z-index: 1;
        }
        .spool-form-scan-overlay--strip #spool-form-scan-video-wrap.spool-form-scan-video-wrap--strip #spool-form-scan-video {
            display: block;
            width: 100%;
            height: 100%;
            max-height: none;
            border-radius: 0;
            object-fit: cover;
            object-position: center center;
        }
        #spool-cable-ocr-overlay[hidden] { display: none !important; }
        #spool-cable-ocr-overlay {
            position: fixed; inset: 0; z-index: 10000;
            background: rgba(0, 0, 0, 0.76);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 0.85rem;
            padding: 1rem;
            box-sizing: border-box;
        }
        #spool-cable-ocr-overlay-text {
            color: #fff;
            margin: 0;
            text-align: center;
            max-width: 38rem;
            font-size: 0.93rem;
            line-height: 1.42;
            padding: 0 0.35rem;
        }
        #spool-cable-ocr-video-wrap {
            width: min(100%, 28rem);
            height: clamp(4.75rem, 14vh, 7rem);
            overflow: hidden;
            border-radius: 8px;
            border: 2px solid rgba(95, 200, 255, 0.85);
            background: #111;
            flex-shrink: 0;
            box-sizing: border-box;
        }
        #spool-cable-ocr-capture-row {
            display: flex;
            flex-wrap: wrap;
            gap: 0.65rem;
            align-items: center;
            justify-content: center;
            max-width: min(100%, 28rem);
        }
        #spool-cable-ocr-capture {
            flex: 1 1 auto;
            min-width: min(100%, 12rem);
            min-height: 2.65rem;
            box-sizing: border-box;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 0.5rem 1rem;
            font: inherit;
            font-size: 1rem;
            font-weight: 600;
            line-height: 1.15;
            color: #1a1a1a;
            cursor: pointer;
            border-radius: 6px;
            border: 2px solid rgba(95, 200, 255, 0.95);
            background: rgba(200, 240, 255, 0.98);
            -webkit-tap-highlight-color: rgba(95, 200, 255, 0.25);
        }
        #spool-cable-ocr-capture:hover:not(:disabled) {
            background: rgba(170, 230, 255, 1);
            border-color: rgba(130, 220, 255, 1);
        }
        #spool-cable-ocr-capture:disabled {
            opacity: 0.55;
            cursor: progress;
            pointer-events: none;
        }
        #spool-cable-ocr-cable-editor[hidden] { display: none !important; }
        #spool-cable-ocr-cable-editor {
            width: min(100%, 28rem);
            box-sizing: border-box;
        }
        #spool-cable-ocr-draft-label {
            display: block;
            color: rgba(255, 255, 255, 0.92);
            font-size: 0.94rem;
            font-weight: 600;
            margin: 0 0 0.35rem;
            text-align: center;
        }
        #spool-cable-ocr-text-draft {
            display: block;
            width: 100%;
            box-sizing: border-box;
            min-height: 6.5rem;
            max-height: min(36vh, 18rem);
            padding: 0.55rem 0.65rem;
            font: inherit;
            font-size: 1.22rem;
            line-height: 1.48;
            -webkit-text-size-adjust: 100%;
            border-radius: 6px;
            border: 1px solid rgba(180, 220, 255, 0.55);
            background: rgba(18, 22, 28, 0.95);
            color: #f2f6fa;
            resize: vertical;
        }
        #spool-cable-ocr-text-draft::placeholder {
            color: rgba(255, 255, 255, 0.38);
        }
        #spool-cable-ocr-match-row {
            display: flex;
            flex-wrap: wrap;
            gap: 0.65rem;
            align-items: stretch;
            justify-content: center;
            margin-top: 0.65rem;
            width: 100%;
        }
        #spool-cable-ocr-match {
            flex: 1 1 auto;
            min-width: min(100%, 14rem);
            min-height: 2.6rem;
            box-sizing: border-box;
            padding: 0.5rem 1rem;
            font: inherit;
            font-size: 1rem;
            font-weight: 600;
            color: #fff;
            cursor: pointer;
            border-radius: 6px;
            border: 2px solid rgba(120, 200, 140, 0.95);
            background: rgba(40, 110, 65, 0.95);
        }
        #spool-cable-ocr-match:hover:not(:disabled) {
            background: rgba(50, 135, 78, 1);
            border-color: rgba(150, 235, 175, 1);
        }
        #spool-cable-ocr-match:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            pointer-events: none;
        }
        #spool-cable-ocr-suggestions[hidden] {
            display: none !important;
        }
        #spool-cable-ocr-suggestions {
            margin-top: 0.65rem;
            width: min(100%, 28rem);
            box-sizing: border-box;
        }
        .spool-cable-ocr-sug-hints {
            margin: 0 0 0.45rem;
            color: rgba(255, 255, 255, 0.78);
            font-size: 0.86rem;
            line-height: 1.38;
            text-align: center;
        }
        .spool-cable-ocr-sug-list {
            display: flex;
            flex-direction: column;
            gap: 0.45rem;
        }
        .spool-cable-ocr-sug-pick {
            width: 100%;
            box-sizing: border-box;
            min-height: 2.5rem;
            padding: 0.45rem 0.65rem;
            border-radius: 6px;
            border: 1px solid rgba(160, 210, 255, 0.45);
            background: rgba(28, 36, 48, 0.98);
            color: #eaf2fb;
            font: inherit;
            font-size: 0.94rem;
            text-align: left;
            cursor: pointer;
            line-height: 1.3;
        }
        .spool-cable-ocr-sug-pick:hover {
            border-color: rgba(200, 235, 255, 0.75);
            background: rgba(38, 50, 66, 0.98);
        }
        .spool-cable-ocr-new-type {
            display: block;
            width: 100%;
            box-sizing: border-box;
            margin-top: 0.55rem;
            min-height: 2.5rem;
            padding: 0.45rem 0.85rem;
            border-radius: 6px;
            border: 1px dashed rgba(255, 215, 150, 0.55);
            background: rgba(55, 40, 22, 0.55);
            color: rgba(255, 245, 220, 1);
            font: inherit;
            font-weight: 600;
            font-size: 0.95rem;
            cursor: pointer;
        }
        .spool-cable-ocr-new-type:hover {
            background: rgba(70, 52, 28, 0.72);
            border-color: rgba(255, 230, 180, 0.75);
        }
        #spool-cable-ocr-video {
            display: block;
            width: 100%;
            height: 100%;
            object-fit: cover;
            object-position: center center;
        }
        {% include 'warehouse/_cable_type_picker_core_styles.html.twig' %}
        @media (min-width: 42rem) {
            .spool-form__value--cable .cable-type-mobile-picker {
                max-width: 24rem;
                margin-left: auto;
            }
        }
        @media (min-width: 42rem) {
            .cable-type-mobile-picker--open .cable-type-mobile-picker__full-desc.has-content {
                max-height: min(20rem, 32vh);
            }
        }
        .cable-type-hover-group { max-width: 100%; }
        .spool-form__cable-full-desc-row {
            width: 100%;
            max-width: 100%;
            margin: -0.35rem 0 0.45rem;
            min-width: 0;
            box-sizing: border-box;
        }
        .cable-type-full-desc {
            display: none;
            width: 100%;
            max-width: 100%;
            box-sizing: border-box;
            font-size: 0.86rem; line-height: 1.45; color: #333;
            border: 1px solid #e0e0e0;
            border-left: 3px solid #bbb;
            padding: 0.45rem 0.6rem; margin: 0;
            text-align: left; background: #fafafa; border-radius: 4px; white-space: pre-wrap; word-break: break-word;
        }
        .cable-type-full-desc:empty { display: none !important; }
        .cable-type-hover-group:hover .cable-type-full-desc.has-content,
        .cable-type-hover-group:focus-within .cable-type-full-desc.has-content { display: block; }
        @media (hover: none), (pointer: coarse) {
            .cable-type-full-desc.has-content { display: block; }
        }
        /* Plný popis v okně: vždy viditelný, když je pikr otevřený a pro vybraný typ existuje text.
           (Nelze spoléhat na :hover na .panel — nad nativním <select> v některých prohlížečích se :hover nepropaguje a řádek mizel.) */
        .cable-type-mobile-picker__full-desc {
            display: none;
            flex-shrink: 0;
            width: 100%;
            min-width: 0;
            box-sizing: border-box;
            font-size: 0.86rem; line-height: 1.45; color: #333;
            border-top: 1px solid #e0e0e0;
            border-left: 3px solid #bbb;
            margin: 0;
            padding: 0.45rem 0.6rem 0.55rem;
            text-align: left;
            background: #f8f8f8;
            white-space: pre-wrap;
            word-break: break-word;
            max-height: min(9rem, 32vh);
            overflow: auto;
            -webkit-overflow-scrolling: touch;
        }
        .cable-type-mobile-picker__full-desc:empty { display: none !important; }
        .cable-type-mobile-picker--open .cable-type-mobile-picker__full-desc.has-content {
            display: block;
        }
        .spool-cable-family-filter[hidden] { display: none !important; }
    </style>
{% endblock %}
{% block body %}
    {% include '_app_menu_cz.html.twig' %}
    <h1>{{ title }}</h1>
    {% set cable_type_meta = {} %}
    {% for ch in form.cableType.vars.choices|default([]) %}
        {% if ch.data is defined and ch.data %}
            {% set cable_type_meta = cable_type_meta|merge({ (ch.value): { family: ch.data.family|default(''), full: ch.data.fullDescription|default(''), name: ch.data.name|default('') } }) %}
        {% endif %}
    {% endfor %}
    <script type="application/json" id="cable-type-meta-json">{{ cable_type_meta|json_encode|raw }}</script>
    <script type="application/json" id="spool-cable-family-labels-json">{{ cable_family_labels_json|default('{}')|raw }}</script>
    <script type="application/json" id="spool-cable-ocr-api-json">{{ {
        matchUrl: path('warehouse_spool_cable_type_ocr_match'),
        stashUrl: path('warehouse_cable_type_ocr_prefill_stash'),
        newCableUrl: path('warehouse_cable_type_new'),
        csrfMatch: csrf_token('spool_cable_type_ocr_match'),
        csrfStash: csrf_token('cable_type_ocr_stash'),
    }|json_encode(256)|raw }}</script>
    {{ form_start(form, { attr: { class: 'spool-form', id: 'spool-new-form' } }) }}
        <div class="cable-type-hover-group" id="cable-type-hover-zone">
        <div class="spool-form__field spool-form__field--cable">
            <button type="button" class="spool-form__label-scan" id="spool-form-cable-ocr" title="OCR řádku se značením kabelu → výběr typu z katalogu nebo nový typ">
                {{- form.cableType.vars.label -}}
            </button>
            <div class="spool-form__value spool-form__value--cable">
                <div class="cable-type-mobile-picker" id="cable-type-mobile-picker">
                    <button type="button" class="cable-type-mobile-picker__toggle" id="cable-type-mobile-btn" aria-haspopup="listbox" aria-expanded="false" aria-controls="cable-type-mobile-panel">
                        <span class="cable-type-mobile-picker__text" id="cable-type-mobile-label">— vyberte typ —</span>
                        <span class="cable-type-mobile-picker__chev" aria-hidden="true">▼</span>
                    </button>
                    <div class="cable-type-mobile-picker__backdrop" id="cable-type-mobile-backdrop" hidden></div>
                    <div class="cable-type-mobile-picker__panel" id="cable-type-mobile-panel" role="dialog" aria-label="Typ kabelu" hidden>
                        <div class="cable-type-mobile-picker__bar">
                            <span class="cable-type-mobile-picker__title">Typ kabelu</span>
                            <button type="button" class="cable-type-mobile-picker__close" id="cable-type-mobile-close" aria-label="Zavřít">×</button>
                        </div>
                        <div class="cable-type-mobile-picker__scroller">
                            {{ form_widget(form.cableType, { attr: { 'aria-label': form.cableType.vars.label } }) }}
                        </div>
                        <div class="cable-type-mobile-picker__full-desc" id="cable-type-full-desc-in-panel" role="region" aria-label="Plný popis kabelu"></div>
                    </div>
                </div>
                {{ form_errors(form.cableType) }}
            </div>
        </div>
        <div class="spool-form__cable-full-desc-row" aria-live="polite">
            <div id="cable-type-full-desc" class="cable-type-full-desc" role="region" aria-label="Plný popis kabelu"></div>
        </div>
        </div>
        <div class="spool-form__field" id="spool-kabel-typ-row" aria-live="polite">
            {{ form_label(form.cableFamilyFilter) }}
            <div class="spool-form__value">
                {{ form_widget(form.cableFamilyFilter) }}
                <p class="spool-form__readout" id="spool-kabel-typ-readout" hidden>—</p>
                {{ form_errors(form.cableFamilyFilter) }}
            </div>
        </div>
        <div class="spool-form__field">
            <button type="button" class="spool-form__label-scan" id="spool-reel-barcode-scan" title="Skenovat čárový kód čísla saře">
                {{- form.reelNumber.vars.label -}}
            </button>
            <div class="spool-form__value">
                {{ form_widget(form.reelNumber, { attr: { 'aria-label': form.reelNumber.vars.label } }) }}
                {{ form_errors(form.reelNumber) }}
            </div>
        </div>
        <div class="spool-form__field">
            <button type="button" class="spool-form__label-scan" id="spool-length-barcode-scan" title="Skenovat čárový kód délky (m)">
                {{- form.totalLengthM.vars.label -}}
            </button>
            <div class="spool-form__value">
                {{ form_widget(form.totalLengthM, { attr: { 'aria-label': form.totalLengthM.vars.label } }) }}
                {{ form_errors(form.totalLengthM) }}
            </div>
        </div>
        <div class="spool-form__field">
            <button type="button" class="spool-form__label-scan" id="spool-ps-ocr-scan" title="OCR čísla PS (viditelných metrů) na štítku — bez čárového kódu">
                {{- form.initialVisibleM.vars.label -}}
            </button>
            <div class="spool-form__value">
                {{ form_widget(form.initialVisibleM, { attr: { 'aria-label': form.initialVisibleM.vars.label } }) }}
                {{ form_errors(form.initialVisibleM) }}
            </div>
        </div>
        <div class="spool-form__field">
            {{ form_label(form.fiberCount) }}
            <div class="spool-form__value">
                {{ form_widget(form.fiberCount) }}
                {{ form_errors(form.fiberCount) }}
            </div>
        </div>
        <div class="spool-form__field">
            {{ form_label(form.diameterMm) }}
            <div class="spool-form__value">
                {{ form_widget(form.diameterMm) }}
                {{ form_errors(form.diameterMm) }}
            </div>
        </div>
        <div class="spool-form__field">
            {{ form_label(form.status) }}
            <div class="spool-form__value">
                {{ form_widget(form.status) }}
                {{ form_errors(form.status) }}
            </div>
        </div>
        <div class="spool-form__field">
            {{ form_label(form.note) }}
            <div class="spool-form__value">
                {{ form_widget(form.note) }}
                {{ form_errors(form.note) }}
            </div>
        </div>
        <div class="spool-form__field">
            {{ form_label(form.registeredAt) }}
            <div class="spool-form__value">
                {{ form_widget(form.registeredAt) }}
                {{ form_errors(form.registeredAt) }}
            </div>
        </div>
        <div class="spool-form__field spool-form__row--actions" style="margin-top: 0.25rem; margin-bottom: 0.25rem;">
            <span class="spool-form__row--action-spacer" aria-hidden="true"></span>

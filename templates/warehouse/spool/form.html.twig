(function () {
  var cfgEl = document.getElementById('spool-reel-check-cfg');
  var cfg = {};
  try {
    cfg = cfgEl ? JSON.parse(cfgEl.textContent) : {};
  } catch (eCfg) {
    cfg = {};
  }
  var lookupUrl = cfg.lookupUrl;
  var reelIn = document.getElementById({{ form.reelNumber.vars.id|json_encode|raw }});
  if (!lookupUrl || !reelIn) return;

  var debT = null;
  var lastWarnedNorm = '';

  function norm(s) {
    return String(s || '').trim();
  }

  function checkReelDup() {
    var q = norm(reelIn.value);
    if (q.length < 1) return;
    var url;
    try {
      url = new URL(String(lookupUrl), window.location.origin);
    } catch (eUrl) {
      return;
    }
    url.searchParams.set('q', q);
    fetch(url.toString(), {
      credentials: 'same-origin',
      headers: { Accept: 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
    })
      .then(function (r) {
        var ct = (r.headers.get('content-type') || '').toLowerCase();
        if (ct.indexOf('application/json') === -1) return null;
        return r.json();
      })
      .then(function (j) {
        if (!j || !j.ok || !j.exists) return;
        var lk = norm(q).toLowerCase();
        if (lastWarnedNorm === lk) return;
        lastWarnedNorm = lk;
        var show = j.showUrl || '#';
        var rnMeta = j.reelNumber != null ? String(j.reelNumber) : q;
        var msg =
          'Cívka s číslem saře «' + rnMeta + '» je už evidována.\n\n' +
          'Druhou cívku se stejným číslem založit nelze — v databázi je číslo saře jedinečné (duplicitní záznam se neuloží).\n\n' +
          'Chcete otevřít kartu této cívky?';
        if (window.confirm(msg)) window.location.href = show;
      })
      .catch(function () {});
  }

  function scheduleCheck() {
    clearTimeout(debT);
    debT = setTimeout(checkReelDup, 480);
  }
  reelIn.addEventListener('input', function () {
    lastWarnedNorm = '';
    scheduleCheck();
  });
  reelIn.addEventListener('change', scheduleCheck);
  reelIn.addEventListener('blur', function () {
    clearTimeout(debT);
    checkReelDup();
  });
})();

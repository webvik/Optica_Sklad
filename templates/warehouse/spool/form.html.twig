{% extends 'base.html.twig' %}
{% block title %}{{ title }}{% endblock %}
{% block stylesheets %}
    {{ parent() }}
    <style>
        .spool-form { max-width: 40rem; line-height: 1.6; }
        .spool-form__field {
            display: grid;
            grid-template-columns: minmax(0, 8rem) minmax(0, 1fr);
            column-gap: 0.45rem;
            row-gap: 0.2rem;
            margin: 0 0 0.75rem;
            align-items: start;
        }
        .spool-form__field > label, .spool-form__field > .spool-form__static-label {
            font-weight: 600;
            font-size: 0.84rem;
            line-height: 1.25;
            padding-top: 0.28rem;
            word-break: break-word;
            hyphens: auto;
        }
        .spool-form__readout { margin: 0; font-size: 0.88rem; line-height: 1.35; color: #333; }
        .spool-form__value { min-width: 0; text-align: left; }
        .spool-form__value .form-error, .spool-form__value ul, .spool-form__value p.help-text { margin: 0.25rem 0 0; display: block; }
        .spool-form__value p.form-text, .spool-form__value p.help-text, .spool-form__value small { font-size: 0.85rem; line-height: 1.4; color: #555; text-align: left; }
        .spool-form__value [type="date"], .spool-form__value [type="number"],
        .spool-form__value [type="text"], .spool-form__value textarea, .spool-form__value select {
            max-width: 100%; box-sizing: border-box;
        }
        .spool-form__value input, .spool-form__value select, .spool-form__value textarea { text-align: left; width: 100%; }
        .spool-form__value select.cable-type-list { max-width: 100%; }
        @media (min-width: 42rem) {
            .spool-form__field { grid-template-columns: 12.5rem 1fr; column-gap: 1.5rem; margin-bottom: 0.9rem; }
            .spool-form__row--actions { grid-template-columns: 12.5rem 1fr; }
            .spool-form__field > label, .spool-form__field > .spool-form__static-label { font-size: 1.06rem; line-height: 1.45; padding-top: 0.2rem; }
            .spool-form__value > input, .spool-form__value > select, .spool-form__value > textarea { max-width: 24rem; margin-left: auto; display: block; }
            .spool-form__value p.form-text, .spool-form__value p.help-text { max-width: 24rem; margin-left: auto; }
            .spool-form__value--actions .spool-form__actions { max-width: 24rem; margin-left: auto; }
            .spool-form__value > ul, .spool-form__value .form-error { text-align: left; margin-left: auto; max-width: 24rem; }
        }
        @media (max-width: 41.99rem) {
            .spool-form__row--action-spacer { display: none !important; }
            .spool-form__row--actions .spool-form__value--actions { grid-column: 1 / -1; }
        }
        .spool-form__actions { display: flex; flex-direction: row; justify-content: space-between; align-items: center; gap: 0.65rem; flex-wrap: wrap; width: 100%; }
        @media (min-width: 42rem) {
            .spool-form__row--actions .spool-form__value--actions { width: 100%; }
        }
        .spool-form__btn, .spool-form__actions button[type="submit"] {
            box-sizing: border-box; display: inline-flex; align-items: center; justify-content: center;
            min-height: 2.55rem; min-width: 5.5rem; padding: 0.45rem 1rem; font: inherit; font-size: 1rem; font-weight: 500;
            line-height: 1.2; border: 1px solid #bbb; border-radius: 4px; background: #f5f5f5; color: #1a1a1a; cursor: pointer;
        }
        .spool-form__btn:hover, .spool-form__actions button[type="submit"]:hover { background: #eaeaec; }
        .spool-form__btn:active, .spool-form__actions button[type="submit"]:active { background: #e0e0e2; }
        .spool-form__row--action-spacer { display: none; }
        @media (min-width: 42rem) {
            .spool-form__row--action-spacer { display: block; min-height: 1px; }
        }
        #spool-form-scan-overlay[hidden] { display: none !important; }
        #spool-form-scan-overlay {
            position: fixed; inset: 0; z-index: 9999; background: rgba(0,0,0,.75);
            display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 1rem; padding: 1rem;
        }
        #spool-form-scan-video { max-width: min(100%, 640px); max-height: 50vh; background: #111; border-radius: 6px; }
        {% include 'warehouse/_cable_type_picker_core_styles.html.twig' %}
        @media (min-width: 42rem) {
            .spool-form__value--cable .cable-type-mobile-picker {
                max-width: 24rem;
                margin-left: auto;
            }
        }
        @media (min-width: 42rem) {
            .cable-type-mobile-picker--open .cable-type-mobile-picker__full-desc.has-content {
                max-height: min(20rem, 32vh);
            }
        }
        .cable-type-hover-group { max-width: 100%; }
        .spool-form__cable-full-desc-row {
            width: 100%;
            max-width: 100%;
            margin: -0.35rem 0 0.45rem;
            min-width: 0;
            box-sizing: border-box;
        }
        .cable-type-full-desc {
            display: none;
            width: 100%;
            max-width: 100%;
            box-sizing: border-box;
            font-size: 0.86rem; line-height: 1.45; color: #333;
            border: 1px solid #e0e0e0;
            border-left: 3px solid #bbb;
            padding: 0.45rem 0.6rem; margin: 0;
            text-align: left; background: #fafafa; border-radius: 4px; white-space: pre-wrap; word-break: break-word;
        }
        .cable-type-full-desc:empty { display: none !important; }
        .cable-type-hover-group:hover .cable-type-full-desc.has-content,
        .cable-type-hover-group:focus-within .cable-type-full-desc.has-content { display: block; }
        @media (hover: none), (pointer: coarse) {
            .cable-type-full-desc.has-content { display: block; }
        }
        /* Plný popis v okně: vždy viditelný, když je pikr otevřený a pro vybraný typ existuje text.
           (Nelze spoléhat na :hover na .panel — nad nativním <select> v některých prohlížečích se :hover nepropaguje a řádek mizel.) */
        .cable-type-mobile-picker__full-desc {
            display: none;
            flex-shrink: 0;
            width: 100%;
            min-width: 0;
            box-sizing: border-box;
            font-size: 0.86rem; line-height: 1.45; color: #333;
            border-top: 1px solid #e0e0e0;
            border-left: 3px solid #bbb;
            margin: 0;
            padding: 0.45rem 0.6rem 0.55rem;
            text-align: left;
            background: #f8f8f8;
            white-space: pre-wrap;
            word-break: break-word;
            max-height: min(9rem, 32vh);
            overflow: auto;
            -webkit-overflow-scrolling: touch;
        }
        .cable-type-mobile-picker__full-desc:empty { display: none !important; }
        .cable-type-mobile-picker--open .cable-type-mobile-picker__full-desc.has-content {
            display: block;
        }
        .spool-cable-family-filter[hidden] { display: none !important; }
    </style>
{% endblock %}
{% block body %}
    {% include '_app_menu_cz.html.twig' %}
    <h1>{{ title }}</h1>
    {% set cable_type_meta = {} %}
    {% for ch in form.cableType.vars.choices|default([]) %}
        {% if ch.data is defined and ch.data %}
            {% set cable_type_meta = cable_type_meta|merge({ (ch.value): { family: ch.data.family|default(''), full: ch.data.fullDescription|default(''), name: ch.data.name|default('') } }) %}
        {% endif %}
    {% endfor %}
    <script type="application/json" id="cable-type-meta-json">{{ cable_type_meta|json_encode|raw }}</script>
    <script type="application/json" id="spool-cable-family-labels-json">{{ cable_family_labels_json|default('{}')|raw }}</script>
    {{ form_start(form, { attr: { class: 'spool-form', id: 'spool-new-form' } }) }}
        <div class="cable-type-hover-group" id="cable-type-hover-zone">
        <div class="spool-form__field spool-form__field--cable">
            {{ form_label(form.cableType) }}
            <div class="spool-form__value spool-form__value--cable">
                <div class="cable-type-mobile-picker" id="cable-type-mobile-picker">
                    <button type="button" class="cable-type-mobile-picker__toggle" id="cable-type-mobile-btn" aria-haspopup="listbox" aria-expanded="false" aria-controls="cable-type-mobile-panel">
                        <span class="cable-type-mobile-picker__text" id="cable-type-mobile-label">— vyberte typ —</span>
                        <span class="cable-type-mobile-picker__chev" aria-hidden="true">▼</span>
                    </button>
                    <div class="cable-type-mobile-picker__backdrop" id="cable-type-mobile-backdrop" hidden></div>
                    <div class="cable-type-mobile-picker__panel" id="cable-type-mobile-panel" role="dialog" aria-label="Typ kabelu" hidden>
                        <div class="cable-type-mobile-picker__bar">
                            <span class="cable-type-mobile-picker__title">Typ kabelu</span>
                            <button type="button" class="cable-type-mobile-picker__close" id="cable-type-mobile-close" aria-label="Zavřít">×</button>
                        </div>
                        <div class="cable-type-mobile-picker__scroller">
                            {{ form_widget(form.cableType) }}
                        </div>
                        <div class="cable-type-mobile-picker__full-desc" id="cable-type-full-desc-in-panel" role="region" aria-label="Plný popis kabelu"></div>
                    </div>
                </div>
                {{ form_errors(form.cableType) }}
            </div>
        </div>
        <div class="spool-form__cable-full-desc-row" aria-live="polite">
            <div id="cable-type-full-desc" class="cable-type-full-desc" role="region" aria-label="Plný popis kabelu"></div>
        </div>
        </div>
        <div class="spool-form__field" id="spool-kabel-typ-row" aria-live="polite">
            {{ form_label(form.cableFamilyFilter) }}
            <div class="spool-form__value">
                {{ form_widget(form.cableFamilyFilter) }}
                <p class="spool-form__readout" id="spool-kabel-typ-readout" hidden>—</p>
                {{ form_errors(form.cableFamilyFilter) }}
            </div>
        </div>
        <div class="spool-form__field">
            {{ form_label(form.reelNumber) }}
            <div class="spool-form__value">
                {{ form_widget(form.reelNumber) }}
                {{ form_errors(form.reelNumber) }}
            </div>
        </div>
        <div class="spool-form__field">
            {{ form_label(form.totalLengthM) }}
            <div class="spool-form__value">
                {{ form_widget(form.totalLengthM) }}
                {{ form_errors(form.totalLengthM) }}
            </div>
        </div>
        <div class="spool-form__field">
            {{ form_label(form.initialVisibleM) }}
            <div class="spool-form__value">
                {{ form_widget(form.initialVisibleM) }}
                {{ form_errors(form.initialVisibleM) }}
            </div>
        </div>
        <div class="spool-form__field">
            {{ form_label(form.fiberCount) }}
            <div class="spool-form__value">
                {{ form_widget(form.fiberCount) }}
                {{ form_errors(form.fiberCount) }}
            </div>
        </div>
        <div class="spool-form__field">
            {{ form_label(form.diameterMm) }}
            <div class="spool-form__value">
                {{ form_widget(form.diameterMm) }}
                {{ form_errors(form.diameterMm) }}
            </div>
        </div>
        <div class="spool-form__field">
            {{ form_label(form.status) }}
            <div class="spool-form__value">
                {{ form_widget(form.status) }}
                {{ form_errors(form.status) }}
            </div>
        </div>
        <div class="spool-form__field">
            {{ form_label(form.note) }}
            <div class="spool-form__value">
                {{ form_widget(form.note) }}
                {{ form_errors(form.note) }}
            </div>
        </div>
        <div class="spool-form__field">
            {{ form_label(form.registeredAt) }}
            <div class="spool-form__value">
                {{ form_widget(form.registeredAt) }}
                {{ form_errors(form.registeredAt) }}
            </div>
        </div>
        <div class="spool-form__field spool-form__row--actions" style="margin-top: 0.25rem; margin-bottom: 0.25rem;">
            <span class="spool-form__row--action-spacer" aria-hidden="true"></span>
            <div class="spool-form__value spool-form__value--actions">
                <div class="spool-form__actions" role="group" aria-label="Akce">
                    <button type="button" class="spool-form__btn" id="spool-form-scan" title="Sken kódu saře do pole Číslo saře">Sken</button>
                    <button type="submit" class="spool-form__btn">Uložit</button>
                </div>
            </div>
        </div>
        {{ form_rest(form) }}
    {{ form_end(form, { render_rest: false }) }}

    <div id="spool-form-scan-overlay" hidden role="dialog" aria-label="Sken čárového kódu">
        <p id="spool-form-scan-overlay-text" style="color:#fff;margin:0;text-align:center;max-width:34rem"></p>
        <video id="spool-form-scan-video" playsinline autoplay muted></video>
        <button type="button" id="spool-form-scan-cancel" class="spool-form__btn" style="color:#1a1a1a">Zrušit</button>
    </div>
    <div style="max-width: 40rem; margin: 0 auto; box-sizing: border-box;">
        <p style="margin: 0.85rem 0 0.35rem; display: flex; flex-wrap: wrap; gap: 0.65rem; align-items: center; justify-content: center;">
            <a class="warehouse-pill" href="{{ path('warehouse_cable_type_new') }}">Nový typ kabelu v katalogu</a>
        </p>
        <p style="margin: 0; text-align: center;"><a href="{{ path('warehouse_spool_index') }}">← zpět na seznam</a></p>
    </div>
{% endblock %}
{% block javascripts %}
    {{ parent() }}
    <script>
(function () {
  var reelIn = document.getElementById({{ form.reelNumber.vars.id|json_encode|raw }});
  var scanBtn = document.getElementById('spool-form-scan');
  var scanOverlay = document.getElementById('spool-form-scan-overlay');
  var scanVideo = document.getElementById('spool-form-scan-video');
  var scanCancel = document.getElementById('spool-form-scan-cancel');
  var scanOverlayText = document.getElementById('spool-form-scan-overlay-text');
  var scanRaf = null, scanStream = null;
  function setScanText() {
    if (scanOverlayText) {
      scanOverlayText.textContent = 'Sken saře: po rozpoznání se vyplní pole Číslo saře (případně doplňte a uložte).';
    }
  }
  function stopBarcodeScan() {
    if (scanRaf) { cancelAnimationFrame(scanRaf); scanRaf = null; }
    if (scanStream) {
      scanStream.getTracks().forEach(function (t) { t.stop(); });
      scanStream = null;
    }
    if (scanVideo) scanVideo.srcObject = null;
    if (scanOverlay) scanOverlay.hidden = true;
  }
  function focusSare() {
    if (reelIn) {
      reelIn.focus();
      try { reelIn.select(); } catch (e) {}
    }
  }
  function onScanDecoded(v) {
    v = String(v).trim();
    if (!v.length) return;
    stopBarcodeScan();
    if (reelIn) reelIn.value = v;
  }
  function startBarcodeScan() {
    if (!scanOverlay || !scanVideo) { focusSare(); return; }
    setScanText();
    scanOverlay.hidden = false;
    navigator.mediaDevices.getUserMedia({ video: { facingMode: { ideal: 'environment' } } })
      .then(function (stream) {
        scanStream = stream;
        scanVideo.srcObject = stream;
        return scanVideo.play();
      })
      .then(function () {
        if (typeof window.BarcodeDetector === 'undefined') {
          stopBarcodeScan();
          focusSare();
          return;
        }
        var detector = new window.BarcodeDetector({ formats: ['code_128', 'code_39', 'code_93', 'ean_13', 'qr_code', 'itf', 'data_matrix'] });
        function tick() {
          if (!scanVideo || scanStream === null) return;
          if (scanVideo.readyState < 2) {
            scanRaf = requestAnimationFrame(tick);
            return;
          }
          detector.detect(scanVideo).then(function (codes) {
            if (codes && codes.length && codes[0].rawValue) {
              onScanDecoded(codes[0].rawValue);
              return;
            }
            scanRaf = requestAnimationFrame(tick);
          }).catch(function () { scanRaf = requestAnimationFrame(tick); });
        }
        scanRaf = requestAnimationFrame(tick);
      })
      .catch(function () {
        stopBarcodeScan();
        focusSare();
      });
  }
  if (scanBtn) {
    scanBtn.addEventListener('click', function () {
      if (typeof window.BarcodeDetector !== 'undefined') startBarcodeScan();
      else focusSare();
    });
  }
  if (scanCancel) scanCancel.addEventListener('click', function () { stopBarcodeScan(); });
  document.addEventListener('keydown', function (ev) {
    if (ev.key === 'Escape' && scanOverlay && !scanOverlay.hidden) { ev.preventDefault(); stopBarcodeScan(); }
  });
})();
(function () {
  var mq = window.matchMedia('(max-width: 41.99rem)');
  var root = document.getElementById('cable-type-mobile-picker');
  if (!root) return;
  var btn = document.getElementById('cable-type-mobile-btn');
  var labelEl = document.getElementById('cable-type-mobile-label');
  var panel = document.getElementById('cable-type-mobile-panel');
  var backdrop = document.getElementById('cable-type-mobile-backdrop');
  var closeBtn = document.getElementById('cable-type-mobile-close');
  var sel = root.querySelector('select.cable-type-list');
  if (!sel) return;
  var PLH = '— vyberte typ —';
  function syncLabel() {
    if (!labelEl) return;
    var i = sel.selectedIndex;
    var opt = sel.options[i];
    if (opt && opt.value !== '') { labelEl.textContent = opt.text; }
    else { labelEl.textContent = PLH; }
  }
  function openPanel() {
    if (!panel) return;
    if (sel.options.length) {
      var n = Math.min(28, Math.max(8, sel.options.length));
      sel.setAttribute('size', String(n));
    }
    root.classList.add('cable-type-mobile-picker--open');
    panel.removeAttribute('hidden');
    if (backdrop) backdrop.removeAttribute('hidden');
    document.body.classList.add('spool-cable-panel-open');
    if (btn) { btn.setAttribute('aria-expanded', 'true'); }
    if (typeof window.spoolFormSyncSpoolKabelBlock === 'function') {
      window.spoolFormSyncSpoolKabelBlock();
    }
    try { sel.focus(); } catch (e) {}
    requestAnimationFrame(function () {
      requestAnimationFrame(function () {
        if (typeof window.spoolFormScheduleCableTypeListbox === 'function') {
          window.spoolFormScheduleCableTypeListbox();
        }
      });
    });
  }
  function closePanel() {
    if (!panel) return;
    root.classList.remove('cable-type-mobile-picker--open');
    panel.setAttribute('hidden', '');
    if (backdrop) backdrop.setAttribute('hidden', '');
    document.body.classList.remove('spool-cable-panel-open');
    if (btn) { btn.setAttribute('aria-expanded', 'false'); try { btn.focus(); } catch (e) {} }
  }
  function syncAll() {
    syncLabel();
    if (typeof window.spoolFormSyncSpoolKabelBlock === 'function') { window.spoolFormSyncSpoolKabelBlock(); }
  }
  if (btn) {
    btn.addEventListener('click', function (ev) {
      ev.preventDefault();
      if (panel && panel.hasAttribute('hidden')) { openPanel(); }
    });
  }
  if (closeBtn) closeBtn.addEventListener('click', function () { closePanel(); });
  if (backdrop) {
    backdrop.addEventListener('click', function () { closePanel(); });
  }
  sel.addEventListener('change', function () {
    syncAll();
    if (!panel.hasAttribute('hidden')) { closePanel(); }
  });
  document.addEventListener('keydown', function (ev) {
    if (ev.key !== 'Escape' || !panel || panel.hasAttribute('hidden')) return;
    ev.preventDefault();
    closePanel();
  });
  function mqChange() {
    syncAll();
    if (!panel.hasAttribute('hidden') && typeof window.spoolFormScheduleCableTypeListbox === 'function') {
      window.spoolFormScheduleCableTypeListbox();
    }
  }
  if (mq.addEventListener) mq.addEventListener('change', mqChange);
  else if (mq.addListener) mq.addListener(mqChange);
  window.addEventListener('pageshow', syncAll);
  syncAll();
})();
(function () {
  var cableSel = document.getElementById({{ form.cableType.vars.id|json_encode|raw }});
  if (!cableSel) return;
  var fiberCountIn = document.getElementById({{ form.fiberCount.vars.id|json_encode|raw }});
  var diameterMmIn = document.getElementById({{ form.diameterMm.vars.id|json_encode|raw }});
  var famSel = document.getElementById({{ form.cableFamilyFilter.vars.id|json_encode|raw }});
  var readout = document.getElementById('spool-kabel-typ-readout');
  var metaEl = document.getElementById('cable-type-meta-json');
  var labelsEl = document.getElementById('spool-cable-family-labels-json');
  var desc = document.getElementById('cable-type-full-desc');
  var descInPanel = document.getElementById('cable-type-full-desc-in-panel');
  var meta = {};
  var familyLabels = {};
  var scroller = cableSel.closest('.cable-type-mobile-picker__scroller');
  var mobileMq = window.matchMedia('(max-width: 41.99rem)');
  var sizeListT = null;
  try { if (metaEl && metaEl.textContent) { meta = JSON.parse(metaEl.textContent); } } catch (e) {}
  try { if (labelsEl && labelsEl.textContent) { familyLabels = JSON.parse(labelsEl.textContent); } } catch (e) {}
  /**
   * Nativní listbox (size>1) skoro nikde nerozšiřuje šířku podle nejdelší option — max-content nefunguje.
   * Změříme texty a nastavíme širší <select>, aby roloval rodič .cable-type-mobile-picker__scroller.
   */
  function sizeCableTypeListbox() {
    if (!scroller) return;
    var measure = document.createElement('div');
    measure.setAttribute('aria-hidden', 'true');
    measure.style.cssText = 'position:absolute;left:-9999px;top:0;white-space:nowrap;visibility:hidden;pointer-events:none;';
    var cs = window.getComputedStyle(cableSel);
    measure.style.font = cs.font;
    measure.style.letterSpacing = cs.letterSpacing;
    measure.style.textTransform = cs.textTransform;
    document.body.appendChild(measure);
    var maxW = 0;
    var k;
    for (k = 0; k < cableSel.options.length; k++) {
      measure.textContent = cableSel.options[k].text || ' ';
      maxW = Math.max(maxW, measure.offsetWidth);
    }
    document.body.removeChild(measure);
    var pad = mobileMq.matches ? 40 : 36;
    var cw = scroller.clientWidth;
    if (cw < 2) {
      cw = mobileMq.matches ? (window.innerWidth || 400) : 300;
    }
    var need = Math.max(cw, maxW + pad);
    cableSel.style.minWidth = need + 'px';
    cableSel.style.width = need + 'px';
  }
  function scheduleSizeCableTypeListbox() {
    if (sizeListT) { clearTimeout(sizeListT); }
    sizeListT = setTimeout(function () {
      sizeListT = null;
      sizeCableTypeListbox();
    }, 50);
  }
  window.spoolFormScheduleCableTypeListbox = scheduleSizeCableTypeListbox;
  function optionFamily(opt) {
    if (!opt || opt.value === '') return '';
    if (opt.dataset && opt.dataset.family) return String(opt.dataset.family);
    var a = opt.getAttribute('data-family');
    return a ? String(a) : '';
  }
  function applyFamilyFilter() {
    if (!famSel || !cableSel) return;
    var want = (famSel.value && String(famSel.value).length) ? String(famSel.value) : '';
    var opts = cableSel.querySelectorAll('option');
    for (var i = 0; i < opts.length; i++) {
      var o = opts[i];
      if (!o.value) { o.hidden = false; continue; }
      var fam = optionFamily(o);
      o.hidden = (want !== '' && fam !== want);
    }
    if (cableSel.value) {
      var cur = getCableTypeOption();
      if (cur && (cur.value === '' || cur.hidden)) {
        cableSel.value = '';
        try { cableSel.dispatchEvent(new Event('change', { bubbles: true })); } catch (e) {}
      }
    }
  }
  /**
   * Plný text bereme z <option> (data b64) — to je ta samá věc v DOM jako název řádku, žádný mapování z JSON.
   */
  function b64ToUtf8(b64) {
    if (b64 == null || b64 === '') {
      return '';
    }
    try {
      b64 = String(b64).replace(/\s/g, '');
      if (!b64.length) {
        return '';
      }
      var bin = atob(b64);
      if (typeof TextDecoder !== 'undefined') {
        var a = new Uint8Array(bin.length);
        for (var u = 0; u < bin.length; u++) {
          a[u] = bin.charCodeAt(u);
        }
        return new TextDecoder('utf-8').decode(a);
      }
      return decodeURIComponent(escape(bin));
    } catch (e) {
      return '';
    }
  }
  /**
   * U listboxu může selectedIndex o pár míst dál od řádku odpovídajícího cableSel.value
   * (o hlášeném „+2“). Vždy bereme <option> podle aktuálního value / selectedOptions[0].
   */
  function getCableTypeOption() {
    var v = String(cableSel.value || '');
    if (!v) {
      return null;
    }
    if (cableSel.selectedOptions && cableSel.selectedOptions[0] && String(cableSel.selectedOptions[0].value) === v) {
      return cableSel.selectedOptions[0];
    }
    var oi;
    for (oi = 0; oi < cableSel.options.length; oi++) {
      if (String(cableSel.options[oi].value) === v) {
        return cableSel.options[oi];
      }
    }
    if (cableSel.selectedIndex >= 0) {
      return cableSel.options[cableSel.selectedIndex] || null;
    }
    return null;
  }
  function applySpoolFieldsFromCableType() {
    var opt = getCableTypeOption();
    if (!opt) {
      return;
    }
    if (fiberCountIn) {
      var f = (opt.getAttribute('data-fiber-count') != null) ? String(opt.getAttribute('data-fiber-count')).trim() : '';
      if (f !== '') {
        fiberCountIn.value = f;
      }
    }
    if (diameterMmIn) {
      var d = (opt.getAttribute('data-diameter-mm') != null) ? String(opt.getAttribute('data-diameter-mm')).trim() : '';
      if (d !== '') {
        diameterMmIn.value = d;
      }
    }
  }
  function setDesc() {
    function clearDescPair() {
      if (desc) {
        desc.textContent = '';
        desc.classList.remove('has-content');
      }
      if (descInPanel) {
        descInPanel.textContent = '';
        descInPanel.classList.remove('has-content');
      }
    }
    if (!desc && !descInPanel) {
      return;
    }
    clearDescPair();
    var opt = getCableTypeOption();
    if (!opt) {
      return;
    }
    var val = String(opt.value || '');
    if (!val) {
      return;
    }
    var t = b64ToUtf8(opt.getAttribute('data-b64-cable-full')).trim();
    if (!t.length) {
      var nm = opt.getAttribute('data-cable-name');
      if (nm) {
        t = String(nm).trim();
      }
    }
    if (!t.length) {
      var m = meta[val];
      if (m == null) {
        m = meta[Number(val)];
      }
      t = m && m.full != null ? String(m.full) : '';
      t = t.trim();
      if (!t.length && m && m.name) {
        t = String(m.name).trim();
      }
    }
    if (!t.length) {
      return;
    }
    if (desc) {
      desc.textContent = t;
      desc.classList.add('has-content');
    }
    if (descInPanel) {
      descInPanel.textContent = t;
      descInPanel.classList.add('has-content');
    }
  }
  function syncKabelTyp() {
    if (!readout) return;
    if (cableSel.value) {
      if (famSel) { famSel.setAttribute('hidden', ''); }
      var opt = getCableTypeOption();
      var code = optionFamily(opt);
      var label = (code && familyLabels[code]) ? familyLabels[code] : (code || '—');
      readout.textContent = label;
      readout.removeAttribute('hidden');
    } else {
      if (famSel) { famSel.removeAttribute('hidden'); }
      readout.setAttribute('hidden', '');
    }
  }
  function syncAllBlock() {
    applyFamilyFilter();
    syncKabelTyp();
    setDesc();
    requestAnimationFrame(function () {
      sizeCableTypeListbox();
    });
  }
  window.spoolFormSyncSpoolKabelBlock = syncAllBlock;
  if (famSel) famSel.addEventListener('change', syncAllBlock);
  function onCableTypeUserPicked() {
    applySpoolFieldsFromCableType();
    syncAllBlock();
  }
  cableSel.addEventListener('change', onCableTypeUserPicked);
  cableSel.addEventListener('input', onCableTypeUserPicked);
  window.addEventListener('resize', scheduleSizeCableTypeListbox);
  if (mobileMq.addEventListener) {
    mobileMq.addEventListener('change', function () { scheduleSizeCableTypeListbox(); });
  } else if (mobileMq.addListener) {
    mobileMq.addListener(function () { scheduleSizeCableTypeListbox(); });
  }
  if (document.fonts && document.fonts.ready) {
    document.fonts.ready.then(function () { scheduleSizeCableTypeListbox(); });
  }
  syncAllBlock();
})();
    </script>

      applyHintPs();
      if (!psIn) return;
      setCableOcrEditorVisible(false);
    }
    if (typeof window.Tesseract === 'undefined' || typeof window.Tesseract.createWorker !== 'function') {
      window.alert('Biblioteka OCR se nenačetla.');
      return;
    }
    overlay.hidden = false;
    navigator.mediaDevices
      .getUserMedia({ video: { facingMode: { ideal: 'environment' } } })
      .then(function (stream) {
        scanStream = stream;
        ocrVideo.srcObject = stream;
        return ocrVideo.play();
      })
      .then(function () {
        ocrBusy = false;
        setCableCaptureUiBusy(false);
        ensureWorker();
      })
      .catch(function () {
        overlay.hidden = true;
        window.alert('Kamera není dostupná.');
      });
  }

  function dismissChoiceStayOnDraft() {
    hideCableChoiceModal();
    applyHintCable();
  }

  if (cableMatchBtn) {
    cableMatchBtn.addEventListener('click', submitCableDraftForMatch);
  }
  if (choiceBackdrop) {
    choiceBackdrop.addEventListener('click', dismissChoiceStayOnDraft);
  }
  if (choiceBackBtn) {
    choiceBackBtn.addEventListener('click', dismissChoiceStayOnDraft);
  }
  if (choicePickBtn) {
    choicePickBtn.addEventListener('click', function () {
      var ct = pendingPickCableType;
      if (!ct || ct.id == null) return;
      hideCableChoiceModal();
      stopCableOcr();
      terminateTessLocal();
      applyCableFromMatch(ct);
    });
  }
  if (choiceNewBtn) {
    choiceNewBtn.addEventListener('click', function () {
      tryStashDraftAndGoToNewCableForm();
    });
  }
  if (cableDirectNewBtn) {
    cableDirectNewBtn.addEventListener('click', function () {
      tryStashDraftAndGoToNewCableForm();
    });
  }

  if (cableCaptureBtn) {
    cableCaptureBtn.addEventListener('click', function () {
      performCableOcrSnap();
    });
  }

  if (ocrBtn) {
    ocrBtn.addEventListener('click', function () {
      openOcr('cable');
    });
  }
  if (psOcrBtn) {
    psOcrBtn.addEventListener('click', function () {
      openOcr('ps');
    });
  }
  if (ocrCancel) {
    ocrCancel.addEventListener('click', function () {
      stopCableOcr();
      terminateTessLocal();
    });
  }
  document.addEventListener('keydown', function (ev) {
    if (ev.key !== 'Escape' || !overlay || overlay.hidden) return;
    ev.preventDefault();
    if (choiceModal && choiceModal.hidden === false) {
      dismissChoiceStayOnDraft();
      return;
    }
    stopCableOcr();
    terminateTessLocal();
  });

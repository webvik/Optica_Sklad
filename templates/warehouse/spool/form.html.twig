    <script crossorigin referrerpolicy="no-referrer" src="https://cdn.jsdelivr.net/npm/tesseract.js@5/dist/tesseract.min.js"></script>
    <script>
(function () {
  var reelIn = document.getElementById({{ form.reelNumber.vars.id|json_encode|raw }});
  var lengthIn = document.getElementById({{ form.totalLengthM.vars.id|json_encode|raw }});
  var reelScanBtn = document.getElementById('spool-reel-barcode-scan');
  var lengthScanBtn = document.getElementById('spool-length-barcode-scan');
  var scanOverlay = document.getElementById('spool-form-scan-overlay');
  var scanVideo = document.getElementById('spool-form-scan-video');
  var scanCancel = document.getElementById('spool-form-scan-cancel');
  var scanOverlayText = document.getElementById('spool-form-scan-overlay-text');
  var scanRaf = null;
  var scanStream = null;
  var scanCropCanvas = null;
  /** @type {'reel'|'length'} */
  var scanTarget = 'reel';
  /** Sladěno se sareStripFrac u work-scan (spool/index) */
  var SPOOL_BC_STRIP_FRAC = 0.17;
  /** Úzké lineární formáty → po ms rozšíření o EAN/UPC/Codabar (viz WORK_SARE_SCAN_PHASE2_AFTER_MS) */
  var SPOOL_BC_PHASE2_AFTER_MS = 900;

  /** Heuristika 1–4 číslice = délka (m) jako u vyhledávání — pro sařu přeskakovat, pro délku preferovat */
  function longestDigitRun(s) {
    var m = String(s || '').match(/\d+/g);
    if (!m || !m.length) return '';
    return m.reduce(function (a, b) { return b.length > a.length ? b : a; }, '');
  }
  /** Stejně jako work-scan sareDetectionRaw */
  function sareDetectionRaw(det) {
    if (!det || typeof det !== 'object') return '';
    var r = det.rawValue;
    if (r == null || r === '') r = det.value;
    return String(r == null ? '' : r).trim();
  }
  function sareDecodedLooksLikeCableLengthMeters(raw) {
    var s = String(raw == null ? '' : raw).trim();
    return /^\d{1,4}$/.test(s);
  }
  /** Stejné chování jako pickSareBarcodeFromDetections ve vyhledávání */
  function pickSareBarcodeFromDetections(codes) {
    if (!codes || !codes.length) return '';
    for (var i = 0; i < codes.length; i++) {
      var rv = sareDetectionRaw(codes[i]);
      if (!rv.length) continue;
      if (!sareDecodedLooksLikeCableLengthMeters(rv)) return rv;
    }
    return '';
  }
  /** Inverze: nejdřív krátké čisté číslo (délka), pak dřívější logika „nejdelší číslice“ */
  function pickLengthBarcodeFromDetections(codes) {
    if (!codes || !codes.length) return '';
    var i, rv, run, pure = [];
    for (i = 0; i < codes.length; i++) {
      rv = sareDetectionRaw(codes[i]);
      if (rv.length && sareDecodedLooksLikeCableLengthMeters(rv)) return rv;
    }
    for (i = 0; i < codes.length; i++) {
      rv = sareDetectionRaw(codes[i]);
      if (!rv.length) continue;
      if (/^\d+$/.test(rv)) pure.push(rv);
    }
    if (pure.length) {
      return pure.reduce(function (a, b) { return b.length > a.length ? b : a; });
    }
    var bestRun = '';
    for (i = 0; i < codes.length; i++) {
      rv = sareDetectionRaw(codes[i]);
      run = longestDigitRun(rv);
      if (run.length > bestRun.length) bestRun = run;
    }
    return bestRun || sareDetectionRaw(codes[0]);
  }
  function pickDecodedRaw(codes) {
    if (!codes) codes = [];
    if (scanTarget === 'reel') return pickSareBarcodeFromDetections(codes);
    return pickLengthBarcodeFromDetections(codes);
  }
  function normalizeLengthBarcode(raw) {
    var run = longestDigitRun(raw);
    if (!run.length) return '';
    var n = parseInt(run, 10);
    return isFinite(n) && n >= 0 ? String(n) : '';
  }
  function setScanText() {
    if (scanOverlayText) {
      scanOverlayText.textContent =
        scanTarget === 'length'
          ? 'Sken délky: úzký pruh nad kódem (jako vyhledávání). Nejprve hodnoty 1–4 číslice = metry; zkontrolujte pole.'
          : 'Sken čísla saře: úzký pruh nad čárovým kódem (jako při Hledat). Hodnoty 1–4 číslice z vedlejšího kódu se přeskakují; zkontrolujte pole.';
    }
  }
  function stopBarcodeScan() {
    if (scanRaf) {
      try { cancelAnimationFrame(scanRaf); } catch (eR) {}
      scanRaf = null;
    }
    if (scanStream) {
      scanStream.getTracks().forEach(function (t) { t.stop(); });
      scanStream = null;
    }
    if (scanVideo) scanVideo.srcObject = null;
    if (scanOverlay) scanOverlay.hidden = true;
  }
  function focusSare() {
    if (reelIn) {
      reelIn.focus();
      try { reelIn.select(); } catch (e) {}
    }
  }
  function focusLength() {
    if (lengthIn) {
      lengthIn.focus();
      try { lengthIn.select(); } catch (e1) {}
    }
  }
  function focusScanTargetField() {
    if (scanTarget === 'length') focusLength();
    else focusSare();
  }
  function onScanDecoded(v) {
    v = String(v).trim();
    if (!v.length) return;
    stopBarcodeScan();
    if (scanTarget === 'length') {
      if (lengthIn) {
        var n = normalizeLengthBarcode(v);
        lengthIn.value = n || v;
      }
    } else if (reelIn) {
      reelIn.value = v;
    }
  }
  function getCropCanvasEl() {
    if (!scanCropCanvas) scanCropCanvas = document.createElement('canvas');
    return scanCropCanvas;
  }
  function trySpoolLinearDetector(formats) {
    var f = formats.slice();
    try {
      return new window.BarcodeDetector({ formats: f });
    } catch (e1) {
      var core = ['code_128', 'code_39', 'code_93', 'itf', 'ean_13', 'ean_8', 'upc_a', 'upc_e', 'codabar'];
      var slim = f.filter(function (x) { return core.indexOf(x) >= 0; });
      try {
        if (slim.length) return new window.BarcodeDetector({ formats: slim });
      } catch (e2) { /* fall through */ }
      try {
        return new window.BarcodeDetector({ formats: ['code_128', 'code_39', 'itf'] });
      } catch (e3) {
        return new window.BarcodeDetector();
      }
    }
  }
  function makeSpoolBarcodeDetector(wideTier) {
    var narrowLin = ['code_128', 'code_39', 'code_93', 'itf'];
    var extraLin = ['ean_13', 'ean_8', 'upc_a', 'upc_e', 'codabar'];
    var fmts = wideTier ? narrowLin.concat(extraLin) : narrowLin.slice();
    return trySpoolLinearDetector(fmts);
  }
  function startBarcodeScan() {
    if (!scanOverlay || !scanVideo) { focusScanTargetField(); return; }
    setScanText();
    scanOverlay.hidden = false;
    var phase2Immediate = SPOOL_BC_PHASE2_AFTER_MS <= 0;
    var spoolFmtTier = phase2Immediate ? 1 : 0;
    var spoolScanOpenedAtMs = typeof performance !== 'undefined' ? performance.now() : 0;
    var detector = makeSpoolBarcodeDetector(spoolFmtTier === 1);

    navigator.mediaDevices.getUserMedia({ video: { facingMode: { ideal: 'environment' } } })
      .then(function (stream) {
        scanStream = stream;
        scanVideo.srcObject = stream;
        return scanVideo.play();
      })
      .then(function () {
        if (typeof window.BarcodeDetector === 'undefined') {
          stopBarcodeScan();
          focusScanTargetField();
          return;
        }
        function maybeEscalateSpoolFormats() {
          if (spoolFmtTier !== 0) return;
          if (!Number.isFinite(SPOOL_BC_PHASE2_AFTER_MS) || SPOOL_BC_PHASE2_AFTER_MS <= 0) return;
          if (performance.now() - spoolScanOpenedAtMs < SPOOL_BC_PHASE2_AFTER_MS) return;
          spoolFmtTier = 1;
          detector = makeSpoolBarcodeDetector(true);
        }
        function tick() {
          if (!scanVideo || scanStream === null) return;
          if (scanVideo.readyState < 2) {
            scanRaf = requestAnimationFrame(tick);
            return;
          }
          maybeEscalateSpoolFormats();
          var vw = scanVideo.videoWidth;
          var vh = scanVideo.videoHeight;
          if (vw < 2 || vh < 2) {
            scanRaf = requestAnimationFrame(tick);
            return;
          }
          var sh = Math.max(12, Math.round(vh * SPOOL_BC_STRIP_FRAC));
          var sy = Math.round((vh - sh) / 2);
          var cw = Math.min(720, vw);
          var ch = Math.max(12, Math.round(sh * (cw / vw)));
          var canv = getCropCanvasEl();
          if (canv.width !== cw || canv.height !== ch) {
            canv.width = cw;
            canv.height = ch;
          }
          var ctx = canv.getContext('2d');
          ctx.drawImage(scanVideo, 0, sy, vw, sh, 0, 0, cw, ch);
          if (!detector || typeof detector.detect !== 'function') {
            scanRaf = requestAnimationFrame(tick);
            return;
          }
          detector.detect(canv).then(function (codes) {
            if (!codes) codes = [];
            var raw = pickDecodedRaw(codes);
            if (raw) {
              onScanDecoded(raw);
              return;
            }
            scanRaf = requestAnimationFrame(tick);
          }).catch(function () { scanRaf = requestAnimationFrame(tick); });
        }
        scanRaf = requestAnimationFrame(tick);
      })
      .catch(function () {
        stopBarcodeScan();
        focusScanTargetField();
      });
  }
  function wireScanButton(btn, target) {
    if (!btn) return;
    btn.addEventListener('click', function () {
      scanTarget = target;
      if (typeof window.BarcodeDetector !== 'undefined') startBarcodeScan();
      else focusScanTargetField();
    });
  }
  wireScanButton(reelScanBtn, 'reel');
  wireScanButton(lengthScanBtn, 'length');
  if (scanCancel) scanCancel.addEventListener('click', function () { stopBarcodeScan(); });
  document.addEventListener('keydown', function (ev) {
    if (ev.key === 'Escape' && scanOverlay && !scanOverlay.hidden) { ev.preventDefault(); stopBarcodeScan(); }
  });
})();
(function () {
  var cfgEl = document.getElementById('spool-cable-ocr-api-json');
  var cfg = {};
  try { cfg = cfgEl ? JSON.parse(cfgEl.textContent) : {}; } catch (eCf) {}

  var ocrBtn = document.getElementById('spool-form-cable-ocr');
  var psOcrBtn = document.getElementById('spool-ps-ocr-scan');
  var overlay = document.getElementById('spool-cable-ocr-overlay');
  var ocrVideo = document.getElementById('spool-cable-ocr-video');
  var ocrCancel = document.getElementById('spool-cable-ocr-cancel');
  var cableCaptureBtn = document.getElementById('spool-cable-ocr-capture');
  var cableEditorBlock = document.getElementById('spool-cable-ocr-cable-editor');
  var cableTextDraft = document.getElementById('spool-cable-ocr-text-draft');
  var cableMatchBtn = document.getElementById('spool-cable-ocr-match');
  var ocrTextHint = document.getElementById('spool-cable-ocr-overlay-text');
  var ocrSugPanel = document.getElementById('spool-cable-ocr-suggestions');
  var ocrSugSub = document.getElementById('spool-cable-ocr-suggestions-sub');
  var ocrSugList = document.getElementById('spool-cable-ocr-suggestions-list');
  var ocrNewTypeStashBtn = document.getElementById('spool-cable-ocr-new-type-stash');
  var cableSelOcr = document.getElementById({{ form.cableType.vars.id|json_encode|raw }});
  var famSelOcr = document.getElementById({{ form.cableFamilyFilter.vars.id|json_encode|raw }});
  var psIn = document.getElementById({{ form.initialVisibleM.vars.id|json_encode|raw }});

  var scanRaf = null;
  var scanStream = null;
  var ocrBusy = false;
  var cableMatchBusy = false;
  var ocrCropCanvas = null;
  var CABLE_STRIP_FRAC = 0.2;
  var MIN_CHARS = 10;
  var tessWorkerPromise = null;
  var tessWorker = null;

  /** @type {'cable'|'ps'} */
  var ocrMode = 'cable';

  var cableReady = !!(ocrBtn && cableSelOcr && cfg.matchUrl);
  var psReady = !!(psOcrBtn && psIn);

  if (!overlay || !ocrVideo || (!cableReady && !psReady)) {
    return;
  }

  function longestDigitRunOcr(s) {
    var m = String(s || '').match(/\d+/g);
    if (!m || !m.length) return '';
    return m.reduce(function (a, b) { return b.length > a.length ? b : a; }, '');
  }

  function parsePositiveIntDigits(run) {
    if (!run || !run.length) return '';
    var n = parseInt(run, 10);
    if (!isFinite(n) || n < 1) return '';
    return String(n);
  }

  /** OCR text z PS řádku na štítku (bez čárového kódu): nejdříve „PS … číslo“, jinak nejdelší číselnou řadu ≥2 znaky */
  function tryExtractPs(raw) {
    var s = String(raw || '').replace(/\u00a0/g, ' ');
    var mPs = /\bPS\b\s*[.:]?\s*(\d{1,8})\b/i.exec(s);
    if (mPs && mPs[1]) {
      var nz = parsePositiveIntDigits(mPs[1]);
      if (nz.length) return nz;
    }
    var run = longestDigitRunOcr(s);
    if (run.length < 2) return '';
    return parsePositiveIntDigits(run);
  }

  function applyHintCable() {
    if (ocrTextHint) {
      ocrTextHint.textContent =
        typeof window.Tesseract === 'undefined' || typeof window.Tesseract.createWorker !== 'function'
          ? 'OCR se nenačetla — zkuste obnovit stránku.'
          : 'Namiřte řádek značení do modrého pruhu → „Přečíst řádek (OCR)“ → v poli níže text upravte → „Porovnat s katalogem“. Opakujte OCR, pokud je text neúplný.';
    }
  }

  function applyHintPs() {
    if (ocrTextHint) {
      ocrTextHint.textContent =
        typeof window.Tesseract === 'undefined' || typeof window.Tesseract.createWorker !== 'function'
          ? 'OCR se nenačetla — zkuste obnovit stránku.'
          : 'Držte číslo viditelných metrů v modrém pruhu — pak klepněte „Přečíst řádek (OCR)“. Bez čárového kódu.';
    }
  }

  function setCableCaptureUiBusy(busy) {
    if (!cableCaptureBtn) return;
    cableCaptureBtn.disabled = !!busy;

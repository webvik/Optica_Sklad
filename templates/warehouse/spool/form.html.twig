    terminateTessLocal();
    psIn.value = valueStr;
    try {
      psIn.dispatchEvent(new Event('input', { bubbles: true }));
    } catch (ePv) {}
    try {
      psIn.focus();
      psIn.select();
    } catch (ePs) {}
  }

  function openOcr(kind) {
    ocrMode = kind === 'ps' ? 'ps' : 'cable';
    if (ocrMode === 'cable') {
      applyHintCable();
      if (!cableReady) {
        window.alert('Konfigurace OCR typu kabelu chybí.');
        return;
      }
      hideCableChoiceModal();
      setCableOcrEditorVisible(true);
      setCableMatchUiBusy(false);
      if (cableTextDraft) cableTextDraft.value = '';

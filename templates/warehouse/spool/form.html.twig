                </div>
            </div>
        </div>
        {{ form_rest(form) }}
    {{ form_end(form, { render_rest: false }) }}

    <div id="spool-form-scan-overlay" class="spool-form-scan-overlay--strip" hidden role="dialog" aria-label="Sken čárového kódu">

      .then(function (r) {
        return r.json();
      })
      .then(function (j) {
        setCableMatchUiBusy(false);
        if (cableCaptureBtn && !overlay.hidden && scanStream) cableCaptureBtn.disabled = false;
        if (j && j.ok) {
          window.location.href = cfg.newCableUrl;
          return;
        }
        window.alert('P\u0159enos textu selhal (relace / CSRF).');
      })
      .catch(function () {
        setCableMatchUiBusy(false);
        if (cableCaptureBtn && !overlay.hidden && scanStream) cableCaptureBtn.disabled = false;
        window.alert('P\u0159enos textu selhal.');
      });
  }

  function renderOcrMatchFollowup(j) {

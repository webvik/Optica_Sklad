  }

  function endOcrSnapCycle() {
    ocrBusy = false;
    setCableCaptureUiBusy(false);
    if (cableMatchBtn && !cableMatchBusy) cableMatchBtn.disabled = false;
  }

  function setCableOcrEditorVisible(vis) {
    if (!cableEditorBlock) return;
    if (vis) cableEditorBlock.removeAttribute('hidden');
    else cableEditorBlock.setAttribute('hidden', '');
  }

  function setCableMatchUiBusy(busy) {
    cableMatchBusy = !!busy;
    if (cableMatchBtn) cableMatchBtn.disabled = !!busy;
  }

  function normalizeDraftText(raw) {
    return String(raw || '')
      .trim()
      .replace(/\s+/g, ' ');
  }

  function clearCableOcrSuggestions() {
    if (!ocrSugPanel) return;
    ocrSugPanel.setAttribute('hidden', '');
    if (ocrSugList) ocrSugList.innerHTML = '';
    if (ocrSugSub) ocrSugSub.textContent = '';
  }

  function formatOcrHintLine(h) {
    if (!h || typeof h !== 'object') return '';
    var p = [];
    if (h.fiberCount != null) p.push('vláken: ' + String(h.fiberCount));
    if (h.diameterMm != null) p.push('\u00d8 ' + String(h.diameterMm) + ' mm');
    if (h.constructionCode) p.push(String(h.constructionCode));
    if (h.familyGuess) p.push(String(h.familyGuess));
    return p.length ? 'Z textu: ' + p.join(' · ') + '.' : '';
  }

  function stashOcrDraftAndOpenNewType(draftText) {
    if (!cfg.newCableUrl || !cfg.stashUrl || !cfg.csrfStash) {
      window.alert('Formul\u00e1\u0159 nov\u00e9ho typu nen\u00ed na str\u00e1nce nakonfigurov\u00e1n.');
      return;
    }
    setCableMatchUiBusy(true);
    if (cableCaptureBtn) cableCaptureBtn.disabled = true;
    fetch(cfg.stashUrl, {
      method: 'POST',
      credentials: 'same-origin',
      headers: {
        'Content-Type': 'application/json',
        Accept: 'application/json',
        'X-Requested-With': 'XMLHttpRequest',
      },
      body: JSON.stringify({ text: draftText, csrf: cfg.csrfStash }),

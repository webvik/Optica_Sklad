{% block javascripts %}
    {{ parent() }}
    {% include 'warehouse/_mobile_menu_js.html.twig' %}
    <script>
(function () {
  var toggle = document.querySelector('.spool-karta-wa-toggle');
  var panel = document.getElementById('spool-karta-wa-panel');
  var sendBtn = document.querySelector('.spool-karta-wa-send');
  var msgEl = document.getElementById('spool-karta-wa-msg');
  var hintEl = document.getElementById('spool-karta-wa-hint');
  if (!toggle || !panel || !sendBtn || !msgEl) return;

  var cfg = {
    pdfUrl: toggle.getAttribute('data-karta-pdf-url') || '',
    filename: toggle.getAttribute('data-karta-filename') || 'skladova-karta.pdf',
    shareUrl: toggle.getAttribute('data-karta-share-url') || '',
  };
  if (!cfg.pdfUrl) return;

  function setHint(text, show) {
    if (!hintEl) return;
    hintEl.textContent = text || '';
    hintEl.hidden = !show;
  }

  toggle.addEventListener('click', function () {
    var open = panel.hidden;
    panel.hidden = !open;
    toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
    if (open) setHint('', false);
  });

  function makeFile(blob, filename, mime) {
    return new File([blob], filename, { type: mime });
  }

  function copyText(text) {
    if (!text || !navigator.clipboard || !navigator.clipboard.writeText) {
      return Promise.resolve(false);
    }
    return navigator.clipboard.writeText(text).then(function () { return true; }).catch(function () { return false; });
  }

  function fetchBlob(url) {
    return fetch(url, { credentials: 'same-origin' }).then(function (resp) {
      if (resp.ok) return resp.blob();
      return resp.text().then(function (body) {
        var detail = (body || '').replace(/\s+/g, ' ').trim().slice(0, 280);
        throw new Error(detail || ('HTTP ' + resp.status));
      });
    });
  }

  function canSharePayload(payload) {
    if (!navigator.share) return false;
    if (!navigator.canShare) return true;
    try {
      return navigator.canShare(payload);
    } catch (e) {
      return false;
    }
  }

  function isOpticaAndroidApp() {
    if (typeof window.opticaIsAndroidApp === 'function') return window.opticaIsAndroidApp();
    var cap = window.Capacitor;
    return !!(cap && cap.getPlatform && cap.getPlatform() === 'android');
  }

  function tryCapacitorSharePdf(pdfFile, message, shareUrl) {
    if (typeof window.opticaCapacitorSharePdf !== 'function') return Promise.resolve(null);
    return window.opticaCapacitorSharePdf(pdfFile, pdfFile.name, message || '', shareUrl || '').then(function (ok) {
      if (ok === false) return null;
      return message ? 'with-text' : 'files-only';
    }).catch(function (err) {
      if (err && err.name === 'AbortError') throw err;
      return null;
    });
  }

  function tryWebSharePdf(pdfFile, message) {
    var withText = { files: [pdfFile], text: message };
    if (canSharePayload(withText)) {
      return navigator.share(withText).then(function () { return 'with-text'; }).catch(function (err) {
        if (err && err.name === 'AbortError') throw err;
        return null;
      });
    }
    var filesOnly = { files: [pdfFile] };
    if (canSharePayload(filesOnly)) {
      return navigator.share(filesOnly).then(function () { return 'files-only'; }).catch(function (err) {
        if (err && err.name === 'AbortError') throw err;
        return null;
      });
    }
    return Promise.resolve(null);
  }

  function sharePdf(pdfFile, message, shareUrl) {
    return tryCapacitorSharePdf(pdfFile, message, shareUrl).then(function (mode) {
      if (mode) return mode;
      var fullMessage = buildShareMessage(message);
      return tryWebSharePdf(pdfFile, fullMessage);
    });
  }

  function openWhatsAppWithText(text) {
    window.location.href = 'https://wa.me/?text=' + encodeURIComponent(text);
  }

  function buildShareMessage(message) {
    if (!cfg.shareUrl) return message;
    return message + '\n\nStáhnout PDF:\n' + cfg.shareUrl;
  }

  sendBtn.addEventListener('click', function () {
    var message = (msgEl.value || '').trim();
    if (!message) {
      setHint('Doplňte text zprávy.', true);
      msgEl.focus();
      return;
    }

    sendBtn.disabled = true;
    setHint('Připravuji PDF…', true);

    function finishShare(pdfFile) {
      return sharePdf(pdfFile, message, cfg.shareUrl).then(function (mode) {
        if (mode === 'with-text') {
          setHint('PDF odeslán — ve WhatsApp vyberte příjemce.', true);
          return 'done';
        }
        if (mode === 'files-only') {
          return copyText(message).then(function () {
            setHint('PDF odeslán — ve WhatsApp vyberte příjemce a vložte text ze schránky (podržte prst → Vložit).', true);
            return 'done';
          });
        }
        return null;
      });
    }

    var nativeUrlShare = isOpticaAndroidApp() && cfg.shareUrl && typeof window.opticaCapacitorSharePdfFromUrl === 'function';
    var sharePromise = nativeUrlShare
      ? window.opticaCapacitorSharePdfFromUrl(cfg.shareUrl, cfg.filename, message).then(function (ok) {
          if (ok) {
            setHint('PDF odeslán — ve WhatsApp vyberte příjemce.', true);
            return 'done';
          }
          return fetchBlob(cfg.pdfUrl).then(function (pdfBlob) {
            return finishShare(makeFile(pdfBlob, cfg.filename, 'application/pdf'));
          });
        })
      : fetchBlob(cfg.pdfUrl).then(function (pdfBlob) {
          return finishShare(makeFile(pdfBlob, cfg.filename, 'application/pdf'));
        });

    sharePromise
      .then(function (status) {
        if (status === 'done') return;
        var fallbackMessage = buildShareMessage(message);
        return copyText(fallbackMessage).then(function () {
          openWhatsAppWithText(fallbackMessage);
          setHint('WhatsApp otevřen — vyberte příjemce; ve zprávě je odkaz ke stažení PDF (48 h).', true);
        });
      })
      .catch(function (err) {
        if (err && err.name === 'AbortError') {
          setHint('', false);
          return;
        }
        setHint(err && err.message ? err.message : 'PDF se nepodařilo vytvořit.', true);
      })
      .finally(function () {
        sendBtn.disabled = false;
      });
  });
})();
    </script>
{% endblock %}

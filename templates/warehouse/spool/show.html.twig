{% extends 'base.html.twig' %}
{% block title %}{{ spool.reelNumber }} — Optický sklad{% endblock %}
{% block body %}
    {% include '_app_menu_cz.html.twig' %}
    <h1>Cívka {{ spool.reelNumber }}</h1>
    <p>
        <strong>Typ:</strong> {{ spool.cableType ? spool.cableType.name ~ ' (' ~ spool.cableType.code ~ ')' : '—' }}<br>
        <strong>L:</strong> {{ spool.totalLengthM }} m,
        <strong>m₀:</strong> {{ spool.initialVisibleM }},
        <strong>zbývá:</strong> {{ spool.currentRemainingM ?? '—' }} m,
        <strong>směr čtení metru:</strong> {{ spool.meterSign is null ? '—' : (spool.meterSign == 1 ? 'rostoucí' : 'klesající') }}<br>
        <strong>Stav:</strong> {% if spool.status.value == 'in_stock' %}na skladě{% elseif spool.status.value == 'transferred' %}předáno{% elseif spool.status.value == 'written_off' %}vyřazeno{% else %}{{ spool.status.value }}{% endif %}
        {% if spool.family %} · <strong>řada:</strong> {{ spool.family }}{% endif %}
    </p>
    <h2>Deník</h2>
    <table>
        <thead>
            <tr><th>Kdy</th><th>Typ</th><th>m (čtení)</th><th>Odběr (m)</th><th>Zakázka</th><th>Pozn.</th></tr>
        </thead>
        <tbody>
        {% for e in spool.events %}
            <tr>
                <td>{{ e.occurredAt|date('Y-m-d H:i') }}</td>
                <td>{% if e.type.value == 'meter_reading' %}odběr dle metru{% elseif e.type.value == 'transfer' %}předání{% elseif e.type.value == 'writeoff' %}vyřazení{% elseif e.type.value == 'inventory' %}inventura{% elseif e.type.value == 'correction' %}oprava{% elseif e.type.value == 'laid_section' %}úsek (štítek){% else %}{{ e.type.value }}{% endif %}</td>
                <td>{{ e.visibleM is not null ? e.visibleM : '—' }}</td>
                <td>{{ e.usedMeters is not null ? e.usedMeters : '—' }}</td>
                <td>{{ e.projectLabel|default('—') }}</td>
                <td>{{ e.note|default('') }}</td>
            </tr>
        {% else %}
            <tr><td colspan="6">Žádné záznamy</td></tr>
        {% endfor %}
        </tbody>
    </table>

    <h2>Nová událost</h2>
    {{ form_start(form) }}
        {{ form_widget(form) }}
        <p><button type="submit">Zapsat</button></p>
    {{ form_end(form) }}
    <p><a href="{{ path('warehouse_spool_index') }}">← zpět na seznam</a></p>
{% endblock %}

{% extends 'base.html.twig' %}
{% block title %}{{ spool.reelNumber }} — Optický sklad{% endblock %}
{% block stylesheets %}
    {{ parent() }}
    <style>
        .spool-form { max-width: 40rem; line-height: 1.6; }
        .spool-form__field {
            display: grid;
            grid-template-columns: minmax(0, 8rem) minmax(0, 1fr);
            column-gap: 0.45rem;
            row-gap: 0.2rem;
            margin: 0 0 0.75rem;
            align-items: start;
        }
        .spool-form__field > label, .spool-form__field > .spool-form__static-label {
            font-weight: 600;
            font-size: 0.84rem;
            line-height: 1.25;
            padding-top: 0.28rem;
            word-break: break-word;
            hyphens: auto;
        }
        .spool-form__value { min-width: 0; text-align: left; }
        .spool-form__value .form-error, .spool-form__value ul, .spool-form__value p.help-text { margin: 0.25rem 0 0; display: block; }
        .spool-form__value p.form-text, .spool-form__value p.help-text, .spool-form__value small { font-size: 0.85rem; line-height: 1.4; color: #555; text-align: left; }
        .spool-form__value [type="date"], .spool-form__value [type="datetime-local"], .spool-form__value [type="number"],
        .spool-form__value [type="text"], .spool-form__value textarea, .spool-form__value select {
            max-width: 100%; box-sizing: border-box;
        }
        .spool-form__value input, .spool-form__value select, .spool-form__value textarea { text-align: left; width: 100%; }
        @media (min-width: 42rem) {
            .spool-form__field { grid-template-columns: 12.5rem 1fr; column-gap: 1.5rem; margin-bottom: 0.9rem; }
            .spool-form__row--actions { grid-template-columns: 12.5rem 1fr; }
            .spool-form__field > label, .spool-form__field > .spool-form__static-label { font-size: 1.06rem; line-height: 1.45; padding-top: 0.2rem; }
            .spool-form__value > input, .spool-form__value > select, .spool-form__value > textarea { max-width: 24rem; margin-left: auto; display: block; }
            .spool-form__value p.form-text, .spool-form__value p.help-text { max-width: 24rem; margin-left: auto; }
            .spool-form__value--actions .spool-form__actions { max-width: 24rem; margin-left: auto; }
            .spool-form__value > ul, .spool-form__value .form-error { text-align: left; margin-left: auto; max-width: 24rem; }
        }
        @media (max-width: 41.99rem) {
            .spool-form__row--action-spacer { display: none !important; }
            .spool-form__row--actions .spool-form__value--actions { grid-column: 1 / -1; }
        }
        .spool-form__actions { display: flex; flex-direction: row; justify-content: space-between; align-items: center; gap: 0.65rem; flex-wrap: wrap; width: 100%; }
        @media (min-width: 42rem) {
            .spool-form__row--actions .spool-form__value--actions { width: 100%; }
        }
        /* Barvy tlačítek: globálně v _styles_ui_buttons.html.twig (base) */
        .spool-form__row--action-spacer { display: none; }
        @media (min-width: 42rem) {
            .spool-form__row--action-spacer { display: block; min-height: 1px; }
        }
        .spool-form--spool-event textarea { min-height: 5rem; }
        .spool-form__readout--balance { margin: 0; font-size: 0.95rem; line-height: 1.4; text-align: left; color: #222; font-weight: 400; }
        .spool-form__readout--balance-value { font-weight: 700; font-variant-numeric: tabular-nums; }
        .spool-cable-end-suffix { font-weight: 400; font-variant-numeric: tabular-nums; color: #555; font-size: 0.92em; }
        .spool-form--spool-event .spool-form__value .spool-form__help--writeoff-zbytek,
        .spool-form--spool-event .spool-form__value p.form-text.spool-form__help--writeoff-zbytek,
        .spool-form--spool-event .spool-form__value #spool_event_writeoffRemainderM_help {
            font-size: 0.8rem;
            line-height: 1.3;
            color: #666;
            margin-top: 0.2rem;
        }
        @media (max-width: 41.99rem) {
            .spool-form--spool-event .spool-form__value .spool-form__help--writeoff-zbytek,
            .spool-form--spool-event .spool-form__value p.form-text.spool-form__help--writeoff-zbytek,
            .spool-form--spool-event .spool-form__value #spool_event_writeoffRemainderM_help {
                font-size: 0.68rem;
                line-height: 1.25;
            }
        }
        /* Doplnění typu na kartě cívky: horizontální scroll pro dlouhé řádky v listboxu (viz spool/form + __scroller) */
        .assign-cable-type-hscroll {
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
            overscroll-behavior-x: contain;
            max-width: 100%;
            min-width: 0;
        }
        .assign-cable-type-field-row { margin-bottom: 0.5rem; }
        .assign-cable-type-field-row > label { display: inline-block; font-weight: 600; margin-bottom: 0.25rem; }
        .assign-cable-type-hscroll select.cable-type-list {
            max-width: none !important;
            display: block;
        }
        .assign-cable-type-disclosure {
            max-width: 40rem;
            margin: 0.75rem 0 1.25rem;
            border: 1px solid #c8c8c8;
            border-radius: 6px;
            background: #fafafa;
            box-sizing: border-box;
            font-size: 1.05rem;
            line-height: 1.45;
        }
        .assign-cable-type-disclosure__summary {
            list-style: none;
            cursor: pointer;
            font-weight: 600;
            font-size: clamp(1.08rem, 2.9vw, 1.22rem);
            line-height: 1.35;
            padding: 0.65rem 0.75rem;
            user-select: none;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 0.5rem;
        }
        .assign-cable-type-disclosure__summary::-webkit-details-marker { display: none; }
        .assign-cable-type-disclosure__summary::marker { content: ''; }
        .assign-cable-type-disclosure__summary:hover { background: #f2f2f2; border-radius: 5px 5px 0 0; }
        .assign-cable-type-disclosure:not([open]) .assign-cable-type-disclosure__summary:hover { border-radius: 5px; }
        .assign-cable-type-disclosure__chev { flex-shrink: 0; color: #444; font-size: 0.78em; transition: transform 0.15s ease; }
        .assign-cable-type-disclosure[open] .assign-cable-type-disclosure__chev { transform: rotate(180deg); }
        .assign-cable-type-disclosure__body {
            padding: 0 0.75rem 0.85rem;
            border-top: 1px solid #ddd;
            background: #fff;
            border-radius: 0 0 5px 5px;
        }
        .assign-cable-type-disclosure__lead { margin: 0.6rem 0 0.75rem; font-size: 1em; color: #333; text-align: left; }
        .assign-cable-type-disclosure .assign-cable-type-field-row > label,
        .assign-cable-type-disclosure .assign-cable-type-field-row { font-size: 1em; }
        .assign-cable-type-disclosure .assign-cable-type-hscroll select.cable-type-list {
            font-size: 1.08rem !important;
            line-height: 1.38;
        }
        .assign-cable-type-disclosure .assign-cable-type-field-row p.form-text,
        .assign-cable-type-disclosure .assign-cable-type-field-row p.help-text {
            font-size: 0.98rem !important;
            color: #444;
            line-height: 1.4;
            margin-top: 0.45rem;
        }
        #spool-assign-cable-form button[type="submit"] {
            font-size: 1.05rem;
            min-height: 2.65rem;
            padding: 0.5rem 1.05rem;
        }
        .spool-card-edit-bar {
            margin: 0 0 0.85rem;
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            gap: 0.35rem 0.5rem;
        }
        .spool-card-edit-bar__hint {
            color: #555;
            font-size: 0.9rem;
            line-height: 1.3;
        }
        a.spool-card-edit-link {
            display: inline-flex;
            width: auto;
            flex: 0 0 auto;
            box-sizing: border-box;
            align-items: center;
            justify-content: center;
            text-align: center;
            text-decoration: none;
            line-height: 1.2;
            min-height: 2.55rem;
            padding: 0.4rem 0.6rem;
            font-size: 0.92rem;
            font-weight: 600;
            border-radius: 6px;
            -webkit-tap-highlight-color: transparent;
        }
        @media (max-width: 48rem) {
            a.spool-card-edit-link {
                min-height: 2.55rem;
                padding: 0.4rem 0.6rem;
                font-size: 0.92rem;
                line-height: 1.2;
                width: auto;
            }
        }
    </style>
{% endblock %}
{% block body %}
    {% include '_app_menu_cz.html.twig' %}
    <h1>Cívka {{ spool.reelNumber }}</h1>
    {% include 'warehouse/spool/_spool_typ_under_title.html.twig' %}
    {% if is_granted('ROLE_SKLAD_EDIT') %}
        {% if editMode|default(false) and editCoreForm is defined and editCoreForm %}
            {% include 'warehouse/spool/_spool_edit_core_data.html.twig' %}
        {% else %}
            <p class="spool-card-edit-bar">
                <a class="app-menu__nav-link spool-card-edit-link" href="{{ path('warehouse_spool_show', {id: spool.id, upravit: 1}) }}">Upravit údaje cívky</a>
                <span class="spool-card-edit-bar__hint">— délka L, PS, vlákna, Ø</span>
            </p>
        {% endif %}
    {% endif %}
    {% include 'warehouse/spool/_spool_summary_and_diary.html.twig' %}
    {% if assignCableForm is defined and assignCableForm %}
        <details class="assign-cable-type-disclosure" id="doplnit-typ">
            <summary class="assign-cable-type-disclosure__summary">
                <span>Doplnit typ kabelu</span>
                <span class="assign-cable-type-disclosure__chev" aria-hidden="true">▼</span>
            </summary>
            <div class="assign-cable-type-disclosure__body">
                <p class="assign-cable-type-disclosure__lead">Typ nebyl při zaevidování uveden; můžete ho vybrat z katalogu.</p>
                {{ form_start(assignCableForm, {
                    action: path('warehouse_spool_assign_cable', { id: spool.id }),
                    method: 'post',
                    attr: { id: 'spool-assign-cable-form' },
                }) }}
                    <div class="assign-cable-type-field-row">
                        {{ form_label(assignCableForm.cableType) }}
                        {{ form_errors(assignCableForm.cableType) }}
                        <div class="assign-cable-type-hscroll">
                            {{ form_widget(assignCableForm.cableType) }}
                        </div>
                        {{ form_help(assignCableForm.cableType) }}
                    </div>
                    <p><button type="submit">Uložit typ kabelu</button></p>
                {{ form_end(assignCableForm) }}
            </div>
        </details>
        <script>
(function () {
  var form = document.getElementById('spool-assign-cable-form');
  if (!form) return;
  var cableSel = form.querySelector('select.cable-type-list');
  var scroller = form.querySelector('.assign-cable-type-hscroll');
  if (!cableSel || !scroller) return;
  var details = document.getElementById('doplnit-typ');
  var mobileMq = window.matchMedia('(max-width: 41.99rem)');
  var sizeListT = null;
  function sizeCableTypeListbox() {
    var measure = document.createElement('div');
    measure.setAttribute('aria-hidden', 'true');
    measure.style.cssText = 'position:absolute;left:-9999px;top:0;white-space:nowrap;visibility:hidden;pointer-events:none;';
    var cs = window.getComputedStyle(cableSel);
    measure.style.font = cs.font;
    measure.style.letterSpacing = cs.letterSpacing;
    measure.style.textTransform = cs.textTransform;
    document.body.appendChild(measure);
    var maxW = 0;
    var k;
    for (k = 0; k < cableSel.options.length; k++) {
      measure.textContent = cableSel.options[k].text || ' ';
      maxW = Math.max(maxW, measure.offsetWidth);
    }
    document.body.removeChild(measure);
    var pad = mobileMq.matches ? 40 : 36;
    var cw = scroller.clientWidth;
    if (cw < 2) {
      cw = mobileMq.matches ? (window.innerWidth || 400) : 300;
    }
    var need = Math.max(cw, maxW + pad);
    cableSel.style.minWidth = need + 'px';
    cableSel.style.width = need + 'px';
  }
  function scheduleSizeCableTypeListbox() {
    if (sizeListT) { clearTimeout(sizeListT); }
    sizeListT = setTimeout(function () {
      sizeListT = null;
      sizeCableTypeListbox();
    }, 50);
  }
  function scheduleIfAssignableVisible() {
    if (details && !details.open) return;
    scheduleSizeCableTypeListbox();
  }
  scheduleIfAssignableVisible();
  if (mobileMq.addEventListener) mobileMq.addEventListener('change', scheduleIfAssignableVisible);
  else if (mobileMq.addListener) mobileMq.addListener(scheduleIfAssignableVisible);
  window.addEventListener('resize', scheduleIfAssignableVisible);
  window.addEventListener('pageshow', scheduleIfAssignableVisible);
  if (details) {
    details.addEventListener('toggle', function () {
      if (details.open) scheduleSizeCableTypeListbox();
    });
    try {
      if (window.location.hash === '#doplnit-typ') {
        details.open = true;
        scheduleSizeCableTypeListbox();
      }
    } catch (e) {}
  }
})();
        </script>
    {% endif %}
    <h2>Nová událost</h2>
    {{ form_start(form, { attr: {
        class: 'spool-form spool-form--spool-event',
        id: 'spool-event-form',
        'data-spool-book-m': spool.currentRemainingM is not null ? spool.currentRemainingM : ''
    } }) }}
        <div class="spool-form__field">
            {{ form_label(form.type) }}
            <div class="spool-form__value">
                {{ form_widget(form.type) }}
                {{ form_errors(form.type) }}
            </div>
        </div>
        <div class="spool-form__field spool-form__field--readout">
            <span class="spool-form__static-label">Zůstatek v evidenci (nyní)</span>
            <div class="spool-form__value">
                <p class="spool-form__readout--balance" id="spool-event-book-remaining">{% if spool.currentRemainingM is not null %}<span class="spool-form__readout--balance-value">{{ spool.currentRemainingM }}</span> m{% include 'warehouse/spool/_spool_cable_end_suffix.html.twig' %}{% else %}— (není doplňován){% endif %}</p>
            </div>
        </div>
        <div class="spool-form__field">
            {{ form_label(form.occurredAt) }}
            <div class="spool-form__value">
                {{ form_widget(form.occurredAt) }}
                {{ form_errors(form.occurredAt) }}
            </div>
        </div>
        <div class="spool-form__field js-spool-event-row-visiblem">
            {{ form_label(form.visibleM) }}
            <div class="spool-form__value">
                {{ form_widget(form.visibleM) }}
                {{ form_errors(form.visibleM) }}
            </div>
        </div>
        <div class="spool-form__field js-spool-event-row-writeoff" style="display: none;">
            {{ form_label(form.writeoffRemainderM) }}
            <div class="spool-form__value">
                {{ form_widget(form.writeoffRemainderM) }}
                {{ form_help(form.writeoffRemainderM) }}
                {{ form_errors(form.writeoffRemainderM) }}
            </div>
        </div>
        <div class="spool-form__field js-spool-event-row-project">
            {{ form_label(form.projectLabel) }}
            <div class="spool-form__value">
                {{ form_widget(form.projectLabel) }}
                {{ form_errors(form.projectLabel) }}
            </div>
        </div>
        <div class="spool-form__field">
            {{ form_label(form.note) }}
            <div class="spool-form__value">
                {{ form_widget(form.note) }}
                {{ form_errors(form.note) }}
            </div>
        </div>
        <div class="spool-form__field spool-form__row--actions" style="margin-top: 0.25rem; margin-bottom: 0.25rem;">
            <span class="spool-form__row--action-spacer" aria-hidden="true"></span>
            <div class="spool-form__value spool-form__value--actions">
                <div class="spool-form__actions" role="group" aria-label="Akce">
                    {% if is_granted('ROLE_SKLAD_ADMIN') %}
                        <input type="hidden" name="_delete_token" value="{{ csrf_token('spool_delete') }}">
                        <button type="submit"
                                class="spool-form__btn spool-form__btn--danger"
                                formaction="{{ path('warehouse_spool_delete', { id: spool.id }) }}"
                                formmethod="post"
                                onclick="return confirm('Opravdu smazat cívku «{{ spool.reelNumber|e('js') }}» včetně celého deníku (odběry, zafuky)? Tuto akci nelze vrátit.');">
                            Smazat
                        </button>
                    {% endif %}
                    <button type="submit" class="spool-form__btn">Zapsat</button>
                </div>
            </div>
        </div>
        {{ form_rest(form) }}
    {{ form_end(form, { render_rest: false }) }}
    <script>
(function () {
  var form = document.getElementById('spool-event-form');
  if (!form) return;
  var typeSelect = form.querySelector('select[name$="[type]"]');
  if (!typeSelect) return;
  var rowV = form.querySelector('.js-spool-event-row-visiblem');
  var rowW = form.querySelector('.js-spool-event-row-writeoff');
  var rowP = form.querySelector('.js-spool-event-row-project');
  var wIn = form.querySelector('.js-spool-writeoff-remainder');
  var bookM = form.getAttribute('data-spool-book-m');
  function isWriteoff() { return typeSelect && typeSelect.value === 'writeoff'; }
  function sync() {
    var w = isWriteoff();
    if (rowV) rowV.style.display = w ? 'none' : '';
    if (rowW) rowW.style.display = w ? '' : 'none';
    if (rowP) rowP.style.display = w ? 'none' : '';
    if (w && wIn && wIn.value === '' && bookM !== '' && bookM != null) {
      wIn.value = String(bookM);
    }
  }
  typeSelect.addEventListener('change', sync);
  sync();
})();
    </script>
    <p><a href="{{ path('warehouse_spool_index') }}">← zpět na práci s optikou</a></p>
{% endblock %}

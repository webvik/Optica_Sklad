{# Společná tabulka cívek; proměnná: spools #}
<div class="table-scroll table-scroll--wide">
<table>
    <thead>
        <tr>
            <th>Číslo cívky</th>
            <th>Typ</th>
            <th title="Jako skupina v krátké inventuře (vláken · řada · průměr)">Skupina</th>
            <th>Zbývá (m)</th>
            <th>Délka L (m)</th>
            <th>Stav</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    {% for s in spools %}
        <tr class="browse-spool-row" data-spool-id="{{ s.id }}">
            <td>{{ s.reelNumber }}</td>
            <td>{{ s.cableType ? s.cableType.code : '—' }}</td>
            <td>{{ s.briefInventuraLabel }}</td>
            <td>{{ s.currentRemainingM ?? '—' }}</td>
            <td>{{ s.totalLengthM }}</td>
            <td>{% if s.status.value == 'in_stock' %}na skladě{% elseif s.status.value == 'transferred' %}předáno{% elseif s.status.value == 'written_off' %}vyřazeno{% else %}{{ s.status.value }}{% endif %}{% if s.needsCorrection %} <span title="Čeká na korekci dat" style="color:#a60;font-weight:600;">· korek.</span>{% endif %}</td>
            <td><a href="{{ path('warehouse_spool_show', {id: s.id}) }}">Karta</a></td>
        </tr>
    {% else %}
        <tr class="browse-spool-row browse-spool-row--empty"><td colspan="7">Žádné záznamy v tomto výběru.</td></tr>
    {% endfor %}
    </tbody>
</table>
</div>

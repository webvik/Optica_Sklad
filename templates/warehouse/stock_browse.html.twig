{% extends 'base.html.twig' %}
{% block title %}Přehled skladu — Optický sklad{% endblock %}
{% block stylesheets %}
    {{ parent() }}
    <style>
        {% include 'warehouse/_cable_type_picker_core_styles.html.twig' %}
        .browse-filters__row {
            display: flex;
            flex-direction: column;
            align-items: stretch;
            gap: 0.75rem;
            margin: 0 0 0.5rem;
        }
        form.browse-filters {
            max-width: 100%;
            box-sizing: border-box;
        }
        .browse-filters__row {
            max-width: 100%;
            min-width: 0;
        }
        .browse-filters__col {
            display: flex;
            flex-direction: column;
            gap: 0.25rem;
            min-width: 0;
            max-width: 100%;
        }
        .browse-filters__col--submit { flex: 0 0 auto; }
        .browse-filters__col--reelSearch { flex: 1 1 0; min-width: 0; }
        .browse-reel-q-input {
            box-sizing: border-box;
            width: 100%;
            min-height: 2.5rem;
            padding: 0.4rem 0.65rem;
            font: inherit;
            font-size: 0.95rem;
            line-height: 1.3;
            border: 1px solid #999;
            border-radius: 4px;
            background: #fff;
            color: #1a1a1a;
        }
        .browse-reel-q-input::placeholder { color: #888; }
        .browse-reel-hint {
            color: #666;
            font-size: 0.9em;
            min-height: 1.2em;
            margin: 0 0 0.75rem;
        }
        .browse-filters__row button[type="submit"] { min-height: 2.5rem; }
        .browse-inventura-btn-line { margin: 0.35rem 0 0.75rem; }
        .browse-inventura-btn-line .warehouse-pill {
            display: inline-flex;
            width: auto;
            max-width: max-content;
            flex: 0 0 auto;
        }
        /* sloupec se nerozmačká pod šířku textu; na úzkém řádku horizontální scroll uvnitř rámečku */
        .browse-filters__col.browse-filters__col--usageReport {
            min-width: 0;
            flex: 0 1 auto;
            max-width: 100%;
        }
        .browse-filters__col--usageReport > label { font-size: 0.95rem; }
        /* Barvy: a.browse-filters__proj-feed-link v _styles_ui_buttons.html.twig */
        .browse-filters__proj-feed-link {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 100%;
            max-width: 100%;
            min-height: 2.5rem;
            padding: 0.4rem 0.5rem;
            text-align: center;
            line-height: 1.2;
            font: inherit;
            font-size: 0.95rem;
            border-radius: 6px;
            text-decoration: none;
            box-sizing: border-box;
            white-space: nowrap;
            overflow-x: auto;
            overflow-y: hidden;
            -webkit-overflow-scrolling: touch;
        }
        .browse-filters__proj-feed-link:focus-visible { outline: none; }
        @media (min-width: 42rem) {
            .browse-filters__col--usageReport {
                margin-left: 0.55rem;
            }
        }
        @media (max-width: 41.99rem) {
            .browse-filters__col--usageReport {
                margin-top: 0.35rem;
            }
        }
        @media (min-width: 42rem) {
            .browse-filters__row {
                flex-direction: row;
                flex-wrap: wrap;
                align-items: flex-end;
            }
            .browse-filters__col--equal { flex: 1 1 0; min-width: 0; }
        }
        .browse-filters__col--fiberCount { display: none; }
        @media (min-width: 42rem) {
            .browse-filters__col--fiberCount {
                display: flex;
                flex: 0 1 auto;
                min-width: 5.5rem;
                max-width: 11rem;
            }
        }
        .browse-fiber-count-panel {
            display: flex;
            flex-wrap: wrap;
            gap: 0.35rem 0.65rem;
            min-height: 2.5rem;
            align-items: center;
            padding: 0.35rem 0.5rem;
            border: 1px solid #999;
            border-radius: 4px;
            background: #fff;
            box-sizing: border-box;
        }
        .browse-fiber-count-panel__item {
            display: inline-flex;
            align-items: center;
            gap: 0.3rem;
            margin: 0;
            font: inherit;
            font-size: 0.95rem;
            cursor: pointer;
            white-space: nowrap;
        }
        .browse-fiber-count-panel__item input[type="checkbox"] {
            width: 1.05rem;
            height: 1.05rem;
            margin: 0;
        }
        .browse-filter-checkpanel {
            display: flex;
            flex-direction: column;
            gap: 0.1rem;
            min-width: 0;
        }
        .browse-filter-checkpanel__row {
            display: grid;
            grid-template-columns: auto minmax(0, 1fr);
            align-items: center;
            gap: 0.6rem 0.9rem;
            padding: 0.4rem 0.5rem;
            border-radius: 4px;
            margin: 0;
            font: inherit;
            font-size: 0.95rem;
            cursor: pointer;
            -webkit-tap-highlight-color: transparent;
        }
        .browse-filter-checkpanel__row:hover { background: rgba(0,0,0,0.05); }
        .browse-filter-checkpanel__row--all {
            font-weight: 600;
            border-bottom: 1px solid #ccc;
            margin-bottom: 0.2rem;
            padding-bottom: 0.5rem;
        }
        .browse-filter-checkpanel__text {
            min-width: 0;
            text-align: left;
            line-height: 1.3;
        }
        .browse-filter-checkpanel__row input[type="checkbox"] {
            width: 1.15rem;
            height: 1.15rem;
            flex-shrink: 0;
            margin: 0;
        }
        /*
         * Panel „Typ kabelu“: vlevo + horizontální scroll pro dlouhé názvy.
         * Bez @media — jinak na tabletech / úzkém desktopu (šířka > ~672px) platí jen „desktop modal“
         * z _cable_type_picker_core_styles a tyto pravidla se vůbec nepoužijí.
         */
        #browse-cable-type-picker.cable-type-mobile-picker--open #browse-cable-type-panel.cable-type-mobile-picker__panel > .cable-type-mobile-picker__scroller {
            display: flex !important;
            flex-direction: column !important;
            align-items: flex-start !important;
            box-sizing: border-box;
            overflow-x: auto !important;
            -webkit-overflow-scrolling: touch;
            overscroll-behavior-x: contain;
            direction: ltr;
        }
        #browse-cable-type-panel .browse-filter-checkpanel {
            width: max-content;
            min-width: 100%;
            box-sizing: border-box;
            margin-inline: 0;
            align-self: flex-start;
            align-items: flex-start;
            direction: ltr;
            padding-inline: max(0.35rem, env(safe-area-inset-left, 0px))
                         max(0.35rem, env(safe-area-inset-right, 0px));
        }
        #browse-cable-type-panel .browse-filter-checkpanel__row {
            display: grid;
            grid-template-columns: auto auto;
            justify-content: start;
            justify-items: start;
            width: max-content;
            max-width: none;
            box-sizing: border-box;
            text-align: left;
            direction: ltr;
        }
        #browse-cable-type-panel .browse-filter-checkpanel__text {
            white-space: nowrap;
            text-align: left;
            justify-self: start;
        }
        #browse-cable-type-panel .browse-filter-checkpanel__text--cable-with-brief {
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            gap: 0.12rem;
            white-space: normal;
            line-height: 1.25;
        }
        #browse-cable-type-panel .browse-cable-type__brief {
            font-size: 0.88em;
            font-weight: 500;
            color: #355064;
            white-space: nowrap;
        }
        #browse-cable-type-panel .browse-cable-type__code-line {
            white-space: nowrap;
        }
        #browse-cable-type-panel .browse-filter-checkpanel__row {
            align-items: start;
        }
        {% include 'warehouse/_mobile_menu_styles.html.twig' %}
    </style>
{% endblock %}
{% block body %}
    {% include 'warehouse/_mobile_menu.html.twig' %}
    <h1>Přehled skladu</h1>
    <p class="browse-inventura-btn-line"><a href="{{ path('warehouse_browse_inventura') }}" class="warehouse-pill">Inventura</a></p>
    <p class="lede">Přehled cívek podle typu a stavu; vhodné pro <strong>kontrolu zásob</strong> a přípravu <strong>inventury</strong> (samostatný inventurní režim můžeme doplnit).</p>

    <form method="get" action="{{ path('warehouse_browse_index') }}" class="browse-filters" style="margin-bottom: 1rem;">
        <div class="browse-filters__row">
            {% if fiberCountChoices|default([])|length > 0 %}
            <div class="browse-filters__col browse-filters__col--fiberCount">
                <span class="browse-filters__label" id="browse-fiber-count-label">Počet vláken</span>
                <div class="browse-fiber-count-panel" role="group" aria-labelledby="browse-fiber-count-label">
                    {% for fc in fiberCountChoices %}
                        <label class="browse-fiber-count-panel__item">
                            <input type="checkbox" name="fiberCounts[]" value="{{ fc }}" class="js-browse-fiber-cb"{% if fc in filterFiberCounts|default([]) %} checked{% endif %}>
                            <span>{{ fc }}</span>
                        </label>
                    {% endfor %}
                </div>
            </div>
            {% endif %}
            <div class="browse-filters__col browse-filters__col--equal">
                <label for="browse-cable-type-btn">Typ kabelu</label>
                <div class="cable-type-mobile-picker" id="browse-cable-type-picker" data-browse-mode="cable">
                    <button type="button" class="cable-type-mobile-picker__toggle" id="browse-cable-type-btn" aria-haspopup="dialog" aria-expanded="false" aria-controls="browse-cable-type-panel">
                        <span class="cable-type-mobile-picker__text" id="browse-cable-type-label">{% if cableTypeFilterIsAll|default(false) %}Všechny typy{% elseif cableTypeFilterIsNone|default(false) %}— všechny —{% else %}…{% endif %}</span>
                        <span class="cable-type-mobile-picker__chev" aria-hidden="true">▼</span>
                    </button>
                    <div class="cable-type-mobile-picker__backdrop" id="browse-cable-type-backdrop" hidden></div>
                    <div class="cable-type-mobile-picker__panel" id="browse-cable-type-panel" role="dialog" aria-label="Typ kabelu" hidden>
                        <div class="cable-type-mobile-picker__bar">
                            <span class="cable-type-mobile-picker__title">Typ kabelu</span>
                            <button type="button" class="cable-type-mobile-picker__close" id="browse-cable-type-close" aria-label="Zavřít">×</button>
                        </div>
                        <div class="cable-type-mobile-picker__scroller">
                            <div class="browse-filter-checkpanel" role="group" aria-label="Výběr typu kabelu">
                                <label class="browse-filter-checkpanel__row browse-filter-checkpanel__row--all">
                                    <input type="checkbox" class="js-browse-cable-vse" aria-label="Vše: zaškrtnout všechny typy" title="Vše" tabindex="0">
                                    <span class="browse-filter-checkpanel__text">Vše</span>
                                </label>
                                <label class="browse-filter-checkpanel__row browse-filter-checkpanel__row--unset">
                                    <input type="checkbox" name="cableTypeUnset" value="1" class="js-browse-cable-unset" data-browse-label="— typ neuveden —"{% if filterCableTypeUnset|default(false) %} checked{% endif %}>
                                    <span class="browse-filter-checkpanel__text">— typ neuveden —</span>
                                </label>
                                {% for ct in cableTypeChoices %}
                                    <label class="browse-filter-checkpanel__row">
                                        <input type="checkbox" name="cableTypeIds[]" value="{{ ct.id }}" class="js-browse-cable-cb" data-browse-label="{{ ct.code|e('html_attr') }} — {{ ct.name|e('html_attr') }}"{% if ct.id in filterCableTypeIds %} checked{% endif %}>
                                        <span class="browse-filter-checkpanel__text browse-filter-checkpanel__text--cable-with-brief">
                                            <span class="browse-cable-type__brief">{{ ct.briefInventuraLabel }}</span>
                                            <span class="browse-cable-type__code-line">{{ ct.code }} — {{ ct.name }}</span>
                                        </span>
                                    </label>
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="browse-filters__col browse-filters__col--equal">
                <label for="browse-status-btn">Stav cívky</label>
                <div class="cable-type-mobile-picker" id="browse-status-picker" data-browse-mode="status">
                    <button type="button" class="cable-type-mobile-picker__toggle" id="browse-status-btn" aria-haspopup="dialog" aria-expanded="false" aria-controls="browse-status-panel">
                        <span class="cable-type-mobile-picker__text" id="browse-status-label">{% if filterNeedsCorrection|default(false) and allStatusesSelected|default(false) %}k ke korekci{% elseif filterNeedsCorrection|default(false) %}… · k ke korekci{% elseif allStatusesSelected|default(false) %}Všechny stavy{% elseif filterStatusValues|length == 1 and filterStatusValues[0] == 'in_stock' %}na skladě{% elseif filterStatusValues|length == 1 and filterStatusValues[0] == 'transferred' %}předáno{% elseif filterStatusValues|length == 1 and filterStatusValues[0] == 'written_off' %}vyřazeno{% else %}…{% endif %}</span>
                        <span class="cable-type-mobile-picker__chev" aria-hidden="true">▼</span>
                    </button>
                    <div class="cable-type-mobile-picker__backdrop" id="browse-status-backdrop" hidden></div>
                    <div class="cable-type-mobile-picker__panel" id="browse-status-panel" role="dialog" aria-label="Stav cívky" hidden>
                        <div class="cable-type-mobile-picker__bar">
                            <span class="cable-type-mobile-picker__title">Stav cívky</span>
                            <button type="button" class="cable-type-mobile-picker__close" id="browse-status-close" aria-label="Zavřít">×</button>
                        </div>
                        <div class="cable-type-mobile-picker__scroller">
                            <div class="browse-filter-checkpanel" role="group" aria-label="Výběr stavu cívky">
                                <label class="browse-filter-checkpanel__row browse-filter-checkpanel__row--all">
                                    <input type="checkbox" class="js-browse-status-vse" aria-label="Vše: všechny stavy" title="Vše" tabindex="0">
                                    <span class="browse-filter-checkpanel__text">Vše</span>
                                </label>
                                <label class="browse-filter-checkpanel__row">
                                    <input type="checkbox" name="status[]" value="in_stock" class="js-browse-status-cb" data-browse-label="na skladě"{% if 'in_stock' in filterStatusValues %} checked{% endif %}>
                                    <span class="browse-filter-checkpanel__text">na skladě</span>
                                </label>
                                <label class="browse-filter-checkpanel__row">
                                    <input type="checkbox" name="status[]" value="transferred" class="js-browse-status-cb" data-browse-label="předáno"{% if 'transferred' in filterStatusValues %} checked{% endif %}>
                                    <span class="browse-filter-checkpanel__text">předáno</span>
                                </label>
                                <label class="browse-filter-checkpanel__row">
                                    <input type="checkbox" name="status[]" value="written_off" class="js-browse-status-cb" data-browse-label="vyřazeno"{% if 'written_off' in filterStatusValues %} checked{% endif %}>
                                    <span class="browse-filter-checkpanel__text">vyřazeno</span>
                                </label>
                                <label class="browse-filter-checkpanel__row browse-filter-checkpanel__row--correction">
                                    <input type="checkbox" name="needsCorrection" value="1" class="js-browse-needs-correction" data-browse-label="k ke korekci"{% if filterNeedsCorrection|default(false) %} checked{% endif %}>
                                    <span class="browse-filter-checkpanel__text">k ke korekci</span>
                                </label>
                                <label class="browse-filter-checkpanel__row browse-filter-checkpanel__row--correction">
                                    <input type="checkbox" name="withoutWarehouseCard" value="1" class="js-browse-without-card" data-browse-label="bez vytištěné karty"{% if filterWithoutWarehouseCard|default(false) %} checked{% endif %}>
                                    <span class="browse-filter-checkpanel__text">bez vytištěné karty</span>
                                </label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="browse-filters__col browse-filters__col--submit">
                <button type="submit">Filtrovat</button>
            </div>
            <div class="browse-filters__col browse-filters__col--equal browse-filters__col--usageReport">
                <label for="browse-usage-proj-link">Podle zakázky</label>
                <a id="browse-usage-proj-link" href="{{ path('warehouse_browse_usage_by_project') }}" class="browse-filters__proj-feed-link">Filtr podle projektů</a>
            </div>
            <div class="browse-filters__col browse-filters__col--equal browse-filters__col--reelSearch">
                <label for="browse-reel-q">Číslo saře</label>
                <input type="text"
                       name="q"
                       id="browse-reel-q"
                       class="browse-reel-q-input"
                       value="{{ searchQuery|default('')|e('html_attr') }}"
                       autocomplete="off"
                       autocapitalize="off"
                       spellcheck="false"
                       inputmode="search"
                       placeholder="např. 450-1470"
                       aria-describedby="browse-reel-hint">
            </div>
        </div>
    </form>

    <p id="browse-reel-hint" class="browse-reel-hint" aria-live="polite"></p>

    <div id="browse-spool-table-host">
    {% include 'warehouse/_spool_table.html.twig' with { spools: spools } only %}
    </div>

    <p><a href="{{ path('warehouse_dashboard') }}">Číselný přehled (dashboard)</a> ·
       <a href="{{ path('warehouse_spool_index') }}">Běžná práce s cívkami</a></p>
    {% include 'warehouse/_mobile_menu_js.html.twig' %}
<script>
(function () {
  var mobileMq = window.matchMedia('(max-width: 41.99rem)');

  function refreshBodyOpen() {
    if (document.querySelector('.browse-filters .cable-type-mobile-picker--open')) {
      document.body.classList.add('spool-cable-panel-open');
    } else {
      document.body.classList.remove('spool-cable-panel-open');
    }
  }

  function czTypu(n) {
    if (n === 1) return '1 typ';
    if (n >= 2 && n <= 4) return n + ' typy';
    return n + ' typů';
  }
  function czStavu(n) {
    if (n === 1) return '1 stav';
    if (n >= 2 && n <= 4) return n + ' stavy';
    return n + ' stavů';
  }

  function summarizeCable(root) {
    var unsetCb = root.querySelector('input.js-browse-cable-unset');
    var cbs = root.querySelectorAll('input.js-browse-cable-cb');
    var t = cbs.length;
    var n = 0;
    var labels = [];
    for (var i = 0; i < cbs.length; i++) {
      if (cbs[i].checked) {
        n++;
        labels.push(cbs[i].getAttribute('data-browse-label') || '');
      }
    }
    var unsetOn = unsetCb && unsetCb.checked;
    var picked = n + (unsetOn ? 1 : 0);
    if (t === 0 && !unsetCb) return '— všechny —';
    if (picked === 0) return '— všechny —';
    if (n === t && unsetOn) return 'Všechny typy';
    if (unsetOn && n === 0) return unsetCb.getAttribute('data-browse-label') || '— typ neuveden —';
    if (picked === 1) {
      if (unsetOn) return unsetCb.getAttribute('data-browse-label') || '…';
      return labels[0] || '…';
    }
    return czTypu(picked);
  }
  function summarizeStatus(root) {
    var korekce = root.querySelector('.js-browse-needs-correction');
    var kOn = korekce && korekce.checked;
    var cbs = root.querySelectorAll('input.js-browse-status-cb');
    var t = cbs.length;
    if (t !== 3) return kOn ? 'k ke korekci' : '…';
    var n = 0;
    var labels = [];
    for (var i = 0; i < cbs.length; i++) {
      if (cbs[i].checked) {
        n++;
        labels.push(cbs[i].getAttribute('data-browse-label') || '');
      }
    }
    var base;
    if (n === 0) base = '— všechny —';
    else if (n === 3) base = 'Všechny stavy';
    else if (n === 1) base = labels[0] || '…';
    else base = czStavu(n);
    if (!kOn) return base;
    if (base === 'Všechny stavy' || base === '— všechny —') return 'k ke korekci';
    return base + ' · k ke korekci';
  }

  function syncCableVse(root) {
    var vse = root.querySelector('.js-browse-cable-vse');
    var unsetCb = root.querySelector('input.js-browse-cable-unset');
    var cbs = root.querySelectorAll('input.js-browse-cable-cb');
    if (!vse) return;
    if (!cbs.length) {
      vse.indeterminate = false;
      vse.checked = unsetCb ? unsetCb.checked : false;
      if (!unsetCb) vse.setAttribute('disabled', 'disabled');
      else vse.removeAttribute('disabled');
      return;
    }
    vse.removeAttribute('disabled');
    var n = 0;
    for (var i = 0; i < cbs.length; i++) if (cbs[i].checked) n++;
    var allCatalog = n === cbs.length;
    var allOn = allCatalog && (!unsetCb || unsetCb.checked);
    vse.indeterminate = !allOn && (n > 0 || (unsetCb && unsetCb.checked));
    vse.checked = allOn;
  }
  function syncStatusVse(root) {
    var vse = root.querySelector('.js-browse-status-vse');
    var cbs = root.querySelectorAll('input.js-browse-status-cb');
    if (!vse || cbs.length !== 3) return;
    var n = 0;
    for (var j = 0; j < cbs.length; j++) if (cbs[j].checked) n++;
    vse.indeterminate = n > 0 && n < 3;
    vse.checked = n === 3;
  }

  function initBrowseCheckboxPicker(root, beforeOpen) {
    var btn = root.querySelector('.cable-type-mobile-picker__toggle');
    var labelEl = root.querySelector('.cable-type-mobile-picker__text');
    var panel = root.querySelector('.cable-type-mobile-picker__panel');
    var backdrop = root.querySelector('.cable-type-mobile-picker__backdrop');
    var closeBtn = root.querySelector('.cable-type-mobile-picker__close');
    var scroller = root.querySelector('.cable-type-mobile-picker__scroller');
    var isCable = (root.getAttribute('data-browse-mode') || '') === 'cable';
    if (!panel) return;
    if (typeof beforeOpen !== 'function') { beforeOpen = function () {}; }

    function syncLabel() {
      if (!labelEl) return;
      if (isCable) syncCableVse(root);
      else syncStatusVse(root);
      labelEl.textContent = isCable ? summarizeCable(root) : summarizeStatus(root);
    }

    function sizePanelMinWidth() {
      if (!scroller) return;
      /* Cable types: řádky mají vlastní šířku (CSS max-content); inline minWidth by kazil horizontální scroll na mobilu. */
      if (root.id === 'browse-cable-type-picker') {
        scroller.style.minWidth = '';
        return;
      }
      var cbs = root.querySelectorAll('input[type=checkbox]');
      if (!cbs.length) return;
      var measure = document.createElement('div');
      measure.setAttribute('aria-hidden', 'true');
      measure.style.cssText = 'position:absolute;left:-9999px;top:0;white-space:nowrap;visibility:hidden;pointer-events:none;';
      var cs = window.getComputedStyle(cbs[0].closest('label') || cbs[0]);
      var lab = cbs[0].closest('label');
      if (lab) {
        var t = lab.querySelector('.browse-filter-checkpanel__text');
        if (t) { measure.style.font = window.getComputedStyle(t).font; }
      }
      document.body.appendChild(measure);
      var maxW = 0;
      for (var j = 0; j < cbs.length; j++) {
        var lab0 = cbs[j].closest('label');
        var tx = lab0 && lab0.querySelector('.browse-filter-checkpanel__text');
        measure.textContent = tx ? (tx.textContent || '') : '';
        maxW = Math.max(maxW, measure.offsetWidth);
      }
      document.body.removeChild(measure);
      var pad = mobileMq.matches ? 50 : 44;
      var cw = scroller.clientWidth;
      if (cw < 2) { cw = mobileMq.matches ? (window.innerWidth || 400) : 500; }
      scroller.style.minWidth = Math.max(cw, maxW + pad) + 'px';
    }
    var sizeT = null;
    function scheduleSize() {
      if (sizeT) clearTimeout(sizeT);
      sizeT = setTimeout(function () { sizeT = null; sizePanelMinWidth(); }, 50);
    }

    function openPanel() {
      beforeOpen();
      root.classList.add('cable-type-mobile-picker--open');
      panel.removeAttribute('hidden');
      if (backdrop) backdrop.removeAttribute('hidden');
      refreshBodyOpen();
      if (btn) btn.setAttribute('aria-expanded', 'true');
      var first = root.querySelector('input[type=checkbox]');
      try { if (first) first.focus(); } catch (e) {}
      requestAnimationFrame(function () {
        requestAnimationFrame(function () {
          scheduleSize();
          /* Horizontální scroll jinak někdy otevře ukázaný konec vpravo (safari/engine). */
          if (root.id === 'browse-cable-type-picker' && scroller) {
            try { scroller.scrollLeft = 0; } catch (e1) {}
            window.setTimeout(function () {
              try { scroller.scrollLeft = 0; } catch (e2) {}
            }, 0);
          }
        });
      });
    }

    function closePanel() {
      root.classList.remove('cable-type-mobile-picker--open');
      panel.setAttribute('hidden', '');
      if (backdrop) backdrop.setAttribute('hidden', '');
      refreshBodyOpen();
      if (btn) { btn.setAttribute('aria-expanded', 'false'); try { btn.focus(); } catch (e) {} }
    }

    if (btn) {
      btn.addEventListener('click', function (ev) {
        ev.preventDefault();
        if (panel && panel.hasAttribute('hidden')) { openPanel(); }
      });
    }
    if (closeBtn) closeBtn.addEventListener('click', function () { closePanel(); });
    if (backdrop) backdrop.addEventListener('click', function () { closePanel(); });

    if (isCable) {
      var vseC = root.querySelector('.js-browse-cable-vse');
      var unsetC = root.querySelector('input.js-browse-cable-unset');
      var cL = root.querySelectorAll('input.js-browse-cable-cb');
      if (vseC) {
        vseC.addEventListener('change', function () {
          var on = vseC.checked;
          for (var a = 0; a < cL.length; a++) cL[a].checked = on;
          if (unsetC) unsetC.checked = on;
          vseC.indeterminate = false;
          syncLabel();
        });
      }
      if (unsetC) unsetC.addEventListener('change', function () { syncLabel(); });
      for (var b = 0; b < cL.length; b++) cL[b].addEventListener('change', function () { syncLabel(); });
    } else {
      var vseS = root.querySelector('.js-browse-status-vse');
      var sL = root.querySelectorAll('input.js-browse-status-cb, input.js-browse-needs-correction');
      if (vseS) {
        vseS.addEventListener('change', function () {
          var on2 = vseS.checked;
          for (var c = 0; c < sL.length; c++) sL[c].checked = on2;
          vseS.indeterminate = false;
          syncLabel();
        });
      }
      for (var d = 0; d < sL.length; d++) sL[d].addEventListener('change', function () { syncLabel(); });
    }
    if (mobileMq.addEventListener) {
      mobileMq.addEventListener('change', function () { if (root.classList.contains('cable-type-mobile-picker--open')) { scheduleSize(); } });
    } else if (mobileMq.addListener) mobileMq.addListener(function () { if (root.classList.contains('cable-type-mobile-picker--open')) { scheduleSize(); } });
    window.addEventListener('pageshow', syncLabel);
    syncLabel();

    return { close: closePanel };
  }

  var cableRoot = document.getElementById('browse-cable-type-picker');
  var statusRoot = document.getElementById('browse-status-picker');
  var closeCable = function () {};
  var closeStatus = function () {};
  if (cableRoot) {
    var ch = initBrowseCheckboxPicker(cableRoot, function () { closeStatus(); });
    if (ch) closeCable = ch.close;
  }
  if (statusRoot) {
    var st = initBrowseCheckboxPicker(statusRoot, function () { closeCable(); });
    if (st) closeStatus = st.close;
  }
  document.addEventListener('keydown', function (ev) {
    if (ev.key !== 'Escape') return;
    if (cableRoot && cableRoot.classList.contains('cable-type-mobile-picker--open')) { ev.preventDefault(); closeCable(); return; }
    if (statusRoot && statusRoot.classList.contains('cable-type-mobile-picker--open')) { ev.preventDefault(); closeStatus(); }
  });

  var browseForm = document.querySelector('form.browse-filters');
  var browseQ = document.getElementById('browse-reel-q');
  var browseHint = document.getElementById('browse-reel-hint');
  var browseTableHost = document.getElementById('browse-spool-table-host');
  var browseReelSearchUrl = {{ path('warehouse_browse_reel_search')|json_encode|raw }};
  var browseDebounceMs = 380;
  var browseSeq = 0;
  var browseTimer = null;

  function browseFilterParams() {
    var p = new URLSearchParams();
    if (!browseForm) return p;
    var fiberCbs = browseForm.querySelectorAll('input.js-browse-fiber-cb:checked');
    for (var f = 0; f < fiberCbs.length; f++) {
      p.append('fiberCounts[]', fiberCbs[f].value);
    }
    var cableCbs = browseForm.querySelectorAll('input.js-browse-cable-cb:checked');
    for (var i = 0; i < cableCbs.length; i++) {
      p.append('cableTypeIds[]', cableCbs[i].value);
    }
    var cableUnset = browseForm.querySelector('input.js-browse-cable-unset');
    if (cableUnset && cableUnset.checked) {
      p.append('cableTypeUnset', '1');
    }
    var statusCbs = browseForm.querySelectorAll('input.js-browse-status-cb:checked');
    for (var j = 0; j < statusCbs.length; j++) {
      p.append('status[]', statusCbs[j].value);
    }
    var kCb = browseForm.querySelector('input.js-browse-needs-correction');
    if (kCb && kCb.checked) {
      p.append('needsCorrection', '1');
    }
    return p;
  }

  function browseTableRows() {
    if (!browseTableHost) return [];
    return browseTableHost.querySelectorAll('tr.browse-spool-row:not(.browse-spool-row--empty)');
  }

  function browseApplyRowFilter(spoolIds, q) {
    var idSet = {};
    if (spoolIds && spoolIds.length) {
      for (var i = 0; i < spoolIds.length; i++) idSet[String(spoolIds[i])] = true;
    }
    var rows = browseTableRows();
    var visible = 0;
    for (var r = 0; r < rows.length; r++) {
      var tr = rows[r];
      var sid = tr.getAttribute('data-spool-id');
      var show = !q || (sid && idSet[sid]);
      tr.hidden = !show;
      if (show) visible++;
    }
    var emptyRow = browseTableHost && browseTableHost.querySelector('tr.browse-spool-row--empty');
    if (emptyRow) emptyRow.hidden = true;
    var noMatch = browseTableHost && browseTableHost.querySelector('#browse-reel-no-match');
    if (q && visible === 0) {
      if (!noMatch && browseTableHost) {
        noMatch = document.createElement('p');
        noMatch.id = 'browse-reel-no-match';
        noMatch.style.cssText = 'color:#333;margin:.5rem 0';
        browseTableHost.appendChild(noMatch);
      }
      if (noMatch) {
        noMatch.hidden = false;
        noMatch.innerHTML = '<strong>Žádná shoda</strong> pro «' + String(q).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;') + '» v aktuálním výběru tabulky.';
      }
    } else if (noMatch) {
      noMatch.hidden = true;
    }
    return visible;
  }

  function browseShowAllRows() {
    var rows = browseTableRows();
    for (var i = 0; i < rows.length; i++) rows[i].hidden = false;
    var noMatch = document.getElementById('browse-reel-no-match');
    if (noMatch) noMatch.hidden = true;
    var emptyRow = browseTableHost && browseTableHost.querySelector('tr.browse-spool-row--empty');
    if (emptyRow) emptyRow.hidden = rows.length > 0;
  }

  function browseRunReelSearch(q, force) {
    q = (q || '').trim();
    if (q.length < 1) {
      if (browseHint) browseHint.textContent = '';
      browseShowAllRows();
      if (window.history && window.history.replaceState) {
        var u0 = new URL(window.location.href);
        u0.searchParams.delete('q');
        window.history.replaceState(null, '', u0.toString());
      }
      return;
    }
    var my = ++browseSeq;
    if (browseHint) browseHint.textContent = 'Načítám…';
    var u = new URL(browseReelSearchUrl, window.location.origin);
    var fp = browseFilterParams();
    fp.set('q', q);
    u.search = fp.toString();
    fetch(u.toString(), {
      credentials: 'same-origin',
      headers: { Accept: 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
    })
      .then(function (res) {
        var ct = res.headers.get('content-type') || '';
        if (ct.indexOf('application/json') === -1) {
          return res.text().then(function () { throw new Error('not json'); });
        }
        return res.json();
      })
      .then(function (data) {
        if (my !== browseSeq) return;
        if (!data || data.ok === false) {
          if (browseHint) browseHint.textContent = (data && data.message) ? ('Chyba: ' + data.message) : 'Chyba hledání.';
          return;
        }
        var visible = browseApplyRowFilter(data.spoolIds || [], q);
        if (browseHint) {
          if (data.count === 0) browseHint.textContent = 'Žádná shoda v tabulce — zkuste Filtrovat nebo upravte dotaz.';
          else if (visible === 0) browseHint.textContent = 'Nalezeno ' + data.count + ' v evidenci, ale žádná řádka v tabulce — stiskněte Filtrovat.';
          else if (data.count === 1) browseHint.textContent = 'Jedna shoda v tabulce.';
          else browseHint.textContent = 'Zobrazeno ' + visible + ' z ' + data.count + ' shod v evidenci.';
        }
        if (window.history && window.history.replaceState) {
          var url = new URL(window.location.href);
          url.searchParams.set('q', q);
          window.history.replaceState(null, '', url.toString());
        }
      })
      .catch(function () {
        if (my !== browseSeq) return;
        if (browseHint) browseHint.textContent = '';
        if (browseForm) browseForm.submit();
      });
  }

  function browseOnReelInput() {
    var q = browseQ ? String(browseQ.value || '').trim() : '';
    clearTimeout(browseTimer);
    browseTimer = setTimeout(function () {
      browseRunReelSearch(browseQ ? browseQ.value : '', false);
    }, browseDebounceMs);
  }

  if (browseQ) {
    browseQ.addEventListener('input', browseOnReelInput);
    browseQ.addEventListener('paste', function () { setTimeout(browseOnReelInput, 0); });
    browseQ.addEventListener('keydown', function (ev) {
      if (ev.key === 'Enter') {
        ev.preventDefault();
        clearTimeout(browseTimer);
        browseRunReelSearch(browseQ.value, true);
      }
    });
  }
  if (browseForm) {
    browseForm.addEventListener('submit', function () {
      clearTimeout(browseTimer);
      browseSeq++;
    });
  }
  if (browseQ && String(browseQ.value || '').trim().length > 0) {
    browseRunReelSearch(browseQ.value, true);
  }
})();
</script>
{% endblock %}

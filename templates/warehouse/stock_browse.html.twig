{% extends 'base.html.twig' %}
{% block title %}Přehled skladu — Optický sklad{% endblock %}
{% block stylesheets %}
    {{ parent() }}
    <style>
        {% include 'warehouse/_cable_type_picker_core_styles.html.twig' %}
        .browse-filters__row {
            display: flex;
            flex-direction: column;
            align-items: stretch;
            gap: 0.75rem;
            margin: 0 0 0.5rem;
        }
        .browse-filters__col {
            display: flex;
            flex-direction: column;
            gap: 0.25rem;
            min-width: 0;
        }
        .browse-filters__col--submit { flex: 0 0 auto; }
        .browse-filters__row button[type="submit"] { min-height: 2.5rem; }
        .browse-inventura-btn-line { margin: 0.35rem 0 0.75rem; }
        .browse-inventura-btn-line .warehouse-pill {
            display: inline-flex;
            width: auto;
            max-width: max-content;
            flex: 0 0 auto;
        }
        /* sloupec se nerozmačká pod šířku textu; na úzkém řádku horizontální scroll uvnitř rámečku */
        .browse-filters__col.browse-filters__col--usageReport {
            min-width: min(100%, max-content);
            flex: 0 1 auto;
            max-width: 100%;
        }
        .browse-filters__col--usageReport > label { font-size: 0.95rem; }
        .browse-filters__proj-feed-link {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 100%;
            max-width: 100%;
            min-height: 2.5rem;
            padding: 0.4rem 0.5rem;
            text-align: center;
            line-height: 1.2;
            font: inherit;
            font-size: 0.95rem;
            border: 1px solid #999;
            border-radius: 4px;
            background: #fff;
            color: #1a1a1a;
            text-decoration: none;
            box-sizing: border-box;
            white-space: nowrap;
            overflow-x: auto;
            overflow-y: hidden;
            -webkit-overflow-scrolling: touch;
        }
        .browse-filters__proj-feed-link:hover,
        .browse-filters__proj-feed-link:focus-visible {
            background: #f5f5f5;
            color: #0a1628;
            outline: none;
        }
        @media (min-width: 42rem) {
            .browse-filters__col--usageReport {
                margin-left: 0.55rem;
            }
        }
        @media (max-width: 41.99rem) {
            .browse-filters__col--usageReport {
                margin-top: 0.35rem;
            }
        }
        @media (min-width: 42rem) {
            .browse-filters__row {
                flex-direction: row;
                flex-wrap: wrap;
                align-items: flex-end;
            }
            .browse-filters__col--equal { flex: 1 1 0; min-width: 0; }
        }
        .browse-filter-checkpanel {
            display: flex;
            flex-direction: column;
            gap: 0.1rem;
            min-width: 0;
        }
        .browse-filter-checkpanel__row {
            display: grid;
            grid-template-columns: minmax(0, 1fr) auto;
            align-items: center;
            gap: 0.6rem 0.9rem;
            padding: 0.4rem 0.5rem;
            border-radius: 4px;
            margin: 0;
            font: inherit;
            font-size: 0.95rem;
            cursor: pointer;
            -webkit-tap-highlight-color: transparent;
        }
        .browse-filter-checkpanel__row:hover { background: rgba(0,0,0,0.05); }
        .browse-filter-checkpanel__row--all {
            font-weight: 600;
            border-bottom: 1px solid #ccc;
            margin-bottom: 0.2rem;
            padding-bottom: 0.5rem;
        }
        .browse-filter-checkpanel__text {
            min-width: 0;
            text-align: left;
            line-height: 1.3;
        }
        .browse-filter-checkpanel__row input[type="checkbox"] {
            width: 1.15rem;
            height: 1.15rem;
            flex-shrink: 0;
            margin: 0;
        }
    </style>
{% endblock %}
{% block body %}
    {% include '_app_menu_cz.html.twig' %}
    <h1>Přehled skladu</h1>
    <p class="browse-inventura-btn-line"><a href="{{ path('warehouse_browse_inventura') }}" class="warehouse-pill">Inventura</a></p>
    <p class="lede">Přehled cívek podle typu a stavu; vhodné pro <strong>kontrolu zásob</strong> a přípravu <strong>inventury</strong> (samostatný inventurní režim můžeme doplnit).</p>

    <form method="get" action="{{ path('warehouse_browse_index') }}" class="browse-filters" style="margin-bottom: 1rem;">
        <div class="browse-filters__row">
            <div class="browse-filters__col browse-filters__col--equal">
                <label for="browse-cable-type-btn">Typ kabelu</label>
                <div class="cable-type-mobile-picker" id="browse-cable-type-picker" data-browse-mode="cable">
                    <button type="button" class="cable-type-mobile-picker__toggle" id="browse-cable-type-btn" aria-haspopup="dialog" aria-expanded="false" aria-controls="browse-cable-type-panel">
                        <span class="cable-type-mobile-picker__text" id="browse-cable-type-label">{% if cableTypeFilterIsAll|default(false) %}Všechny typy{% elseif cableTypeFilterIsNone|default(false) %}— všechny —{% else %}…{% endif %}</span>
                        <span class="cable-type-mobile-picker__chev" aria-hidden="true">▼</span>
                    </button>
                    <div class="cable-type-mobile-picker__backdrop" id="browse-cable-type-backdrop" hidden></div>
                    <div class="cable-type-mobile-picker__panel" id="browse-cable-type-panel" role="dialog" aria-label="Typ kabelu" hidden>
                        <div class="cable-type-mobile-picker__bar">
                            <span class="cable-type-mobile-picker__title">Typ kabelu</span>
                            <button type="button" class="cable-type-mobile-picker__close" id="browse-cable-type-close" aria-label="Zavřít">×</button>
                        </div>
                        <div class="cable-type-mobile-picker__scroller">
                            <div class="browse-filter-checkpanel" role="group" aria-label="Výběr typu kabelu">
                                <label class="browse-filter-checkpanel__row browse-filter-checkpanel__row--all">
                                    <span class="browse-filter-checkpanel__text">Vše</span>
                                    <input type="checkbox" class="js-browse-cable-vse" aria-label="Vše: zaškrtnout všechny typy" title="Vše" tabindex="0">
                                </label>
                                {% for ct in cableTypeChoices %}
                                    <label class="browse-filter-checkpanel__row">
                                        <span class="browse-filter-checkpanel__text">{{ ct.code }} — {{ ct.name }}</span>
                                        <input type="checkbox" name="cableTypeIds[]" value="{{ ct.id }}" class="js-browse-cable-cb" data-browse-label="{{ ct.code|e('html_attr') }} — {{ ct.name|e('html_attr') }}"{% if ct.id in filterCableTypeIds %} checked{% endif %}>
                                    </label>
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="browse-filters__col browse-filters__col--equal">
                <label for="browse-status-btn">Stav cívky</label>
                <div class="cable-type-mobile-picker" id="browse-status-picker" data-browse-mode="status">
                    <button type="button" class="cable-type-mobile-picker__toggle" id="browse-status-btn" aria-haspopup="dialog" aria-expanded="false" aria-controls="browse-status-panel">
                        <span class="cable-type-mobile-picker__text" id="browse-status-label">{% if allStatusesSelected|default(false) %}Všechny stavy{% elseif filterStatusValues|length == 1 and filterStatusValues[0] == 'in_stock' %}na skladě{% elseif filterStatusValues|length == 1 and filterStatusValues[0] == 'transferred' %}předáno{% elseif filterStatusValues|length == 1 and filterStatusValues[0] == 'written_off' %}vyřazeno{% else %}…{% endif %}</span>
                        <span class="cable-type-mobile-picker__chev" aria-hidden="true">▼</span>
                    </button>
                    <div class="cable-type-mobile-picker__backdrop" id="browse-status-backdrop" hidden></div>
                    <div class="cable-type-mobile-picker__panel" id="browse-status-panel" role="dialog" aria-label="Stav cívky" hidden>
                        <div class="cable-type-mobile-picker__bar">
                            <span class="cable-type-mobile-picker__title">Stav cívky</span>
                            <button type="button" class="cable-type-mobile-picker__close" id="browse-status-close" aria-label="Zavřít">×</button>
                        </div>
                        <div class="cable-type-mobile-picker__scroller">
                            <div class="browse-filter-checkpanel" role="group" aria-label="Výběr stavu cívky">
                                <label class="browse-filter-checkpanel__row browse-filter-checkpanel__row--all">
                                    <span class="browse-filter-checkpanel__text">Vše</span>
                                    <input type="checkbox" class="js-browse-status-vse" aria-label="Vše: všechny stavy" title="Vše" tabindex="0">
                                </label>
                                <label class="browse-filter-checkpanel__row">
                                    <span class="browse-filter-checkpanel__text">na skladě</span>
                                    <input type="checkbox" name="status[]" value="in_stock" class="js-browse-status-cb" data-browse-label="na skladě"{% if 'in_stock' in filterStatusValues %} checked{% endif %}>
                                </label>
                                <label class="browse-filter-checkpanel__row">
                                    <span class="browse-filter-checkpanel__text">předáno</span>
                                    <input type="checkbox" name="status[]" value="transferred" class="js-browse-status-cb" data-browse-label="předáno"{% if 'transferred' in filterStatusValues %} checked{% endif %}>
                                </label>
                                <label class="browse-filter-checkpanel__row">
                                    <span class="browse-filter-checkpanel__text">vyřazeno</span>
                                    <input type="checkbox" name="status[]" value="written_off" class="js-browse-status-cb" data-browse-label="vyřazeno"{% if 'written_off' in filterStatusValues %} checked{% endif %}>
                                </label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="browse-filters__col browse-filters__col--submit">
                <button type="submit">Filtrovat</button>
            </div>
            <div class="browse-filters__col browse-filters__col--equal browse-filters__col--usageReport">
                <label for="browse-usage-proj-link">Podle zakázky</label>
                <a id="browse-usage-proj-link" href="{{ path('warehouse_browse_usage_by_project') }}" class="browse-filters__proj-feed-link">Filtr podle projektů</a>
            </div>
        </div>
    </form>

    {% include 'warehouse/_spool_table.html.twig' with { spools: spools } only %}

    <p><a href="{{ path('warehouse_dashboard') }}">Číselný přehled (dashboard)</a> ·
       <a href="{{ path('warehouse_spool_index') }}">Běžná práce s cívkami</a></p>
<script>
(function () {
  var mobileMq = window.matchMedia('(max-width: 41.99rem)');

  function refreshBodyOpen() {
    if (document.querySelector('.browse-filters .cable-type-mobile-picker--open')) {
      document.body.classList.add('spool-cable-panel-open');
    } else {
      document.body.classList.remove('spool-cable-panel-open');
    }
  }

  function czTypu(n) {
    if (n === 1) return '1 typ';
    if (n >= 2 && n <= 4) return n + ' typy';
    return n + ' typů';
  }
  function czStavu(n) {
    if (n === 1) return '1 stav';
    if (n >= 2 && n <= 4) return n + ' stavy';
    return n + ' stavů';
  }

  function summarizeCable(root) {
    var cbs = root.querySelectorAll('input.js-browse-cable-cb');
    var t = cbs.length;
    var n = 0;
    var labels = [];
    for (var i = 0; i < cbs.length; i++) {
      if (cbs[i].checked) {
        n++;
        labels.push(cbs[i].getAttribute('data-browse-label') || '');
      }
    }
    if (t === 0) return '— všechny —';
    if (n === 0) return '— všechny —';
    if (n === t) return 'Všechny typy';
    if (n === 1) return labels[0] || '…';
    return czTypu(n);
  }
  function summarizeStatus(root) {
    var cbs = root.querySelectorAll('input.js-browse-status-cb');
    var t = cbs.length;
    if (t !== 3) return '…';
    var n = 0;
    var labels = [];
    for (var i = 0; i < cbs.length; i++) {
      if (cbs[i].checked) {
        n++;
        labels.push(cbs[i].getAttribute('data-browse-label') || '');
      }
    }
    if (n === 0) return '— všechny —';
    if (n === 3) return 'Všechny stavy';
    if (n === 1) return labels[0] || '…';
    return czStavu(n);
  }

  function syncCableVse(root) {
    var vse = root.querySelector('.js-browse-cable-vse');
    var cbs = root.querySelectorAll('input.js-browse-cable-cb');
    if (!vse) return;
    if (!cbs.length) {
      vse.indeterminate = false;
      vse.checked = false;
      vse.setAttribute('disabled', 'disabled');
      return;
    }
    vse.removeAttribute('disabled');
    var n = 0;
    for (var i = 0; i < cbs.length; i++) if (cbs[i].checked) n++;
    vse.indeterminate = n > 0 && n < cbs.length;
    vse.checked = n === cbs.length;
  }
  function syncStatusVse(root) {
    var vse = root.querySelector('.js-browse-status-vse');
    var cbs = root.querySelectorAll('input.js-browse-status-cb');
    if (!vse || cbs.length !== 3) return;
    var n = 0;
    for (var j = 0; j < cbs.length; j++) if (cbs[j].checked) n++;
    vse.indeterminate = n > 0 && n < 3;
    vse.checked = n === 3;
  }

  function initBrowseCheckboxPicker(root, beforeOpen) {
    var btn = root.querySelector('.cable-type-mobile-picker__toggle');
    var labelEl = root.querySelector('.cable-type-mobile-picker__text');
    var panel = root.querySelector('.cable-type-mobile-picker__panel');
    var backdrop = root.querySelector('.cable-type-mobile-picker__backdrop');
    var closeBtn = root.querySelector('.cable-type-mobile-picker__close');
    var scroller = root.querySelector('.cable-type-mobile-picker__scroller');
    var isCable = (root.getAttribute('data-browse-mode') || '') === 'cable';
    if (!panel) return;
    if (typeof beforeOpen !== 'function') { beforeOpen = function () {}; }

    function syncLabel() {
      if (!labelEl) return;
      if (isCable) syncCableVse(root);
      else syncStatusVse(root);
      labelEl.textContent = isCable ? summarizeCable(root) : summarizeStatus(root);
    }

    function sizePanelMinWidth() {
      if (!scroller) return;
      var cbs = root.querySelectorAll('input[type=checkbox]');
      if (!cbs.length) return;
      var measure = document.createElement('div');
      measure.setAttribute('aria-hidden', 'true');
      measure.style.cssText = 'position:absolute;left:-9999px;top:0;white-space:nowrap;visibility:hidden;pointer-events:none;';
      var cs = window.getComputedStyle(cbs[0].closest('label') || cbs[0]);
      var lab = cbs[0].closest('label');
      if (lab) {
        var t = lab.querySelector('.browse-filter-checkpanel__text');
        if (t) { measure.style.font = window.getComputedStyle(t).font; }
      }
      document.body.appendChild(measure);
      var maxW = 0;
      for (var j = 0; j < cbs.length; j++) {
        var lab0 = cbs[j].closest('label');
        var tx = lab0 && lab0.querySelector('.browse-filter-checkpanel__text');
        measure.textContent = tx ? (tx.textContent || '') : '';
        maxW = Math.max(maxW, measure.offsetWidth);
      }
      document.body.removeChild(measure);
      var pad = mobileMq.matches ? 50 : 44;
      var cw = scroller.clientWidth;
      if (cw < 2) { cw = mobileMq.matches ? (window.innerWidth || 400) : 500; }
      scroller.style.minWidth = Math.max(cw, maxW + pad) + 'px';
    }
    var sizeT = null;
    function scheduleSize() {
      if (sizeT) clearTimeout(sizeT);
      sizeT = setTimeout(function () { sizeT = null; sizePanelMinWidth(); }, 50);
    }

    function openPanel() {
      beforeOpen();
      root.classList.add('cable-type-mobile-picker--open');
      panel.removeAttribute('hidden');
      if (backdrop) backdrop.removeAttribute('hidden');
      refreshBodyOpen();
      if (btn) btn.setAttribute('aria-expanded', 'true');
      var first = root.querySelector('input[type=checkbox]');
      try { if (first) first.focus(); } catch (e) {}
      requestAnimationFrame(function () { requestAnimationFrame(function () { scheduleSize(); }); });
    }

    function closePanel() {
      root.classList.remove('cable-type-mobile-picker--open');
      panel.setAttribute('hidden', '');
      if (backdrop) backdrop.setAttribute('hidden', '');
      refreshBodyOpen();
      if (btn) { btn.setAttribute('aria-expanded', 'false'); try { btn.focus(); } catch (e) {} }
    }

    if (btn) {
      btn.addEventListener('click', function (ev) {
        ev.preventDefault();
        if (panel && panel.hasAttribute('hidden')) { openPanel(); }
      });
    }
    if (closeBtn) closeBtn.addEventListener('click', function () { closePanel(); });
    if (backdrop) backdrop.addEventListener('click', function () { closePanel(); });

    if (isCable) {
      var vseC = root.querySelector('.js-browse-cable-vse');
      var cL = root.querySelectorAll('input.js-browse-cable-cb');
      if (vseC) {
        vseC.addEventListener('change', function () {
          var on = vseC.checked;
          for (var a = 0; a < cL.length; a++) cL[a].checked = on;
          vseC.indeterminate = false;
          syncLabel();
        });
      }
      for (var b = 0; b < cL.length; b++) cL[b].addEventListener('change', function () { syncLabel(); });
    } else {
      var vseS = root.querySelector('.js-browse-status-vse');
      var sL = root.querySelectorAll('input.js-browse-status-cb');
      if (vseS) {
        vseS.addEventListener('change', function () {
          var on2 = vseS.checked;
          for (var c = 0; c < sL.length; c++) sL[c].checked = on2;
          vseS.indeterminate = false;
          syncLabel();
        });
      }
      for (var d = 0; d < sL.length; d++) sL[d].addEventListener('change', function () { syncLabel(); });
    }
    if (mobileMq.addEventListener) {
      mobileMq.addEventListener('change', function () { if (root.classList.contains('cable-type-mobile-picker--open')) { scheduleSize(); } });
    } else if (mobileMq.addListener) mobileMq.addListener(function () { if (root.classList.contains('cable-type-mobile-picker--open')) { scheduleSize(); } });
    window.addEventListener('pageshow', syncLabel);
    syncLabel();

    return { close: closePanel };
  }

  var cableRoot = document.getElementById('browse-cable-type-picker');
  var statusRoot = document.getElementById('browse-status-picker');
  var closeCable = function () {};
  var closeStatus = function () {};
  if (cableRoot) {
    var ch = initBrowseCheckboxPicker(cableRoot, function () { closeStatus(); });
    if (ch) closeCable = ch.close;
  }
  if (statusRoot) {
    var st = initBrowseCheckboxPicker(statusRoot, function () { closeCable(); });
    if (st) closeStatus = st.close;
  }
  document.addEventListener('keydown', function (ev) {
    if (ev.key !== 'Escape') return;
    if (cableRoot && cableRoot.classList.contains('cable-type-mobile-picker--open')) { ev.preventDefault(); closeCable(); return; }
    if (statusRoot && statusRoot.classList.contains('cable-type-mobile-picker--open')) { ev.preventDefault(); closeStatus(); }
  });
})();
</script>
{% endblock %}

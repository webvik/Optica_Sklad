{% extends 'base.html.twig' %}
{% block title %}Změna hesla{% endblock %}
{% block stylesheets %}
    {{ parent() }}
    {% include '_styles_spool_form_layout.html.twig' %}
{% endblock %}
{% block body %}
    <nav class="app-menu app-menu--toolbar" aria-label="Účet a navigace správy">
        {% include '_app_menu_cz_top.html.twig' %}
    </nav>
    <p style="margin:0 0 1rem"><a href="{{ path('app_home') }}">← zpět na domů</a></p>
    <h1>Změna hesla</h1>
    <p class="spool-form" style="margin: 0 0 1rem; max-width: 40rem">
        Po změně použijte nové heslo při dalším přihlášení.
    </p>

    {{ form_start(form, { attr: { class: 'spool-form', id: 'account-change-password-form' } }) }}
        <div class="spool-form__field">
            {{ form_label(form.currentPassword) }}
            <div class="spool-form__value">
                {{ form_widget(form.currentPassword, { attr: { 'aria-label': form.currentPassword.vars.label } }) }}
                {{ form_errors(form.currentPassword) }}
            </div>
        </div>
        <div class="spool-form__field">
            {{ form_label(form.newPassword.first) }}
            <div class="spool-form__value">
                {{ form_widget(form.newPassword.first, { attr: { 'aria-label': form.newPassword.first.vars.label } }) }}
                {{ form_errors(form.newPassword.first) }}
            </div>
        </div>
        <div class="spool-form__field">
            {{ form_label(form.newPassword.second) }}
            <div class="spool-form__value">
                {{ form_widget(form.newPassword.second, { attr: { 'aria-label': form.newPassword.second.vars.label } }) }}
                {{ form_errors(form.newPassword.second) }}
                {{ form_errors(form.newPassword) }}
            </div>
        </div>
        {% do form.newPassword.setRendered() %}
        <div class="spool-form__field spool-form__row--actions" style="margin-top: 0.25rem; margin-bottom: 0.25rem;">
            <span class="spool-form__row--action-spacer" aria-hidden="true"></span>
            <div class="spool-form__value spool-form__value--actions">
                <div class="spool-form__actions spool-form__actions--submit-only" role="group" aria-label="Akce">
                    <button type="submit" class="spool-form__btn">Uložit nové heslo</button>
                </div>
            </div>
        </div>
        {{ form_rest(form) }}
    {{ form_end(form, { render_rest: false }) }}
{% endblock %}

<!DOCTYPE html>
<html lang="cs">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <link rel="icon" href="/favicon.svg" type="image/svg+xml">
        <link rel="apple-touch-icon" href="/favicon.svg">
        <meta name="theme-color" content="#0f2847">
        <title>{% block title %}Welcome!{% endblock %}</title>
        <style>
            *, *::before, *::after { box-sizing: border-box; }
            :root { font-family: system-ui, -apple-system, 'Segoe UI', sans-serif; line-height: 1.45; }
            html { -webkit-text-size-adjust: 100%; }
            body {
                margin: 0;
                padding: 0.75rem max(0.75rem, env(safe-area-inset-right)) max(1rem, env(safe-area-inset-bottom)) max(0.75rem, env(safe-area-inset-left));
            }
            a { color: #06c; -webkit-tap-highlight-color: rgba(0, 102, 204, 0.12); }
            .app-menu a { -webkit-tap-highlight-color: rgba(0, 102, 204, 0.15); }
            .app-menu { margin-bottom: 0; }
            .app-menu__top {
                display: flex;
                flex-direction: column;
                align-items: stretch;
                gap: 0.55rem;
                margin-bottom: .75rem;
            }
            .app-menu__top-row--account {
                display: flex;
                justify-content: space-between;
                align-items: center;
                flex-wrap: wrap;
                gap: .5rem .75rem;
            }
            .app-menu__top-row--account > a {
                min-height: 2.75rem;
                display: inline-flex;
                align-items: center;
                padding: 0.2rem 0;
            }
            .app-menu__top-row--admin {
                display: flex;
                flex-wrap: wrap;
                align-items: stretch;
                gap: 0.45rem 0.55rem;
            }
            .app-menu__top-row--admin .warehouse-pill {
                flex: 1 1 auto;
                min-width: min(14rem, 100%);
                white-space: normal;
                text-wrap: balance;
            }
            .app-menu__list { list-style: none; padding: 0; margin: 0; display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: stretch; }
            /* Rozložení pills — barvy v _styles_ui_buttons.html.twig */
            a.app-menu__nav-link, a.warehouse-pill, button.warehouse-pill {
                box-sizing: border-box; display: flex; align-items: center; justify-content: center;
                text-align: center; text-decoration: none; line-height: 1.2;
                min-height: 2.55rem; padding: 0.4rem 0.6rem; font-size: 0.92rem;
                border-radius: 6px;
                -webkit-tap-highlight-color: transparent;
            }
            @media (max-width: 48rem) {
                .app-menu__list {
                    flex-direction: column;
                    flex-wrap: nowrap;
                    gap: 0.5rem;
                    width: 100%;
                    align-items: stretch;
                }
                .app-menu__list li {
                    flex: 0 0 auto;
                    width: 100%;
                    min-width: 0;
                }
                a.app-menu__nav-link {
                    width: 100%;
                    min-height: 2.9rem;
                    padding: 0.52rem 0.65rem;
                    font-size: 1.1rem;
                    line-height: 1.28;
                }
                a.warehouse-pill,
                button.warehouse-pill {
                    font-size: 1.1rem;
                    line-height: 1.25;
                }
                input[type="submit"],
                input[type="button"]:not(.error-modal-x):not(.success-modal-x):not(.beta-welcome-x),
                input[type="reset"],
                button:not(.error-modal-x):not(.success-modal-x):not(.beta-welcome-x):not(.warehouse-pill) {
                    font-size: 1.05rem;
                }
                .error-modal-ok,
                .success-modal-ok,
                .beta-welcome-ok {
                    font-size: 1.05rem;
                }
                /* Ruční vstup na mobilu: větší písmo a dotyk. cable-type-list = dlouhý výběr typu — beze změny (globálně + picker). */
                input[type="text"],
                input[type="search"],
                input[type="password"],
                input[type="email"],
                input[type="tel"],
                input[type="url"],
                input[type="number"],
                input[type="date"],
                input[type="datetime-local"],
                input[type="time"],
                input[type="month"],
                input[type="week"],
                textarea,
                select:not(.cable-type-list) {
                    font-size: 1.05rem;
                    line-height: 1.35;
                    min-height: 2.65rem;
                    padding: 0.42rem 0.5rem;
                }
                textarea {
                    min-height: 5.75rem;
                }
                .app-menu__top-row--admin {
                    flex-wrap: nowrap;
                    gap: 0.45rem;
                }
                .app-menu__top-row--admin .warehouse-pill {
                    flex: 1 1 0;
                    min-width: 0;
                    font-size: 0.98rem;
                    padding-left: 0.4rem;
                    padding-right: 0.4rem;
                    line-height: 1.2;
                }
            }
            .table-scroll { overflow-x: auto; -webkit-overflow-scrolling: touch; max-width: 100%; }
            .table-scroll > table { min-width: 100%; }
            .table-scroll--wide > table { min-width: 40rem; }
            .browse-filters { display: flex; flex-wrap: wrap; gap: 1rem; align-items: flex-end; margin-bottom: 1rem; }
            @media (max-width: 36rem) {
                .browse-filters { flex-direction: column; align-items: stretch; }
                .browse-filters p { width: 100%; margin: 0; }
                .browse-filters select, .browse-filters button { width: 100%; min-height: 2.75rem; font-size: 1.06rem; }
                .browse-filters select.cable-type-list { min-height: unset; }
            }
            /* Long cable-type list: listbox + scroll (native dropdown is often not scrollable on mobile) */
            select.cable-type-list {
                display: block;
                width: 100%;
                max-width: 36rem;
                min-height: 0;
                max-height: min(14rem, 42vh);
                overflow-y: auto;
                -webkit-overflow-scrolling: touch;
                padding: 0.3rem 0.45rem;
                font-size: 0.95rem;
                line-height: 1.3;
                border: 1px solid #999;
                border-radius: 4px;
                background: #fff;
            }
            select.cable-type-list:focus { outline: 2px solid #6ae; outline-offset: 1px; }
            .flash-stack { position: sticky; top: 0; z-index: 1000; margin: 0; padding: 0; }
            .flashes p { margin: .5rem 0; padding: .65rem 1rem; border-radius: 4px; max-width: min(52rem, 100%); }
            .flashes .success { background: #efe; color: #060; border: 1px solid #b8d4b8; }
            .flashes .flash-info { background: #e8f3ff; color: #036; border: 1px solid #9cc2e6; }
            .error-modal-overlay {
                position: fixed; inset: 0; z-index: 20000; display: flex; align-items: center; justify-content: center;
                padding: 1rem; background: rgba(0,0,0,.45); box-sizing: border-box;
            }
            .error-modal-panel {
                position: relative; max-width: 28rem; width: 100%; margin: 0; padding: 1.15rem 1.25rem 1rem;
                background: #fff; color: #1a1a1a; border-radius: 8px; border: 1px solid #d8a0a0;
                box-shadow: 0 8px 32px rgba(0,0,0,.2);
            }
            .error-modal-title { font-size: 1.1rem; margin: 0 0 .65rem; color: #800; }
            .error-modal-text { margin: 0; line-height: 1.5; }
            .error-modal-text + .error-modal-text { margin-top: .75rem; }
            .error-modal-x {
                position: absolute; top: .45rem; right: .5rem; width: 2rem; height: 2rem; padding: 0; border: 0; border-radius: 4px;
                background: transparent; color: #666; font-size: 1.4rem; line-height: 1; cursor: pointer;
            }
            .error-modal-x:hover { background: #f0f0f0; color: #111; }
            .error-modal-ok {
                display: block; width: 100%; margin-top: 1.1rem; padding: .55rem 1rem; font-size: 1rem; cursor: pointer;
                background: #c33; color: #fff; border: 0; border-radius: 6px; font-weight: 600;
            }
            .error-modal-ok:hover { background: #a22; }
            .success-modal-overlay {
                position: fixed; inset: 0; z-index: 20000; display: flex; align-items: center; justify-content: center;
                padding: 1rem; background: rgba(0,0,0,.4); box-sizing: border-box;
            }
            .success-modal-panel {
                position: relative; max-width: 30rem; width: 100%; margin: 0; padding: 1.15rem 1.25rem 1rem;
                background: #fff; color: #1a1a1a; border-radius: 8px; border: 1px solid #8bc48b;
                box-shadow: 0 8px 32px rgba(0,0,0,.2);
            }
            .success-modal-title { font-size: 1.1rem; margin: 0 0 .65rem; color: #0a4d0a; }
            .success-modal-text { margin: 0; line-height: 1.5; }
            .success-modal-text + .success-modal-text { margin-top: .75rem; }
            .success-modal-x {
                position: absolute; top: .45rem; right: .5rem; width: 2rem; height: 2rem; padding: 0; border: 0; border-radius: 4px;
                background: transparent; color: #666; font-size: 1.4rem; line-height: 1; cursor: pointer;
            }
            .success-modal-x:hover { background: #f0f0f0; color: #111; }
            .success-modal-ok {
                display: block; width: 100%; margin-top: 1.1rem; padding: .55rem 1rem; font-size: 1rem; cursor: pointer;
                background: #2a6a2a; color: #fff; border: 0; border-radius: 6px; font-weight: 600;
            }
            .success-modal-ok:hover { background: #215421; }
            .beta-welcome-overlay {
                position: fixed; inset: 0; z-index: 20000; display: flex; align-items: center; justify-content: center;
                padding: 1rem; background: rgba(0,0,0,.4); box-sizing: border-box;
            }
            .beta-welcome-panel {
                position: relative; max-width: 34rem; width: 100%; max-height: min(78vh, 32rem); overflow-y: auto;
                margin: 0; padding: 1.15rem 1.25rem 1rem;
                background: #fff; color: #1a1a1a; border-radius: 8px; border: 1px solid #7ea3c9;
                box-shadow: 0 8px 32px rgba(0,0,0,.2);
            }
            .beta-welcome-title { font-size: 1.1rem; margin: 0 0 .65rem; color: #1e4a73; }
            .beta-welcome-text { margin: 0; line-height: 1.55; }
            .beta-welcome-text + .beta-welcome-text { margin-top: .75rem; }
            .beta-welcome-x {
                position: absolute; top: .45rem; right: .5rem; width: 2rem; height: 2rem; padding: 0; border: 0; border-radius: 4px;
                background: transparent; color: #666; font-size: 1.4rem; line-height: 1; cursor: pointer;
            }
            .beta-welcome-x:hover { background: #f0f0f0; color: #111; }
            .beta-welcome-ok {
                display: block; width: 100%; margin-top: 1.15rem; padding: .55rem 1rem; font-size: 1rem; cursor: pointer;
                background: #2a5894; color: #fff; border: 0; border-radius: 6px; font-weight: 600;
            }
            .beta-welcome-ok:hover { background: #234a79; }
            .beta-welcome-overlay[hidden] { display: none !important; }
            .beta-welcome-root { margin: 0; }
            button.beta-welcome-chip {
                width: 100%;
                max-width: 100%;
                box-sizing: border-box;
                margin: 0.45rem 0 0.85rem;
                cursor: pointer;
                font: inherit;
                font-weight: 600;
                color: #14521f;
                border: 1px solid #8bc894;
                background: linear-gradient(180deg, #e9f8ec 0%, #c8e8cf 100%);
            }
            button.beta-welcome-chip:hover {
                color: #0d3a16;
                border-color: #6fb87c;
                background: linear-gradient(180deg, #dff3e3 0%, #b8deb8 100%);
            }
            button.beta-welcome-chip:active {
                background: #a8d4b2;
                border-color: #5aa86a;
            }
            .beta-welcome-text--contact a { font-weight: 600; }
            body.flash-center-open { overflow: hidden; }
            table { border-collapse: collapse; width: 100%; }
            th, td { border: 1px solid #ccc; padding: .4rem .6rem; text-align: left; }
            @media (max-width: 36rem) {
                th, td { padding: 0.5rem 0.45rem; font-size: 0.92rem; }
            }
            .spool-diary-table { table-layout: fixed; width: 100%; }
            .spool-diary-table th:nth-child(1), .spool-diary-table td:nth-child(1) {
                width: 3.6rem; max-width: 3.6rem; padding: 0.35rem 0.3rem; text-align: right; font-variant-numeric: tabular-nums;
            }
            .spool-diary-table th:nth-child(2), .spool-diary-table td:nth-child(2) {
                width: 3.9rem; max-width: 3.9rem; padding: 0.35rem 0.3rem; text-align: right; font-variant-numeric: tabular-nums;
            }
        </style>
        {% block stylesheets %}
        {% endblock %}
        {% include '_styles_ui_buttons.html.twig' %}

        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
        {% endif %}
    </head>
    <body>
        <div class="flash-stack" id="global-flash-stack">
        {% for message in app.flashes('success') %}
            <div class="flashes" role="status" data-flash-severity="success"><p class="success">{{ message }}</p></div>
        {% endfor %}
        {% for message in app.flashes('info') %}
            <div class="flashes" role="status" data-flash-severity="info"><p class="flash-info">{{ message }}</p></div>
        {% endfor %}
        </div>
        {% set error_flash_list = app.flashes('error') %}
        {% if error_flash_list|length > 0 %}
        <div id="error-flash-modal" class="error-modal-overlay" role="alertdialog" aria-modal="true" aria-labelledby="error-flash-modal-title">
            <div class="error-modal-panel">
                <button type="button" class="error-modal-x" data-flash-center-close aria-label="Zavřít">×</button>
                <h2 id="error-flash-modal-title" class="error-modal-title">Nelze uložit</h2>
                {% for message in error_flash_list %}
                <p class="error-modal-text">{{ message }}</p>
                {% endfor %}
                <button type="button" class="error-modal-ok" data-flash-center-close>Rozumím</button>
            </div>
        </div>
        {% endif %}
        {% set success_modal_list = app.flashes('success_modal') %}
        {% if success_modal_list|length > 0 %}
        <div id="success-flash-modal" class="success-modal-overlay" role="alertdialog" aria-modal="true" aria-labelledby="success-flash-modal-title">
            <div class="success-modal-panel">
                <button type="button" class="success-modal-x" data-flash-center-close aria-label="Zavřít">×</button>
                <h2 id="success-flash-modal-title" class="success-modal-title">Zaevidováno</h2>
                {% for message in success_modal_list %}
                <p class="success-modal-text">{{ message }}</p>
                {% endfor %}
                <button type="button" class="success-modal-ok" data-flash-center-close>Rozumím</button>
            </div>
        </div>
        {% endif %}
        {% if app.user and beta_welcome_enabled() %}
        {% set beta_login_hints = app.flashes('beta_welcome_open') %}
        <div id="beta-welcome-root" data-beta-auto-open-after-login="{{ beta_login_hints|length > 0 ? '1' : '0' }}">
            <div id="beta-welcome-modal" class="beta-welcome-overlay" role="dialog" aria-modal="true" aria-labelledby="beta-welcome-modal-title" aria-hidden="true" hidden tabindex="-1">
                <div class="beta-welcome-panel" tabindex="-1">
                    <button type="button" class="beta-welcome-x" data-beta-close aria-label="Zavřít">×</button>
                    <h2 id="beta-welcome-modal-title" class="beta-welcome-title">Beta verze aplikace</h2>
                    {% for text in beta_welcome_paragraphs() %}
                    <p class="beta-welcome-text">{{ text }}</p>
                    {% endfor %}
                    {% set waHref = beta_whatsapp_contact_url() %}
                    {% if waHref %}
                    <p class="beta-welcome-text beta-welcome-text--contact">
                        Rychlé hlášení chyb vývojáři (Viktor Burlak) přes WhatsApp{% if beta_whatsapp_contact_label() %} ({{ beta_whatsapp_contact_label() }}){% endif %}:
                        <a href="{{ waHref }}" target="_blank" rel="noopener noreferrer">otevřít konverzaci</a>.
                    </p>
                    {% endif %}
                    <button type="button" class="beta-welcome-ok" data-beta-close>Rozumím</button>
                </div>
            </div>
            <button type="button" class="warehouse-pill beta-welcome-chip" id="beta-welcome-chip" hidden>Beta testování</button>
        </div>
        {% endif %}
        {% block body %}{% endblock %}
        {% block javascripts %}
        {% endblock %}
        <script src="/js/capacitor-share-pdf.js?v=4"></script>
        <script>
        (function () {
            /**
             * Výchozí 0 na číselných polích (type=number): select/setSelectionRange v Chromium často nefunguje.
             * řešení: při hodnotě „jen nula“ první stisk číslice / vkládání nahradí místo prefixu „0…“.
             */
            function isZeroPlaceholder(v) {
                if (typeof v !== 'string' || /[eE]/.test(v)) return false;
                var s = v.trim();

                return /^-?0+(?:\\.0*)?$/.test(s);
            }

            function fieldSelector() {
                return (
                    'input[type="number"]:not(.no-number-zero-select):not(:disabled):not(:read-only)'
                    + ', input[type="text"]:not(.no-number-zero-select):not(:disabled):not(:read-only)[inputmode="numeric"]'
                    + ', input[type="text"]:not(.no-number-zero-select):not(:disabled):not(:read-only)[inputmode="decimal"]'
                );
            }

            function keyDigitOrEmpty(ev) {
                if (!ev.key || ev.key.length !== 1) return '';
                if (ev.ctrlKey || ev.metaKey || ev.altKey || ev.repeat) return '';
                var c = ev.key;
                return (c >= '0' && c <= '9') ? c : '';
            }

            function dispatchInputSyn(el) {
                try {
                    el.dispatchEvent(new Event('input', { bubbles: true }));
                } catch (eI) {}

                try {
                    el.dispatchEvent(new Event('change', { bubbles: true }));
                } catch (eC) {}
            }

            function pasteNormalized(text, decimalOk) {
                var s = String(text || '').replace(/\s+/g, '');
                if (!decimalOk) {
                    var i;
                    var o = '';

                    for (i = 0; i < s.length; i++) {
                        var ch = s.charCodeAt(i);
                        if (ch >= 48 && ch <= 57) o += s.charAt(i);
                    }

                    return o;
                }
                var j;
                var out = '';

                var seenDot = false;
                for (j = 0; j < s.length; j++) {
                    var cu = s.charAt(j);

                    var code = s.charCodeAt(j);
                    if (code >= 48 && code <= 57) {
                        out += cu;

                        continue;
                    }
                    if ((cu === '.' || cu === ',') && !seenDot) {
                        out += '.';
                        seenDot = true;
                    }
                }

                return out.replace(/\.+$/, '');
            }

            document.addEventListener('keydown', function (ev) {
                var el = ev.target;

                if (!(el.matches && el.matches(fieldSelector()))) return;
                if (!isZeroPlaceholder(String(el.value))) return;
                var d = keyDigitOrEmpty(ev);

                if (!d) return;
                ev.preventDefault();
                el.value = d;
                dispatchInputSyn(el);
            }, true);

            document.addEventListener('paste', function (ev) {
                var elP = ev.target;

                if (!(elP.matches && elP.matches(fieldSelector()))) return;
                if (!isZeroPlaceholder(String(elP.value))) return;
                var dec = !!(elP.matches && elP.matches('input[inputmode="decimal"]'));
                var raw = '';

                try {
                    raw = (ev.clipboardData || window.clipboardData).getData('text') || '';
                } catch (eA) {}

                var norm = pasteNormalized(raw, dec);

                if (norm === '' || norm === '.' || norm === '-') return;
                ev.preventDefault();
                elP.value = norm;
                dispatchInputSyn(elP);
            }, true);

            document.addEventListener('focusin', function (ev) {
                var ef = ev.target;

                if (!(ef.matches && ef.matches(fieldSelector()))) return;
                if (!isZeroPlaceholder(String(ef.value))) return;

                window.requestAnimationFrame(function () {
                    try {
                        if (typeof ef.setSelectionRange === 'function') {
                            var len = String(ef.value || '').length;

                            ef.setSelectionRange(0, len);

                            return;
                        }
                    } catch (e1) {}

                    try {
                        ef.select();
                    } catch (e2) {}
                });
            });

            document.addEventListener('pointerdown', function (ev) {
                var ep = ev.target;

                if (!(ep.matches && ep.matches(fieldSelector()))) return;
                if (!isZeroPlaceholder(String(ep.value))) return;

                function blockUp(evUp) {
                    evUp.preventDefault();

                    evUp.stopPropagation?.();
                    ep.removeEventListener('pointerup', blockUp, true);
                    ep.removeEventListener('mouseup', blockUp, true);
                }

                ep.addEventListener('pointerup', blockUp, true);
                ep.addEventListener('mouseup', blockUp, true);
            }, true);
        })();
        </script>
        <script>
        function __betaWelcomeVisible() {
            var m = document.getElementById('beta-welcome-modal');
            return !!(m && !m.hasAttribute('hidden'));
        }
        (function () {
            var s = document.getElementById('global-flash-stack');
            if (s && s.querySelector('.flashes')) s.scrollIntoView({ behavior: 'smooth', block: 'start' });
        })();
        (function () {
            function closeErr() {
                var el = document.getElementById('error-flash-modal');
                if (!el) { document.removeEventListener('keydown', onEscErr); return; }
                el.remove();
                if (!document.getElementById('success-flash-modal') && !__betaWelcomeVisible()) {
                    document.body.classList.remove('flash-center-open');
                }
                document.removeEventListener('keydown', onEscErr);
            }
            function onEscErr(ev) { if (ev.key === 'Escape') closeErr(); }
            var o = document.getElementById('error-flash-modal');
            if (o) {
            document.body.classList.add('flash-center-open');
            var okE = o.querySelector('.error-modal-ok');
            if (okE) okE.focus();
            o.addEventListener('click', function (ev) { if (ev.target === o) closeErr(); });
            o.querySelectorAll('[data-flash-center-close]').forEach(function (b) { b.addEventListener('click', closeErr); });
            document.addEventListener('keydown', onEscErr);
            }
        })();
        (function () {
            function closeOk() {
                var el = document.getElementById('success-flash-modal');
                if (!el) { document.removeEventListener('keydown', onEscOk); return; }
                el.remove();
                if (!document.getElementById('error-flash-modal') && !__betaWelcomeVisible()) {
                    document.body.classList.remove('flash-center-open');
                }
                document.removeEventListener('keydown', onEscOk);
            }
            function onEscOk(ev) { if (ev.key === 'Escape') closeOk(); }
            var s = document.getElementById('success-flash-modal');
            if (!s) return;
            document.body.classList.add('flash-center-open');
            var okB = s.querySelector('.success-modal-ok');
            if (okB) okB.focus();
            s.addEventListener('click', function (ev) { if (ev.target === s) closeOk(); });
            s.querySelectorAll('[data-flash-center-close]').forEach(function (b) { b.addEventListener('click', closeOk); });
            document.addEventListener('keydown', onEscOk);
        })();
        (function () {
            var STORAGE = 'optica_sklad_beta_welcome_intro_dismissed';
            var root = document.getElementById('beta-welcome-root');
            var modal = document.getElementById('beta-welcome-modal');
            var chip = document.getElementById('beta-welcome-chip');
            if (!root || !modal || !chip) return;

            function bodyLockApply() {
                if (__betaWelcomeVisible() ||
                    document.getElementById('error-flash-modal') ||
                    document.getElementById('success-flash-modal')) {
                    document.body.classList.add('flash-center-open');
                } else {
                    document.body.classList.remove('flash-center-open');
                }
            }

            function showModal() {
                chip.setAttribute('hidden', '');
                modal.removeAttribute('hidden');
                modal.setAttribute('aria-hidden', 'false');
                bodyLockApply();
                var panel = modal.querySelector('.beta-welcome-panel');
                if (panel) { panel.scrollTop = 0; }
                var okBtn = modal.querySelector('.beta-welcome-ok');
                if (okBtn) {
                    try { okBtn.focus({ preventScroll: true }); } catch (e1) { okBtn.focus(); }
                    if (panel) {
                        panel.scrollTop = 0;
                        window.requestAnimationFrame(function () {
                            panel.scrollTop = 0;
                            window.requestAnimationFrame(function () { panel.scrollTop = 0; });
                        });
                    }
                }
            }

            function hideModalPersistChip() {
                modal.setAttribute('hidden', '');
                modal.setAttribute('aria-hidden', 'true');
                try { window.sessionStorage.setItem(STORAGE, '1'); } catch (e2) {}
                chip.removeAttribute('hidden');
                bodyLockApply();
            }

            function onEscBeta(ev) {
                if (ev.key !== 'Escape' || !__betaWelcomeVisible()) return;
                ev.preventDefault();
                hideModalPersistChip();
            }

            modal.addEventListener('click', function (ev) {
                if (ev.target === modal) hideModalPersistChip();
            });
            modal.querySelectorAll('[data-beta-close]').forEach(function (btn) {
                btn.addEventListener('click', hideModalPersistChip);
            });

            chip.addEventListener('click', function () {
                showModal();
            });

            document.addEventListener('keydown', onEscBeta);

            var autoOpen = root.getAttribute('data-beta-auto-open-after-login') === '1';
            var dismissed = false;
            try { dismissed = window.sessionStorage.getItem(STORAGE) === '1'; } catch (eS) {}

            if (dismissed) {
                chip.removeAttribute('hidden');
            }
            if (autoOpen && !dismissed) {
                showModal();
            }
        })();
        </script>
    </body>
</html>

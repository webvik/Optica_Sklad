# Copy → `.env.local` (ignored by Git). Never commit real passwords or APP_SECRET.
# Generate APP_SECRET (32 bytes hex):  openssl rand -hex 32

### Development (workstation)
APP_ENV=dev
APP_SECRET=

# Match user / database / MariaDB banner from hosting panel (`mysqladmin version` → serverVersion=)
DATABASE_URL="mysql://USERNAME:PASSWORD@127.0.0.1:3306/lowpartners_app?serverVersion=mariadb-10.11.2&charset=utf8mb4"

DEFAULT_URI=http://localhost

### Production VPS (alternative: only these keys → copy `.env.prod.local.dist` → `.env.prod.local` plus `APP_ENV=prod` in `.env.local`)
# APP_ENV=prod
# APP_SECRET=
# DATABASE_URL="mysql://USER:PASS@127.0.0.1:3306/lowpartners_app?serverVersion=mariadb-10.11.2&charset=utf8mb4"
# DEFAULT_URI=https://lowpartners.net
